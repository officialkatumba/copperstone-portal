<footer class="mt-auto bg-dark text-light py-4">
  <div class="container text-center">
    <h4 class="fw-bold mb-2" style="color: var(--secondary-pink);">
      Copperstone University
    </h4>
    <p class="mb-2 text-white-50">
      Excellence in Education & Innovation
    </p>
    <p class="small text-white-50 mb-0">
      &copy; <%= new Date().getFullYear() %> Copperstone University. All rights reserved.
    </p>
  </div>
</footer>

<!-- Bootstrap Bundle JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<!-- Flash Messages -->
<script>
  <% if (typeof success_msg !== 'undefined' && success_msg.length > 0) { %>
    Swal.fire({
      icon: 'success',
      title: 'Success!',
      text: "<%= success_msg %>",
      confirmButtonColor: '#3085d6'
    });
  <% } %>

  <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
    Swal.fire({
      icon: 'error',
      title: 'Oops!',
      text: "<%= error_msg %>",
      confirmButtonColor: '#d33'
    });
  <% } %>

  <% if (typeof info !== 'undefined' && info.length > 0) { %>
    Swal.fire({
      icon: 'info',
      title: 'Notice',
      text: "<%= info %>",
      confirmButtonColor: '#3085d6'
    });
  <% } %>
</script>
<!-- Form Submission Prevention -->
<script>
  // Prevent multiple form submissions
  document.addEventListener('DOMContentLoaded', function() {
    // Add event listener to all forms
    document.addEventListener('submit', function(e) {
      const form = e.target;
      
      // Only process if it's a form element
      if (form.tagName === 'FORM') {
        // Check if form is already submitting
        if (form.classList.contains('submitting')) {
          e.preventDefault();
          e.stopPropagation();
          return false;
        }
        
        // Mark form as submitting
        form.classList.add('submitting');
        
        // Find all submit buttons in this form
        const submitButtons = form.querySelectorAll('button[type="submit"], input[type="submit"]');
        
        // Disable all submit buttons and show loading state
        submitButtons.forEach(button => {
          const originalText = button.innerHTML;
          button.setAttribute('data-original-text', originalText);
          button.disabled = true;
          
          // Add loading spinner
          button.innerHTML = `
            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
            Processing...
          `;
          
          // Store original styles
          const originalCursor = button.style.cursor;
          const originalOpacity = button.style.opacity;
          
          button.style.cursor = 'not-allowed';
          button.style.opacity = '0.7';
          
          // Store for restoration
          button.setAttribute('data-original-cursor', originalCursor);
          button.setAttribute('data-original-opacity', originalOpacity);
        });
        
        // Add a global overlay for visual feedback
        const overlay = document.createElement('div');
        overlay.id = 'submission-overlay';
        overlay.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background: rgba(0, 0, 0, 0.1);
          z-index: 9999;
          display: flex;
          justify-content: center;
          align-items: center;
          pointer-events: none;
        `;
        
        // Add loading spinner to overlay
        overlay.innerHTML = `
          <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
        `;
        
        document.body.appendChild(overlay);
        
        // Store overlay reference on form for cleanup
        form.setAttribute('data-overlay', 'true');
        
        // Set timeout to handle if form submission takes too long
        const timeoutId = setTimeout(() => {
          console.warn('Form submission is taking longer than expected. Consider checking your network or server.');
        }, 30000); // 30 seconds timeout
        
        // Store timeout ID on form
        form.setAttribute('data-timeout-id', timeoutId);
        
        // Clean up function
        const cleanupForm = function(formElement) {
          if (!formElement) return;
          
          // Remove submitting class
          formElement.classList.remove('submitting');
          
          // Re-enable buttons and restore original text
          const buttons = formElement.querySelectorAll('button[type="submit"], input[type="submit"]');
          buttons.forEach(button => {
            button.disabled = false;
            const originalText = button.getAttribute('data-original-text');
            if (originalText) {
              button.innerHTML = originalText;
              button.removeAttribute('data-original-text');
            }
            
            // Restore original styles
            const originalCursor = button.getAttribute('data-original-cursor');
            const originalOpacity = button.getAttribute('data-original-opacity');
            
            if (originalCursor) button.style.cursor = originalCursor;
            if (originalOpacity) button.style.opacity = originalOpacity;
            
            button.removeAttribute('data-original-cursor');
            button.removeAttribute('data-original-opacity');
          });
          
          // Clear timeout
          const timeoutId = formElement.getAttribute('data-timeout-id');
          if (timeoutId) {
            clearTimeout(parseInt(timeoutId));
            formElement.removeAttribute('data-timeout-id');
          }
          
          // Remove overlay
          const overlay = document.getElementById('submission-overlay');
          if (overlay) {
            overlay.remove();
          }
        };
        
        // Handle form submission completion
        form.addEventListener('ajax:complete', function() {
          cleanupForm(form);
        });
        
        // Handle form submission error
        form.addEventListener('ajax:error', function() {
          cleanupForm(form);
        });
        
        // Fallback: Clean up after a delay if events don't fire
        setTimeout(() => {
          if (form.classList.contains('submitting')) {
            cleanupForm(form);
          }
        }, 30000); // Clean up after 30 seconds max
        
        // For non-AJAX forms, cleanup will happen on page unload
        // For AJAX forms using fetch or XMLHttpRequest, override to trigger cleanup
        const originalSubmit = HTMLFormElement.prototype.submit;
        HTMLFormElement.prototype.submit = function() {
          if (this === form) {
            // For standard form submission, cleanup on next tick
            setTimeout(() => cleanupForm(this), 1000);
          }
          return originalSubmit.apply(this, arguments);
        };
      }
    });
    
    // Also handle button clicks that might submit forms programmatically
    document.addEventListener('click', function(e) {
      const button = e.target.closest('button[type="submit"]');
      if (button) {
        const form = button.closest('form');
        if (form) {
          // This will be handled by the submit event above
        }
      }
    });
    
    // Add CSS for spinner animation
    const style = document.createElement('style');
    style.textContent = `
      @keyframes spinner-border {
        to { transform: rotate(360deg); }
      }
      .spinner-border {
        display: inline-block;
        width: 1rem;
        height: 1rem;
        vertical-align: text-bottom;
        border: 0.15em solid currentColor;
        border-right-color: transparent;
        border-radius: 50%;
        animation: spinner-border .75s linear infinite;
      }
      .spinner-border-sm {
        width: 0.8rem;
        height: 0.8rem;
        border-width: 0.15em;
      }
      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
    `;
    document.head.appendChild(style);
  });
</script>
<!-- Password Toggle Visibility -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // Function to create password toggle for a specific input
    function addPasswordToggle(passwordInput) {
      // Only process password inputs that don't already have a toggle
      if (!passwordInput || passwordInput.type !== 'password' || 
          passwordInput.parentElement.querySelector('.password-toggle')) {
        return;
      }
      
      // Create toggle wrapper
      const wrapper = document.createElement('div');
      wrapper.className = 'position-relative';
      
      // Wrap the input with the wrapper
      passwordInput.parentNode.insertBefore(wrapper, passwordInput);
      wrapper.appendChild(passwordInput);
      
      // Create toggle button
      const toggleButton = document.createElement('button');
      toggleButton.type = 'button';
      toggleButton.className = 'btn password-toggle';
      toggleButton.style.cssText = `
        position: absolute;
        right: 10px;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        color: #6c757d;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
      `;
      
      // Create eye icon
      const eyeIcon = document.createElement('i');
      eyeIcon.className = 'fas fa-eye';
      toggleButton.appendChild(eyeIcon);
      
      // Add tooltip
      toggleButton.title = 'Show password';
      toggleButton.setAttribute('aria-label', 'Show password');
      
      // Insert toggle button
      wrapper.appendChild(toggleButton);
      
      // Toggle password visibility
      toggleButton.addEventListener('click', function() {
        const isPassword = passwordInput.type === 'password';
        
        if (isPassword) {
          passwordInput.type = 'text';
          eyeIcon.className = 'fas fa-eye-slash';
          this.title = 'Hide password';
          this.setAttribute('aria-label', 'Hide password');
        } else {
          passwordInput.type = 'password';
          eyeIcon.className = 'fas fa-eye';
          this.title = 'Show password';
          this.setAttribute('aria-label', 'Show password');
        }
        
        // Keep focus on the input
        passwordInput.focus();
      });
      
      // Add hover effect
      toggleButton.addEventListener('mouseenter', function() {
        this.style.color = 'var(--primary-purple)';
      });
      
      toggleButton.addEventListener('mouseleave', function() {
        this.style.color = '#6c757d';
      });
      
      // Handle focus states
      passwordInput.addEventListener('focus', function() {
        toggleButton.style.color = 'var(--primary-purple)';
      });
      
      passwordInput.addEventListener('blur', function() {
        toggleButton.style.color = '#6c757d';
      });
    }
    
    // Process all password inputs on page load
    const passwordInputs = document.querySelectorAll('input[type="password"]');
    passwordInputs.forEach(addPasswordToggle);
    
    // Watch for dynamically added password inputs (optional)
    const observer = new MutationObserver(function(mutations) {
      mutations.forEach(function(mutation) {
        if (mutation.addedNodes.length) {
          mutation.addedNodes.forEach(function(node) {
            if (node.nodeType === 1) { // Element node
              const newPasswordInputs = node.querySelectorAll 
                ? node.querySelectorAll('input[type="password"]')
                : node.nodeName === 'INPUT' && node.type === 'password' 
                  ? [node] 
                  : [];
              
              newPasswordInputs.forEach(addPasswordToggle);
            }
          });
        }
      });
    });
    
    // Start observing the document body for added nodes
    observer.observe(document.body, {
      childList: true,
      subtree: true
    });
  });
</script>
</body>
</html>
