<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <!-- PAGE HEADER -->
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: var(--primary-purple)">
                    <i class="fas fa-users me-2"></i>All Students
                </h2>
                <p class="lead text-muted">
                    Manage student academic records and clearance
                    <br>
                    <small class="text-info">
                        Total Students: <%- stats.total || 0 %> | Filtered: <%- totalCount || 0 %>
                    </small>
                </p>
            </div>

            <!-- SUMMARY SECTION -->
            <div class="row mb-5">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-4" style="color: var(--primary-purple)">
                                <i class="fas fa-chart-line me-2"></i>Summary Overview
                            </h4>
                            <div class="row g-3">
                                <!-- Total Students -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e3f2fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #2196f3;">
                                            <i class="fas fa-users fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats.total || 0 %>
                                            </h5>
                                            <small class="text-muted">Total Students</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Cleared Students -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #d1f7c4;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #4caf50;">
                                            <i class="fas fa-check-circle fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats.cleared || 0 %>
                                            </h5>
                                            <small class="text-muted">Cleared</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pending Clearances -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fff3cd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #ff9800;">
                                            <i class="fas fa-hourglass-half fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats.pending || 0 %>
                                            </h5>
                                            <small class="text-muted">Pending</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Filtered Students -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #f3e5f5;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #9c27b0;">
                                            <i class="fas fa-filter fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- totalCount || 0 %>
                                            </h5>
                                            <small class="text-muted">Filtered</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FILTERS -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-3">
                            <input type="text" name="search" class="form-control"
                                placeholder="Search name, email, NURTE #" value="<%= search %>">
                        </div>
                        <div class="col-md-2">
                            <select name="programme" class="form-select">
                                <option value="">All Programmes</option>
                                <% programmes.forEach(function(p){ %>
                                    <option value="<%= p._id %>" <%=programmeFilter===p._id.toString() ? 'selected' : ''
                                        %>>
                                        <%= p.name %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select name="semester" class="form-select">
                                <option value="">All Semesters</option>
                                <% for(let i=1; i<=8; i++){ %>
                                    <option value="<%= i %>" <%=semesterFilter===i.toString() ? 'selected' : '' %>>
                                        Semester <%= i %>
                                    </option>
                                    <% } %>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <select name="limit" class="form-select" onchange="this.form.submit()">
                                <option value="20" <%=limit===20 ? 'selected' : '' %>>20 per page</option>
                                <option value="50" <%=limit===50 ? 'selected' : '' %>>50 per page</option>
                                <option value="100" <%=limit===100 ? 'selected' : '' %>>100 per page</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <div class="d-grid gap-2 d-md-flex">
                                <button type="submit" class="btn btn-primary flex-fill">
                                    <i class="fas fa-filter me-1"></i> Filter
                                </button>
                                <a href="/director-academic/students" class="btn btn-outline-secondary">
                                    <i class="fas fa-redo me-1"></i> Reset
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- STUDENTS TABLE -->
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Student</th>
                                <th>Contact</th>
                                <th>Programme</th>
                                <th>Sem</th>
                                <th>Clearance</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!students || students.length===0) { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4">
                                        <div class="text-muted">
                                            <i class="fas fa-users fa-2x mb-3"></i>
                                            <p>No students found</p>
                                        </div>
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% students.forEach(function(s, index) { const clearance=s.studentProfile &&
                                        s.studentProfile.academicClearance ?
                                        s.studentProfile.academicClearance.currentSemesterClearance : {
                                        clearanceLevel: 'Pending' }; let badgeClass='' ;
                                        switch(clearance.clearanceLevel) { case 'Full' : badgeClass='bg-success' ;
                                        break; case 'Partial' : badgeClass='bg-warning text-dark' ; break; case 'Denied'
                                        : badgeClass='bg-danger' ; break; default: badgeClass='bg-info' ; } %>
                                        <tr>
                                            <td><%- (currentPage - 1) * limit + index + 1 %></td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-3"
                                                        style="width: 40px; height: 40px;">
                                                        <% if (s.profilePicture) { %>
                                                            <img src="<%- s.profilePicture %>" class="rounded-circle"
                                                                style="width: 100%; height: 100%; object-fit: cover;">
                                                            <% } else { %>
                                                                <i class="fas fa-user text-muted"></i>
                                                                <% } %>
                                                    </div>
                                                    <div>
                                                        <strong><%- s.firstName %> <%- s.surname %></strong><br>
                                                        <small class="text-muted">
                                                            ID: <%- s.studentProfile && s.studentProfile.nurteNumber ?
                                                                s.studentProfile.nurteNumber : 'No NURTE' %>
                                                        </small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <small><%- s.email %></small><br>
                                                <small class="text-muted">
                                                    <%- s.mobile || 'No phone' %>
                                                </small>
                                            </td>
                                            <td>
                                                <%- s.programme ? s.programme.name : '—' %><br>
                                                    <small class="text-muted">
                                                        <%- s.programme ? s.programme.code : '' %>
                                                    </small>
                                            </td>
                                            <td>
                                                <span class="badge bg-secondary">Sem <%- s.currentSemester || '—'
                                                        %></span>
                                            </td>
                                            <td>
                                                <span class="badge <%- badgeClass %>">
                                                    <%- clearance.clearanceLevel || 'Pending' %>
                                                </span>
                                            </td>
                                            <td>
                                                <a href="/director-academic/students/<%- s._id %>"
                                                    class="btn btn-sm btn-primary">
                                                    <i class="fas fa-eye me-1"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- PAGINATION -->
            <% if (totalPages> 1) { %>
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                            <a class="page-link"
                                href="?page=<%- currentPage - 1 %>&limit=<%- limit %>&search=<%- search %>&programme=<%- programmeFilter %>&semester=<%- semesterFilter %>">
                                Previous
                            </a>
                        </li>

                        <% const startPage=Math.max(1, currentPage - 2); const endPage=Math.min(totalPages, currentPage
                            + 2); %>

                            <% if (startPage> 1) { %>
                                <li class="page-item">
                                    <a class="page-link" href="?page=1&limit=<%- limit %>">1</a>
                                </li>
                                <% if (startPage> 2) { %>
                                    <li class="page-item disabled"><span class="page-link">…</span></li>
                                    <% } %>
                                        <% } %>

                                            <% for(let i=startPage; i <=endPage; i++) { %>
                                                <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                                    <a class="page-link"
                                                        href="?page=<%- i %>&limit=<%- limit %>&search=<%- search %>&programme=<%- programmeFilter %>&semester=<%- semesterFilter %>">
                                                        <%- i %>
                                                    </a>
                                                </li>
                                                <% } %>

                                                    <% if (endPage < totalPages) { %>
                                                        <% if (endPage < totalPages - 1) { %>
                                                            <li class="page-item disabled"><span
                                                                    class="page-link">…</span></li>
                                                            <% } %>
                                                                <li class="page-item">
                                                                    <a class="page-link"
                                                                        href="?page=<%- totalPages %>&limit=<%- limit %>&search=<%- search %>&programme=<%- programmeFilter %>&semester=<%- semesterFilter %>">
                                                                        <%- totalPages %>
                                                                    </a>
                                                                </li>
                                                                <% } %>

                                                                    <li
                                                                        class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                                        <a class="page-link"
                                                                            href="?page=<%- currentPage + 1 %>&limit=<%- limit %>&search=<%- search %>&programme=<%- programmeFilter %>&semester=<%- semesterFilter %>">
                                                                            Next
                                                                        </a>
                                                                    </li>
                    </ul>
                </nav>
                <% } %>
        </div>

        <!-- Export Modal -->
        <div class="modal fade" id="exportModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Export Student Data</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <form action="/director-academic/students/export" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Select Format</label>
                                <select class="form-select" name="format">
                                    <option value="csv">CSV (Excel)</option>
                                    <option value="pdf">PDF Report</option>
                                    <option value="json">JSON Data</option>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Include Columns</label>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="columns[]" value="personal"
                                        checked>
                                    <label class="form-check-label">Personal Information</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="columns[]" value="academic"
                                        checked>
                                    <label class="form-check-label">Academic Details</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="columns[]" value="financial">
                                    <label class="form-check-label">Financial Status</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="columns[]" value="clearance"
                                        checked>
                                    <label class="form-check-label">Clearance Status</label>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Export</button>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>