<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <!-- PAGE HEADING -->
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: var(--primary-purple)">Student Payments</h2>
                <p class="text-muted">View payment records for academic oversight</p>
            </div>

            <!-- ===================================== -->
            <!-- 4 SUMMARY CARDS (Simplified) -->
            <!-- ===================================== -->
            <div class="row g-4 mb-5">
                <!-- Total Today -->
                <div class="col-md-3 col-6">
                    <div class="card text-center border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-primary mb-2">
                                <i class="fas fa-calendar-day fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                ZMW <%= Number(totalToday || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                    maximumFractionDigits: 2}) %>
                            </h3>
                            <p class="text-muted mb-0">Today</p>
                            <small class="text-primary">
                                <%= today %>
                            </small>
                        </div>
                    </div>
                </div>

                <!-- This Month -->
                <div class="col-md-3 col-6">
                    <div class="card text-center border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-success mb-2">
                                <i class="fas fa-calendar-alt fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                ZMW <%= Number(totalMonth || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                    maximumFractionDigits: 2}) %>
                            </h3>
                            <p class="text-muted mb-0">This Month</p>
                            <small class="text-success">
                                <%= monthRange %>
                            </small>
                        </div>
                    </div>
                </div>

                <!-- This Year -->
                <div class="col-md-3 col-6">
                    <div class="card text-center border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-warning mb-2">
                                <i class="fas fa-calendar fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                ZMW <%= Number(totalYear || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                    maximumFractionDigits: 2}) %>
                            </h3>
                            <p class="text-muted mb-0">This Year</p>
                            <small class="text-warning">
                                <%= yearRange %>
                            </small>
                        </div>
                    </div>
                </div>

                <!-- Total All -->
                <div class="col-md-3 col-6">
                    <div class="card text-center border-0 shadow-sm h-100">
                        <div class="card-body">
                            <div class="text-secondary mb-2">
                                <i class="fas fa-wallet fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                ZMW <%= Number(totalAll || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                    maximumFractionDigits: 2}) %>
                            </h3>
                            <p class="text-muted mb-0">All Time</p>
                            <small class="text-secondary">Total Revenue</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- FILTERS AND SEARCH -->
            <!-- ===================================== -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-5">
                            <input type="text" name="search" class="form-control"
                                placeholder="Search by student name, email, or NURTE" value="<%= search || '' %>">
                        </div>

                        <div class="col-md-3">
                            <select name="category" class="form-select">
                                <option value="">All Categories</option>
                                <option value="Tuition Fee (Per Semester)" <%=category==='Tuition Fee (Per Semester)'
                                    ? 'selected' : '' %>>Tuition Fee</option>
                                <option value="Boarding Fee" <%=category==='Boarding Fee' ? 'selected' : '' %>>Boarding
                                    Fee</option>
                                <option value="Application Fee" <%=category==='Application Fee' ? 'selected' : '' %>
                                    >Application Fee</option>
                                <option value="Registration Fee" <%=category==='Registration Fee' ? 'selected' : '' %>
                                    >Registration Fee</option>
                                <option value="Exam Fee" <%=category==='Exam Fee' ? 'selected' : '' %>>Exam Fee</option>
                                <option value="Graduation Fee" <%=category==='Graduation Fee' ? 'selected' : '' %>
                                    >Graduation Fee</option>
                                <option value="Other" <%=category==='Other' ? 'selected' : '' %>>Other</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <select name="limit" class="form-select" onchange="this.form.submit()">
                                <option value="20" <%=limit===20 ? 'selected' : '' %>>20 per page</option>
                                <option value="50" <%=limit===50 ? 'selected' : '' %>>50 per page</option>
                                <option value="100" <%=limit===100 ? 'selected' : '' %>>100 per page</option>
                            </select>
                        </div>

                        <div class="col-md-1">
                            <button class="btn btn-primary w-100">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>

                        <div class="col-md-1">
                            <a href="/director-academic/payments" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-redo"></i>
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- PAYMENTS TABLE -->
            <!-- ===================================== -->
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-list me-2"></i>Payment Records
                        <span class="badge bg-primary ms-2">
                            <%= totalCount %> payments
                        </span>
                    </h5>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Student Details</th>
                                <th>Category</th>
                                <th>Amount Paid</th>
                                <th>Balance</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!payments || payments.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-5">
                                        <i class="fas fa-search fa-2x mb-3"></i>
                                        <p>No payments found matching your criteria</p>
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% payments.forEach(function(p, index) { %>
                                        <tr>
                                            <td class="fw-bold">
                                                <%= (currentPage - 1) * limit + index + 1 %>
                                            </td>

                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                                        style="width:40px; height:40px;">
                                                        <i class="fas fa-user-graduate text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <strong>
                                                            <%= p.student ? p.student.firstName + ' ' +
                                                                p.student.surname : 'N/A' %>
                                                        </strong><br>
                                                        <small class="text-muted">
                                                            <%= p.student ? p.student.email : '' %>
                                                        </small><br>
                                                        <% if (p.student && p.student.studentProfile &&
                                                            p.student.studentProfile.nurteNumber) { %>
                                                            <small class="text-info">NURTE: <%=
                                                                    p.student.studentProfile.nurteNumber %></small>
                                                            <% } %>
                                                    </div>
                                                </div>
                                            </td>


                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    <%= p.category %>
                                                </span>
                                            </td>

                                            <td class="fw-bold" style="color: var(--primary-purple)">
                                                ZMW <%= Number(p.amount || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </td>

                                            <td>
                                                <% if ((p.balanceAfterPayment || 0)> 0) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-clock me-1"></i>ZMW <%=
                                                            Number(p.balanceAfterPayment || 0).toLocaleString('en-US',
                                                            {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-check me-1"></i>Paid
                                                        </span>
                                                        <% } %>
                                            </td>

                                            <td>
                                                <% const statusClass=p.status==='Verified' || p.status==='Fully Paid'
                                                    ? 'bg-success' : p.status==='Partially Paid'
                                                    ? 'bg-warning text-dark' : p.status==='Pending' ? 'bg-secondary' :
                                                    p.status==='Cancelled' || p.status==='Rejected' ? 'bg-danger'
                                                    : 'bg-light text-dark' ; %>
                                                    <span class="badge <%= statusClass %>">
                                                        <%= p.status %>
                                                    </span>
                                            </td>

                                            <td>
                                                <small>
                                                    <%= new Date(p.createdAt).toLocaleDateString() %>
                                                </small><br>
                                                <small class="text-muted">
                                                    <%= new Date(p.createdAt).toLocaleTimeString([], { hour: '2-digit' ,
                                                        minute: '2-digit' }) %>
                                                </small>
                                            </td>

                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= p._id %>">
                                                    <i class="fas fa-eye me-1"></i>View
                                                </button>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- PAGINATION AND FOOTER -->
            <!-- ===================================== -->
            <% if (payments && payments.length> 0) { %>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Showing <strong>
                            <%= (currentPage - 1) * limit + 1 %> to <%= Math.min(currentPage * limit, totalCount) %>
                        </strong>
                        of <strong>
                            <%= totalCount %>
                        </strong> payments
                    </div>

                    <% if (totalPages> 1) { %>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="?page=<%= currentPage-1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>

                                <% for(let i=Math.max(1, currentPage - 2); i <=Math.min(totalPages, currentPage + 2);
                                    i++) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                        <a class="page-link"
                                            href="?page=<%= i %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>

                                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                            <a class="page-link"
                                                href="?page=<%= currentPage+1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                                <i class="fas fa-chevron-right"></i>
                                            </a>
                                        </li>
                            </ul>
                        </nav>
                        <% } %>
                </div>
                <% } %>
        </div>

        <!-- ===================================== -->
        <!-- PAYMENT MODALS (VIEW ONLY) -->
        <!-- ===================================== -->
        <% if (payments && payments.length> 0) { %>
            <% payments.forEach(function(payment) { %>
                <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered modal-lg">
                        <div class="modal-content">
                            <div class="modal-header" style="background-color: var(--primary-purple); color: white;">
                                <h5 class="modal-title fw-bold">
                                    <i class="fas fa-file-invoice-dollar me-2"></i>Payment Details
                                </h5>
                                <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">
                                <!-- Student Header -->
                                <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                        style="width:60px; height:60px;">
                                        <i class="fas fa-user-graduate fa-2x text-primary"></i>
                                    </div>
                                    <div>
                                        <h5 class="mb-1">
                                            <%= payment.student.firstName %>
                                                <%= payment.student.surname %>
                                        </h5>
                                        <p class="text-muted mb-1">
                                            <%= payment.student.email %>
                                        </p>
                                        <% if (payment.student.studentProfile &&
                                            payment.student.studentProfile.nurteNumber) { %>
                                            <span class="badge bg-info">NURTE: <%=
                                                    payment.student.studentProfile.nurteNumber %></span>
                                            <% } %>
                                                <% if (payment.student.programme) { %>
                                                    <div class="mt-1">
                                                        <span class="badge bg-light text-dark">
                                                            <%= payment.student.programme.name %>
                                                        </span>
                                                        <span class="badge bg-light text-dark ms-1">Sem <%=
                                                                payment.student.currentSemester %></span>
                                                    </div>
                                                    <% } %>
                                    </div>
                                </div>

                                <!-- Payment Details Grid -->
                                <div class="row">
                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <small class="text-muted d-block">Payment ID</small>
                                            <code><%= payment._id %></code>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Category</small>
                                            <h6 class="mb-0">
                                                <%= payment.category %>
                                            </h6>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Description</small>
                                            <p class="mb-0">
                                                <%= payment.description || 'No description provided' %>
                                            </p>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Payment Method</small>
                                            <span class="badge bg-info text-white">
                                                <%= payment.method %>
                                            </span>
                                        </div>
                                    </div>

                                    <div class="col-md-6">
                                        <div class="mb-3">
                                            <small class="text-muted d-block">Total Amount Due</small>
                                            <h4 class="text-success">ZMW <%= Number(payment.totalDue || payment.amount
                                                    || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                                    maximumFractionDigits: 2}) %>
                                            </h4>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Amount Paid</small>
                                            <h4 class="text-primary">ZMW <%= Number(payment.amount ||
                                                    0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                                    maximumFractionDigits: 2}) %>
                                            </h4>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Balance Outstanding</small>
                                            <h4 class="text-warning">ZMW <%= Number(payment.balanceAfterPayment ||
                                                    0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                                    maximumFractionDigits: 2}) %>
                                            </h4>
                                        </div>

                                        <div class="mb-3">
                                            <small class="text-muted d-block">Status</small>
                                            <% const statusClass=payment.status==='Verified' ||
                                                payment.status==='Fully Paid' ? 'bg-success' :
                                                payment.status==='Partially Paid' ? 'bg-warning text-dark' :
                                                payment.status==='Pending' ? 'bg-secondary' :
                                                payment.status==='Cancelled' || payment.status==='Rejected'
                                                ? 'bg-danger' : 'bg-light text-dark' ; %>
                                                <span class="badge <%= statusClass %> fs-6 p-2">
                                                    <%= payment.status %>
                                                </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Academic Details -->
                                <% if (payment.semester || payment.academicYear) { %>
                                    <div class="border-top pt-3 mt-3">
                                        <h6 class="fw-bold mb-3">Academic Information</h6>
                                        <div class="row">
                                            <% if (payment.semester) { %>
                                                <div class="col-md-6">
                                                    <small class="text-muted d-block">Semester</small>
                                                    <span>Semester <%= payment.semester %></span>
                                                </div>
                                                <% } %>
                                                    <% if (payment.academicYear) { %>
                                                        <div class="col-md-6">
                                                            <small class="text-muted d-block">Academic Year</small>
                                                            <span>
                                                                <%= payment.academicYear %>
                                                            </span>
                                                        </div>
                                                        <% } %>
                                        </div>
                                    </div>
                                    <% } %>

                                        <!-- Receipt Section (View Only) -->
                                        <% if (payment.receipt && payment.receipt.gcsUrl) { %>
                                            <div class="border-top pt-3 mt-3">
                                                <h6 class="fw-bold mb-3">Receipt</h6>
                                                <a href="<%= payment.receipt.gcsUrl %>" target="_blank"
                                                    class="btn btn-success">
                                                    <i class="fas fa-file-pdf me-1"></i> View Receipt
                                                </a>
                                                <a href="<%= payment.receipt.gcsUrl %>" download
                                                    class="btn btn-outline-success ms-2">
                                                    <i class="fas fa-download me-1"></i> Download
                                                </a>
                                            </div>
                                            <% } %>
                            </div>

                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <% if (payment.receipt && payment.receipt.gcsUrl) { %>
                                    <a href="<%= payment.receipt.gcsUrl %>" target="_blank" class="btn btn-primary">
                                        <i class="fas fa-print me-1"></i> Print Receipt
                                    </a>
                                    <% } %>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
                    <% } %>

                        <%- include('../partials/footer') %>