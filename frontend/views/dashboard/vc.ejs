<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: var(--primary-purple)">
                    Vice-Chancellor Dashboard
                </h2>
                <p class="lead text-muted">
                    Welcome, <strong>
                        <%= user.firstName %>
                            <%= user.surname %>
                    </strong> — You are logged in as
                    <strong>Vice-Chancellor</strong>.
                    <br>
                    <small class="text-info">
                        University Head | Full System Access
                    </small>
                </p>
            </div>

            <!-- Summary Section (Same style as Director Academic) -->
            <div class="row mb-5">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-4" style="color: var(--primary-purple)">
                                <i class="fas fa-chart-line me-2"></i>University Overview
                            </h4>
                            <div class="row g-3">
                                <!-- Total Students -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e3f2fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #2196f3;">
                                            <i class="fas fa-users fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats && stats.totalStudents ? stats.totalStudents : 0 %>
                                            </h5>
                                            <small class="text-muted">Total Students</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Staff -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fce4ec;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #e91e63;">
                                            <i class="fas fa-chalkboard-teacher fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats && stats.totalStaff ? stats.totalStaff : 0 %>
                                            </h5>
                                            <small class="text-muted">Total Staff</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Pending Approvals -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fff3cd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #ff9800;">
                                            <i class="fas fa-clock fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats && stats.pendingApprovals ? stats.pendingApprovals : 0 %>
                                            </h5>
                                            <small class="text-muted">Pending Approvals</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Active Issues -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #ffebee;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #f44336;">
                                            <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                <%- stats && stats.activeIssues ? stats.activeIssues : 0 %>
                                            </h5>
                                            <small class="text-muted">Active Issues</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dashboard Cards - 6 cards total (3x2 layout) -->
            <div class="row g-4 justify-content-center">
                <!-- All Payments -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-money-bill-wave fa-3x mb-3" style="color: #6f42c1;"></i>
                            <h5 class="card-title fw-bold">All Payments</h5>
                            <p class="card-text text-muted">
                                View all institution-wide payment transactions
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/payments" class="btn" style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-list-alt me-1"></i> View Payments
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- All Expenses -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-file-invoice-dollar fa-3x mb-3 text-danger"></i>
                            <h5 class="card-title fw-bold">All Expenses</h5>
                            <p class="card-text text-muted">
                                Comprehensive view of university expenditures
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/expenses" class="btn btn-danger">
                                    <i class="fas fa-chart-line me-1"></i> View Expenses
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- All Staff -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-users fa-3x mb-3" style="color: #20c997;"></i>
                            <h5 class="card-title fw-bold" style="color: #20c997;">All Staff</h5>
                            <p class="card-text text-muted">
                                Manage all university staff members
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/manage-staff" class="btn" style="background-color: #20c997; color: white;">
                                    <i class="fas fa-user-tie me-1"></i> View Staff
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reports -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-chart-bar fa-3x mb-3 text-info"></i>
                            <h5 class="card-title fw-bold">Reports</h5>
                            <p class="card-text text-muted">
                                Comprehensive university reports and analytics
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/reports" class="btn btn-info text-white">
                                    <i class="fas fa-chart-pie me-1"></i> View Reports
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- University Management -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-landmark fa-3x mb-3 text-primary"></i>
                            <h5 class="card-title fw-bold">University Management</h5>
                            <p class="card-text text-muted">
                                Manage Deans, HODs, DVCs and oversee senior staff
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/manage-deans" class="btn btn-primary">
                                    <i class="fas fa-user-graduate me-1"></i> Manage Deans
                                </a>
                                <!-- <a href="/vc/manage-hods" class="btn btn-info text-white">
                                    <i class="fas fa-user-tie me-1"></i> Manage HODs
                                </a> -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Academic Oversight -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-graduation-cap fa-3x mb-3 text-success"></i>
                            <h5 class="card-title fw-bold">Academic Oversight</h5>
                            <p class="card-text text-muted">
                                University-wide academic reports and programme approvals
                            </p>
                            <div class="d-grid gap-2">
                                <!-- <a href="/vc/reports/academic" class="btn btn-success">
                            <i class="fas fa-chart-bar me-1"></i> Academic Reports
                        </a> -->
                                <a href="/vc/approve-programmes" class="btn btn-outline-success">
                                    <i class="fas fa-check-circle me-1"></i> Approve Programmes
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="row mt-5">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body">
                            <h5 class="fw-bold mb-3" style="color: var(--primary-purple)">
                                <i class="fas fa-bolt me-2"></i>Quick Access
                            </h5>
                            <div class="row g-2">
                                <div class="col-md-2 col-6">
                                    <a href="/vc/manage-deans" class="btn btn-outline-primary w-100">
                                        <i class="fas fa-user-graduate me-1"></i> Deans
                                    </a>
                                </div>
                                <div class="col-md-2 col-6">
                                    <a href="/vc/manage-hods" class="btn btn-outline-info w-100">
                                        <i class="fas fa-user-tie me-1"></i> HODs
                                    </a>
                                </div>
                                <div class="col-md-2 col-6">
                                    <a href="/vc/pending-payments" class="btn btn-outline-warning w-100">
                                        <i class="fas fa-clock me-1"></i> Pending
                                    </a>
                                </div>
                                <div class="col-md-2 col-6">
                                    <a href="/vc/discipline" class="btn btn-outline-danger w-100">
                                        <i class="fas fa-gavel me-1"></i> Discipline
                                    </a>
                                </div>
                                <div class="col-md-2 col-6">
                                    <a href="/vc/inbox" class="btn btn-outline-secondary w-100">
                                        <i class="fas fa-inbox me-1"></i> Inbox
                                    </a>
                                </div>
                                <div class="col-md-2 col-6">
                                    <a href="/profile" class="btn btn-outline-dark w-100">
                                        <i class="fas fa-user-cog me-1"></i> Profile
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>