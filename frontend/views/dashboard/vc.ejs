<!--// frontend/views/dashboard/vc.ejs -->

<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <!-- Header Section -->
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: var(--primary-purple)">Vice-Chancellor Dashboard</h2>
                <p class="lead text-muted">
                    Welcome,Prof. <strong>
                        <%= user.firstName %>
                            <%= user.surname %>
                    </strong> — You are logged in as
                    <strong>Vice-Chancellor</strong> (Highest Authority).
                </p>
                <div class="d-flex justify-content-center align-items-center gap-3">
                    <p class="mb-0 text-muted">
                        <i class="fas fa-calendar-alt me-1"></i>Last login: <%= new Date().toLocaleDateString() %>
                    </p>
                    <span class="badge bg-primary fs-6">University Head</span>
                </div>
            </div>

            <!-- Quick Stats Row -->
            <div class="row g-4 justify-content-center mb-5">
                <div class="col-md-3">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-primary mb-2">
                                <i class="fas fa-users fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                <%= stats.totalStudents || 0 %>
                            </h3>
                            <p class="text-muted mb-0">Total Students</p>
                            <small class="text-success">Active: <%= stats.activeStudents || 0 %></small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-success mb-2">
                                <i class="fas fa-chalkboard-teacher fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                <%= stats.totalStaff || 0 %>
                            </h3>
                            <p class="text-muted mb-0">Total Staff</p>
                            <small class="text-info">Academic: <%= stats.academicStaff || 0 %></small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-warning mb-2">
                                <i class="fas fa-clock fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                <%= stats.pendingApprovals || 0 %>
                            </h3>
                            <p class="text-muted mb-0">Pending Approvals</p>
                            <small class="text-danger">Urgent: <%= stats.urgentApprovals || 0 %></small>
                        </div>
                    </div>
                </div>

                <div class="col-md-3">
                    <div class="card text-center border-0 shadow-sm">
                        <div class="card-body">
                            <div class="text-danger mb-2">
                                <i class="fas fa-exclamation-triangle fa-3x"></i>
                            </div>
                            <h3 class="fw-bold">
                                <%= stats.activeIssues || 0 %>
                            </h3>
                            <p class="text-muted mb-0">Active Issues</p>
                            <small class="text-warning">Discipline: <%= stats.disciplineCases || 0 %></small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 1: Core Administration -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-cogs me-2"></i>Core Administration
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- University Management -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-landmark fa-3x mb-3 text-primary"></i>
                            <h5 class="card-title fw-bold">University Management</h5>
                            <p class="card-text text-muted">
                                Manage Deans, HODs, DVCs and oversee all senior staff appointments.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/manage-deans" class="btn btn-primary">
                                    <i class="fas fa-user-graduate me-1"></i> Manage Deans
                                    <span class="badge bg-light text-primary ms-1">
                                        <%= stats.totalDeans || 0 %>
                                    </span>
                                </a>
                                <a href="/vc/manage-hods" class="btn btn-info text-white">
                                    <i class="fas fa-user-tie me-1"></i> Manage HODs
                                    <span class="badge bg-light text-info ms-1">
                                        <%= stats.totalHODs || 0 %>
                                    </span>
                                </a>
                                <a href="/vc/manage-dvcs" class="btn btn-success">
                                    <i class="fas fa-user-cog me-1"></i> Manage DVCs
                                    <span class="badge bg-light text-success ms-1">
                                        <%= stats.totalDVCs || 0 %>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Administrative Functions -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-user-shield fa-3x mb-3 text-danger"></i>
                            <h5 class="card-title fw-bold">Administrative Functions</h5>
                            <p class="card-text text-muted">
                                Senior appointments, promotions, committees and audit reports.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/appointments" class="btn btn-danger">
                                    <i class="fas fa-user-plus me-1"></i> Appointments
                                </a>
                                <a href="/vc/promotions" class="btn btn-danger">
                                    <i class="fas fa-user-check me-1"></i> Promotions
                                </a>
                                <a href="/vc/committees" class="btn btn-danger">
                                    <i class="fas fa-users me-1"></i> Committees
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Strategic Planning -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-chess-king fa-3x mb-3" style="color: #6f42c1;"></i>
                            <h5 class="card-title fw-bold" style="color: #6f42c1;">Strategic Planning</h5>
                            <p class="card-text text-muted">
                                Strategic plan implementation, policy formulation and institutional performance.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/strategic-plan" class="btn"
                                    style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-road me-1"></i> Strategic Plan
                                </a>
                                <a href="/vc/policies" class="btn" style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-book me-1"></i> Policy Formulation
                                </a>
                                <a href="/vc/performance" class="btn" style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-tachometer-alt me-1"></i> Performance
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 2: Academic & Research -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-graduation-cap me-2"></i>Academic & Research
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- Academic Oversight -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-graduation-cap fa-3x mb-3 text-success"></i>
                            <h5 class="card-title fw-bold">Academic Oversight</h5>
                            <p class="card-text text-muted">
                                University-wide academic reports, programme approvals, and quality assurance.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/reports/academic" class="btn btn-success">
                                    <i class="fas fa-chart-bar me-1"></i> Academic Reports
                                </a>
                                <a href="/vc/approve-programmes" class="btn btn-success">
                                    <i class="fas fa-check-circle me-1"></i> Approve Programmes
                                </a>
                                <a href="/vc/quality-assurance" class="btn btn-success">
                                    <i class="fas fa-clipboard-check me-1"></i> Quality Assurance
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Research & Accreditation -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-flask fa-3x mb-3" style="color: #20c997;"></i>
                            <h5 class="card-title fw-bold" style="color: #20c997;">Research & Accreditation</h5>
                            <p class="card-text text-muted">
                                Research publications, accreditation status and partnerships.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/research" class="btn" style="background-color: #20c997; color: white;">
                                    <i class="fas fa-flask me-1"></i> Research
                                </a>
                                <a href="/vc/accreditation" class="btn"
                                    style="background-color: #20c997; color: white;">
                                    <i class="fas fa-award me-1"></i> Accreditation
                                </a>
                                <a href="/vc/partnerships" class="btn" style="background-color: #20c997; color: white;">
                                    <i class="fas fa-handshake me-1"></i> Partnerships
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Academic Finance & Payments -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-money-check-alt fa-3x mb-3 text-info"></i>
                            <h5 class="card-title fw-bold">Academic Finance</h5>
                            <p class="card-text text-muted">
                                Research grants, academic payments, and funding allocations.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/research-grants" class="btn btn-info text-white">
                                    <i class="fas fa-gem me-1"></i> Research Grants
                                </a>
                                <a href="/vc/academic-payments" class="btn btn-info text-white">
                                    <i class="fas fa-money-check me-1"></i> Academic Payments
                                </a>
                                <a href="/vc/funding-allocations" class="btn btn-outline-info">
                                    <i class="fas fa-chart-pie me-1"></i> Funding Allocation
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 3: Student Affairs & Finance -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-user-graduate me-2"></i>Student Affairs & Finance
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- Student Affairs -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-user-graduate fa-3x mb-3 text-warning"></i>
                            <h5 class="card-title fw-bold">Student Affairs</h5>
                            <p class="card-text text-muted">
                                Student discipline, welfare, representation and graduation approvals.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/discipline" class="btn btn-warning text-dark">
                                    <i class="fas fa-gavel me-1"></i> Discipline Cases
                                    <span class="badge bg-danger ms-1">
                                        <%= stats.pendingDiscipline || 0 %>
                                    </span>
                                </a>
                                <a href="/vc/student-welfare" class="btn btn-warning text-dark">
                                    <i class="fas fa-hands-helping me-1"></i> Student Welfare
                                </a>
                                <a href="/vc/graduation" class="btn btn-warning text-dark">
                                    <i class="fas fa-graduation-cap me-1"></i> Graduation
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Student Payments -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-credit-card fa-3x mb-3" style="color: #6f42c1;"></i>
                            <h5 class="card-title fw-bold" style="color: #6f42c1;">Student Payments</h5>
                            <p class="card-text text-muted">
                                Tuition fees, scholarship payments, and student financial aid management.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/tuition-payments" class="btn"
                                    style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-university me-1"></i> Tuition Fees
                                </a>
                                <a href="/vc/scholarships" class="btn" style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-award me-1"></i> Scholarships
                                </a>
                                <a href="/vc/student-financial-aid" class="btn"
                                    style="background-color: #6f42c1; color: white;">
                                    <i class="fas fa-hand-holding-usd me-1"></i> Financial Aid
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Infrastructure & Payments -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-building fa-3x mb-3" style="color: #fd7e14;"></i>
                            <h5 class="card-title fw-bold" style="color: #fd7e14;">Infrastructure & Finance</h5>
                            <p class="card-text text-muted">
                                Campus development, facilities management, and infrastructure payments.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/infrastructure" class="btn"
                                    style="background-color: #fd7e14; color: white;">
                                    <i class="fas fa-hard-hat me-1"></i> Projects
                                </a>
                                <a href="/vc/facilities-payments" class="btn"
                                    style="background-color: #fd7e14; color: white;">
                                    <i class="fas fa-tools me-1"></i> Facility Payments
                                </a>
                                <a href="/vc/contractor-payments" class="btn"
                                    style="background-color: #fd7e14; color: white;">
                                    <i class="fas fa-file-contract me-1"></i> Contractor Payments
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 4: Financial Oversight -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-chart-pie me-2"></i>Financial Oversight & Payments
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- Financial Oversight -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-chart-pie fa-3x mb-3 text-info"></i>
                            <h5 class="card-title fw-bold">Financial Oversight</h5>
                            <p class="card-text text-muted">
                                University financial reports, budget approvals and expenditure oversight.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/financial-reports" class="btn btn-info text-white">
                                    <i class="fas fa-file-invoice-dollar me-1"></i> Financial Reports
                                </a>
                                <a href="/vc/budget-approval" class="btn btn-info text-white">
                                    <i class="fas fa-hand-holding-usd me-1"></i> Budget Approvals
                                </a>
                                <a href="/vc/expenditure-oversight" class="btn btn-info text-white">
                                    <i class="fas fa-search-dollar me-1"></i> Expenditure Oversight
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- All Payments Dashboard -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-money-bill-wave fa-3x mb-3 text-primary"></i>
                            <h5 class="card-title fw-bold">All Payments Dashboard</h5>
                            <p class="card-text text-muted">
                                Comprehensive view of all institution-wide payment transactions and records.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/payments" class="btn btn-primary">
                                    <i class="fas fa-list-alt me-1"></i> View All Payments
                                    <span class="badge bg-light text-primary ms-1">
                                        <%= stats.totalPayments || 0 %>
                                    </span>
                                </a>
                                <a href="/vc/payment-reports" class="btn btn-outline-primary">
                                    <i class="fas fa-chart-line me-1"></i> Payment Analytics
                                </a>
                                <a href="/vc/pending-payments" class="btn btn-outline-primary">
                                    <i class="fas fa-clock me-1"></i> Pending Approvals
                                    <span class="badge bg-warning ms-1">
                                        <%= stats.pendingPayments || 0 %>
                                    </span>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Grants & Funding -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-gem fa-3x mb-3" style="color: #20c997;"></i>
                            <h5 class="card-title fw-bold" style="color: #20c997;">Grants & Funding</h5>
                            <p class="card-text text-muted">
                                External grants, donor funding, and research project payments.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/grants" class="btn" style="background-color: #20c997; color: white;">
                                    <i class="fas fa-gem me-1"></i> Grants Management
                                </a>
                                <a href="/vc/donor-payments" class="btn"
                                    style="background-color: #20c997; color: white;">
                                    <i class="fas fa-hand-holding-heart me-1"></i> Donor Funds
                                </a>
                                <a href="/vc/project-funding" class="btn"
                                    style="background-color: #20c997; color: white;">
                                    <i class="fas fa-project-diagram me-1"></i> Project Funding
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 5: Governance & Analytics -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-chart-line me-2"></i>Governance & Analytics
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- Council & Senate -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-users-between-lines fa-3x mb-3" style="color: #7952b3;"></i>
                            <h5 class="card-title fw-bold" style="color: #7952b3;">Council & Senate</h5>
                            <p class="card-text text-muted">
                                Manage university council, senate meetings, agendas, and resolutions.
                            </p>
                            <div class="d-grid gap-2">
                                <a href="/vc/council" class="btn" style="background-color: #7952b3; color: white;">
                                    <i class="fas fa-landmark me-1"></i> University Council
                                </a>
                                <a href="/vc/senate" class="btn" style="background-color: #7952b3; color: white;">
                                    <i class="fas fa-gavel me-1"></i> Academic Senate
                                </a>
                                <a href="/vc/governance-payments" class="btn"
                                    style="background-color: #7952b3; color: white;">
                                    <i class="fas fa-file-invoice me-1"></i> Governance Expenses
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- University Analytics -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-chart-line fa-3x mb-3" style="color: #17a2b8;"></i>
                            <h5 class="card-title fw-bold" style="color: #17a2b8;">University Analytics</h5>
                            <p class="card-text text-muted">
                                Comprehensive analytics and performance metrics across all university departments.
                            </p>
                            <div class="row text-center g-2 mb-3">
                                <div class="col-6">
                                    <div class="bg-light rounded p-2">
                                        <div class="fw-bold text-primary">
                                            <%= stats.seniorStaff || 0 %>
                                        </div>
                                        <small class="text-muted">Senior Staff</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2">
                                        <div class="fw-bold text-success">
                                            <%= stats.totalDeans || 0 %>
                                        </div>
                                        <small class="text-muted">Faculties</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2">
                                        <div class="fw-bold text-warning">
                                            <%= stats.academicStaff || 0 %>
                                        </div>
                                        <small class="text-muted">Lecturers</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded p-2">
                                        <div class="fw-bold text-info">
                                            <%= stats.totalHODs || 0 %>
                                        </div>
                                        <small class="text-muted">Departments</small>
                                    </div>
                                </div>
                            </div>
                            <div class="d-grid gap-2">
                                <a href="/vc/analytics" class="btn" style="background-color: #17a2b8; color: white;">
                                    <i class="fas fa-chart-bar me-1"></i> View Analytics
                                </a>
                                <a href="/vc/metrics" class="btn btn-outline-info">
                                    <i class="fas fa-tachometer-alt me-1"></i> Performance Metrics
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Emergency Management -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-shield-alt fa-3x mb-3 text-dark"></i>
                            <h5 class="card-title fw-bold">Emergency Management</h5>
                            <p class="card-text text-muted">
                                System override, audit logs, and emergency broadcast messages.
                            </p>
                            <div class="d-grid gap-2">
                                <button class="btn btn-outline-danger" data-bs-toggle="modal"
                                    data-bs-target="#overrideModal">
                                    <i class="fas fa-unlock-alt me-1"></i> System Override
                                </button>
                                <a href="/vc/audit-log" class="btn btn-outline-dark">
                                    <i class="fas fa-clipboard-list me-1"></i> Audit Log
                                </a>
                                <button class="btn btn-outline-dark" data-bs-toggle="modal"
                                    data-bs-target="#broadcastModal">
                                    <i class="fas fa-bullhorn me-1"></i> Broadcast
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section 6: Personal & Communications -->
            <div class="row mb-4">
                <div class="col-12">
                    <h4 class="fw-bold mb-3" style="color: var(--primary-purple)">
                        <i class="fas fa-user-circle me-2"></i>Personal & Communications
                    </h4>
                </div>
            </div>

            <div class="row g-4 justify-content-center mb-5">
                <!-- VC's Inbox -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-inbox fa-3x mb-3 text-secondary"></i>
                            <h5 class="card-title fw-bold">VC's Inbox</h5>
                            <div class="text-start mb-3">
                                <div class="table-responsive">
                                    <table class="table table-sm table-borderless">
                                        <tbody>
                                            <% if (inbox && inbox.length> 0) { %>
                                                <% inbox.slice(0, 3).forEach(item=> { %>
                                                    <tr>
                                                        <td class="ps-0">
                                                            <small class="fw-bold">
                                                                <%= item.from %>
                                                            </small><br>
                                                            <small class="text-muted">
                                                                <%= item.subject %>
                                                            </small>
                                                        </td>
                                                        <td class="text-end pe-0">
                                                            <span
                                                                class="badge bg-<%= item.priority === 'High' ? 'danger' : item.priority === 'Medium' ? 'warning' : 'secondary' %>">
                                                                <%= item.priority %>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                                        <% } else { %>
                                                            <tr>
                                                                <td colspan="2" class="text-center text-muted py-2">No
                                                                    messages</td>
                                                            </tr>
                                                            <% } %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                            <a href="/vc/inbox" class="btn btn-secondary w-100">
                                <i class="fas fa-envelope me-1"></i> View All Messages
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Recent Activity -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-history fa-3x mb-3" style="color: #6c757d;"></i>
                            <h5 class="card-title fw-bold">Recent Activity</h5>
                            <div class="text-start mb-3">
                                <div class="activity-feed">
                                    <% if (activities && activities.length> 0) { %>
                                        <% activities.slice(0, 3).forEach(activity=> { %>
                                            <div class="mb-2">
                                                <small class="fw-bold">
                                                    <i
                                                        class="fas fa-<%= activity.icon %> text-<%= activity.type === 'approval' ? 'success' : activity.type === 'reject' ? 'danger' : 'info' %> me-1"></i>
                                                    <%= activity.description %>
                                                </small><br>
                                                <small class="text-muted">
                                                    <i class="far fa-clock me-1"></i>
                                                    <%= activity.time %>
                                                </small>
                                            </div>
                                            <% }); %>
                                                <% } else { %>
                                                    <p class="text-center text-muted py-2">No recent activity</p>
                                                    <% } %>
                                </div>
                            </div>
                            <a href="/vc/activity-log" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-list me-1"></i> View Full Log
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Profile Settings -->
                <div class="col-lg-4 col-md-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-user-cog fa-3x mb-3 text-secondary"></i>
                            <h5 class="card-title fw-bold">Profile Settings</h5>
                            <p class="card-text text-muted">
                                Update your personal information and change your password.
                            </p>
                            <a href="/profile" class="btn btn-secondary w-100">
                                <i class="fas fa-user-edit me-1"></i> Edit Profile
                            </a>
                            <div class="mt-3">
                                <small class="text-muted">
                                    <i class="fas fa-shield-alt me-1"></i> Security Level: Maximum
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Emergency Warning Card -->
            <div class="row mt-5">
                <div class="col-12">
                    <div class="card border-danger shadow-sm">
                        <div class="card-body text-center">
                            <div class="alert alert-warning mb-3">
                                <h5 class="alert-heading">
                                    <i class="fas fa-exclamation-triangle me-2"></i>Emergency Actions
                                </h5>
                                <p class="mb-0">
                                    <strong>Warning:</strong> These actions have system-wide impact. Use only in
                                    exceptional circumstances.
                                </p>
                            </div>
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <button class="btn btn-outline-danger w-100" data-bs-toggle="modal"
                                        data-bs-target="#overrideModal">
                                        <i class="fas fa-unlock-alt me-1"></i>System Override
                                    </button>
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-warning w-100" data-bs-toggle="modal"
                                        data-bs-target="#suspendModal">
                                        <i class="fas fa-ban me-1"></i>Suspend User
                                    </button>
                                </div>
                                <div class="col-md-3">
                                    <a href="/vc/audit-log" class="btn btn-outline-info w-100">
                                        <i class="fas fa-clipboard-list me-1"></i>View Audit Log
                                    </a>
                                </div>
                                <div class="col-md-3">
                                    <button class="btn btn-outline-dark w-100" data-bs-toggle="modal"
                                        data-bs-target="#broadcastModal">
                                        <i class="fas fa-bullhorn me-1"></i>Broadcast Message
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Modals (Keep as is) -->
        <div class="modal fade" id="overrideModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-danger text-white">
                        <h5 class="modal-title">System Override</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <p>This action will grant you temporary override powers. Requires dual authentication.</p>
                        <div class="mb-3">
                            <label class="form-label">Enter Security Token</label>
                            <input type="password" class="form-control" placeholder="Security token from registrar">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reason for Override</label>
                            <textarea class="form-control" rows="3"
                                placeholder="Explain the emergency requiring override..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger">Proceed with Override</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="suspendModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header bg-warning text-dark">
                        <h5 class="modal-title">Suspend User Account</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">User Email or ID</label>
                            <input type="text" class="form-control" placeholder="Enter user email or ID">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reason for Suspension</label>
                            <textarea class="form-control" rows="3"
                                placeholder="Reason for suspending this user..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Duration</label>
                            <select class="form-select">
                                <option value="24">24 Hours</option>
                                <option value="72">72 Hours</option>
                                <option value="168">1 Week</option>
                                <option value="permanent">Permanent</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-warning">Suspend Account</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal fade" id="broadcastModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title">Broadcast Message</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Recipients</label>
                            <select class="form-select" multiple>
                                <option value="all" selected>All University</option>
                                <option value="students">All Students</option>
                                <option value="staff">All Staff</option>
                                <option value="faculty">Faculty Members</option>
                                <option value="admin">Administrative Staff</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" class="form-control" placeholder="Message subject">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Message</label>
                            <textarea class="form-control" rows="5" placeholder="Enter broadcast message..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <select class="form-select">
                                <option value="normal">Normal</option>
                                <option value="high">High Priority</option>
                                <option value="urgent">Urgent</option>
                                <option value="emergency">Emergency</option>
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-dark">Send Broadcast</button>
                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>

            <style>
                .card {
                    transition: all 0.3s ease;
                    border-radius: 10px;
                }

                .card:hover {
                    transform: translateY(-5px);
                    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
                }

                .activity-feed {
                    max-height: 150px;
                    overflow-y: auto;
                }

                .badge {
                    font-size: 0.7em;
                }

                .btn {
                    border-radius: 5px;
                }

                h4 {
                    border-bottom: 2px solid var(--primary-purple);
                    padding-bottom: 8px;
                }
            </style>