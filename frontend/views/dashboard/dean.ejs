<%- include('../partials/header') %> <%- include('../partials/navbar') %>

    <div class="container my-5">
      <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: var(--primary-purple)">Dean Dashboard</h2>
        <p class="lead text-muted">
          Welcome, <%= user.firstName %> — You are logged in as
            <strong>Dean</strong>.
        </p>
      </div>

      <!-- Dashboard Cards -->
      <div class="row g-4 justify-content-center">
        <!-- View Academic Reports -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-chart-line fa-3x mb-3 text-primary"></i>
              <h5 class="card-title fw-bold">Academic Reports</h5>
              <p class="card-text text-muted">
                View school academic performance, departmental statistics, and
                analytics.
              </p>
              <a href="/dean/reports" class="btn btn-primary w-100">
                <i class="fas fa-chart-bar me-1"></i> View Reports
              </a>
            </div>
          </div>
        </div>

        <!-- Assign Courses -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-book fa-3x mb-3 text-info"></i>
              <h5 class="card-title fw-bold">Assign Courses</h5>
              <p class="card-text text-muted">
                Assign core courses to registered students.
              </p>
              <a href="/dean/assign-courses" class="btn btn-info text-white w-100">
                <i class="fas fa-tasks me-1"></i> Assign Courses
              </a>
            </div>
          </div>
        </div>


        <!-- Manage Individual Student Courses -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-user-edit fa-3x mb-3 text-warning"></i>
              <h5 class="card-title fw-bold">Manage Individual Courses</h5>
              <p class="card-text text-muted">
                Manual course adjustments for exemptions, repeats, and special cases.
              </p>
              <!-- KEEP THE EXISTING LINK -->
              <a href="/dean/assign-courses" class="btn btn-warning text-dark w-100">
                <i class="fas fa-user-graduate me-1"></i> Student Course Adjustments
              </a>
            </div>
          </div>
        </div>

        <!-- Assign Lecturers to Courses -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-chalkboard-teacher fa-3x mb-3 text-info"></i>
              <h5 class="card-title fw-bold">Assign Lecturers to Courses</h5>
              <p class="card-text text-muted">
                Assign lecturers to courses and manage teaching responsibilities.
              </p>
              <a href="/dean/assign-lecturers" class="btn btn-info text-white w-100">
                <i class="fas fa-user-tie me-1"></i> Manage Assignments
              </a>
            </div>
          </div>
        </div>

        <!-- Assign Courses to Groups -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-book fa-3x mb-3 text-success"></i>
              <h5 class="card-title fw-bold">Assign Courses to Groups</h5>
              <p class="card-text text-muted">
                Assign which courses each academic group will take.
              </p>
              <a href="/dean/assign-group-courses" class="btn btn-success w-100">
                <i class="fas fa-book-open me-1"></i> Assign Group Courses
              </a>
            </div>
          </div>
        </div>

        <!-- Remove Course from Group -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-trash-alt fa-3x mb-3 text-danger"></i>
              <h5 class="card-title fw-bold">Remove Course from Group</h5>
              <p class="card-text text-muted">
                Remove courses from groups when curriculum changes or errors occur.
              </p>
              <a href="/dean/remove-group-courses" class="btn btn-danger w-100">
                <i class="fas fa-times-circle me-1"></i> Remove Courses
              </a>
            </div>
          </div>
        </div>

        <!-- Lecturer Performance -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-users fa-3x mb-3 text-warning"></i>
              <h5 class="card-title fw-bold">Lecturer Performance</h5>
              <p class="card-text text-muted">
                Monitor lecturer performance, workload distribution, and
                evaluations.
              </p>
              <a href="/dean/lecturers" class="btn btn-warning text-dark w-100">
                <i class="fas fa-user-tie me-1"></i> View Lecturers
              </a>
            </div>
          </div>
        </div>

        <!-- Leave of Absence -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-user-clock fa-3x mb-3 text-warning"></i>
              <h5 class="card-title fw-bold">Leave Requests</h5>
              <p class="card-text text-muted">
                Approve or reject student leave of absence requests.
              </p>
              <a href="/dean/leave-requests" class="btn btn-warning text-dark w-100">
                <i class="fas fa-calendar-check me-1"></i> View Requests
              </a>
            </div>
          </div>
        </div>
        <!-- Academic Results -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-file-alt fa-3x mb-3 text-success"></i>
              <h5 class="card-title fw-bold">Academic Results</h5>
              <p class="card-text text-muted">
                Review and approve submitted student results.
              </p>
              <a href="/dean/results" class="btn btn-success w-100">
                <i class="fas fa-check me-1"></i> Manage Results
              </a>
            </div>
          </div>
        </div>

        <!-- Student Discipline -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-gavel fa-3x mb-3 text-danger"></i>
              <h5 class="card-title fw-bold">Discipline Cases</h5>
              <p class="card-text text-muted">
                Review and manage student disciplinary cases.
              </p>
              <a href="/dean/discipline" class="btn btn-danger w-100">
                <i class="fas fa-balance-scale me-1"></i> View Cases
              </a>
            </div>
          </div>
        </div>

        <!-- Manage Departments -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-building fa-3x mb-3 text-danger"></i>
              <h5 class="card-title fw-bold">Manage Departments</h5>
              <p class="card-text text-muted">
                Oversee academic departments and assign Heads of Department.
              </p>
              <a href="/dean/departments" class="btn btn-danger w-100">
                <i class="fas fa-sitemap me-1"></i> Manage Departments
              </a>
            </div>
          </div>
        </div>

        <!-- Approve Programmes -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-check-circle fa-3x mb-3 text-success"></i>
              <h5 class="card-title fw-bold">Approve Programmes</h5>
              <p class="card-text text-muted">
                Review and approve academic programmes submitted by departments.
              </p>
              <a href="/dean/programmes" class="btn btn-success w-100">
                <i class="fas fa-list-check me-1"></i> Manage Programmes
              </a>
            </div>
          </div>
        </div>

        <!-- Profile Settings -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-user-cog fa-3x mb-3 text-secondary"></i>
              <h5 class="card-title fw-bold">Profile Settings</h5>
              <p class="card-text text-muted">
                Update your personal information and change your password.
              </p>
              <a href="/profile" class="btn btn-secondary w-100">
                <i class="fas fa-user-edit me-1"></i> Edit Profile
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>