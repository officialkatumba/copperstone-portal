<%- include('../partials/header') %> <%- include('../partials/navbar') %>

    <div class="container my-5">
      <div class="text-center mb-5">
        <h2 class="fw-bold" style="color: var(--primary-purple)">
          Finance Dashboard
        </h2>
        <p class="lead text-muted">
          Welcome, <%= user.firstName %> — You are logged in as
            <strong>Finance Officer</strong>.
        </p>
      </div>

      <!-- Dashboard Cards -->
      <div class="row g-4 justify-content-center">
        <!-- View Applications for Payment Verification -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-money-check-alt fa-3x mb-3 text-success"></i>
              <h5 class="card-title fw-bold">Verify Payments</h5>
              <p class="card-text text-muted">
                Review student applications and verify their payments.
              </p>
              <a href="/finance/applications" class="btn btn-success w-100">
                <i class="fas fa-check-circle me-1"></i> Manage Payments
              </a>
            </div>
          </div>
        </div>

        <!-- Skill Payment Verification -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-tools fa-3x mb-3 text-warning"></i>
              <h5 class="card-title fw-bold">Verify Skill Payments</h5>
              <p class="card-text text-muted">
                Review and verify payments for Short Skills Training applications.
              </p>
              <a href="/finance/skills/applications" class="btn btn-warning w-100 text-dark fw-semibold">
                <i class="fas fa-hammer me-1"></i> Manage Skill Payments
              </a>
            </div>
          </div>
        </div>

        <!-- Initiate Payment -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-file-invoice-dollar fa-3x mb-3 text-danger"></i>
              <h5 class="card-title fw-bold">Initiate Payment</h5>
              <p class="card-text text-muted">
                Create payments for students (tuition, semester fees, penalties, etc.)
              </p>
              <a href="/finance/payments/new" class="btn btn-danger w-100">
                <i class="fas fa-plus-circle me-1"></i> Create Payment
              </a>
            </div>
          </div>
        </div>


        <!-- View All Payments -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-receipt fa-3x mb-3 text-primary"></i>
              <h5 class="card-title fw-bold">All Payments</h5>
              <p class="card-text text-muted">
                View all student payments and download official receipts.
              </p>
              <a href="/finance/payments" class="btn btn-primary w-100">
                <i class="fas fa-list me-1"></i> View Payments
              </a>
            </div>
          </div>
        </div>





        <!-- Finance Reports -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-chart-pie fa-3x mb-3 text-primary"></i>
              <h5 class="card-title fw-bold">Finance Reports</h5>
              <p class="card-text text-muted">
                View insights into payments, verifications, and pending fees.
              </p>
              <a href="/finance/reports" class="btn btn-primary w-100">
                <i class="fas fa-chart-line me-1"></i> View Reports
              </a>
            </div>
          </div>
        </div>

        <!-- Profile Settings -->
        <div class="col-lg-4 col-md-6">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-body text-center">
              <i class="fas fa-user-cog fa-3x mb-3 text-secondary"></i>
              <h5 class="card-title fw-bold">Profile Settings</h5>
              <p class="card-text text-muted">
                Update your account information and change your password.
              </p>
              <a href="/profile" class="btn btn-secondary w-100">
                <i class="fas fa-user-edit me-1"></i> Edit Profile
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>