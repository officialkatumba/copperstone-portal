<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-5">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      Welcome, <%= user.firstName %>!
    </h2>
    <p class="lead text-muted">
      You are logged in as <strong><%= user.role %></strong>.
    </p>
  </div>

  <!-- Dashboard Cards (3x3 layout on desktop) -->
  <div class="row g-4 justify-content-center">
    <!-- Apply for a Program -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-file-signature fa-3x mb-3 text-primary"></i>
          <h5 class="card-title fw-bold">Apply for a Program</h5>
          <p class="card-text text-muted">
            Submit your application for your desired program and upload
            supporting documents.
          </p>
          <!-- <a href="/apply" class="btn btn-primary w-100">Apply Now</a> -->

          <a href="/programs/apply" class="btn btn-primary w-100">
            <i class="fas fa-pen me-1"></i> Apply Now
          </a>
        </div>
      </div>
    </div>

    <!-- My Applications -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-folder-open fa-3x mb-3 text-success"></i>
          <h5 class="card-title fw-bold">My Applications</h5>
          <p class="card-text text-muted">
            Track the status of your submitted applications and view feedback.
          </p>
          <a href="/programs/my" class="btn btn-success w-100">
            <i class="fas fa-eye me-1"></i> View Applications
          </a>
        </div>
      </div>
    </div>

    <!-- Courses -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-book-open fa-3x mb-3 text-info"></i>
          <h5 class="card-title fw-bold">My Courses</h5>
          <p class="card-text text-muted">
            Access your enrolled courses, materials, and track your academic
            progress.
          </p>
          <a href="/student/courses" class="btn btn-info text-white w-100">
            <i class="fas fa-book me-1"></i> View Courses
          </a>
        </div>
      </div>
    </div>

    <!-- Grades -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-graduation-cap fa-3x mb-3 text-warning"></i>
          <h5 class="card-title fw-bold">My Grades</h5>
          <p class="card-text text-muted">
            View your academic results and performance reports.
          </p>
          <a href="/student/grades" class="btn btn-warning text-dark w-100">
            <i class="fas fa-chart-line me-1"></i> View Grades
          </a>
        </div>
      </div>
    </div>

    <!-- Profile Settings -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-user-cog fa-3x mb-3 text-secondary"></i>
          <h5 class="card-title fw-bold">Profile Settings</h5>
          <p class="card-text text-muted">
            Update your personal information, password, and contact details.
          </p>
          <a href="/profile" class="btn btn-secondary w-100">
            <i class="fas fa-user-edit me-1"></i> Edit Profile
          </a>
        </div>
      </div>
    </div>

    <!-- Payments -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-credit-card fa-3x mb-3 text-danger"></i>
          <h5 class="card-title fw-bold">Payments</h5>
          <p class="card-text text-muted">
            View tuition invoices, make online payments, and download receipts.
          </p>
          <a href="/student/payments" class="btn btn-danger w-100">
            <i class="fas fa-money-bill-wave me-1"></i> Manage Payments
          </a>
        </div>
      </div>
    </div>

    <!-- Timetable -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-calendar-alt fa-3x mb-3 text-primary"></i>
          <h5 class="card-title fw-bold">My Timetable</h5>
          <p class="card-text text-muted">
            Access your class schedule and upcoming academic events.
          </p>
          <a href="/student/timetable" class="btn btn-primary w-100">
            <i class="fas fa-clock me-1"></i> View Timetable
          </a>
        </div>
      </div>
    </div>

    <!-- Announcements -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-bullhorn fa-3x mb-3 text-success"></i>
          <h5 class="card-title fw-bold">Announcements</h5>
          <p class="card-text text-muted">
            Stay updated with the latest campus news and official notices.
          </p>
          <a href="/student/announcements" class="btn btn-success w-100">
            <i class="fas fa-bell me-1"></i> View Announcements
          </a>
        </div>
      </div>
    </div>

    <!-- Support / Help Desk -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-headset fa-3x mb-3 text-info"></i>
          <h5 class="card-title fw-bold">Support & Help</h5>
          <p class="card-text text-muted">
            Get assistance with technical issues or academic inquiries.
          </p>
          <a href="/support" class="btn btn-info text-white w-100">
            <i class="fas fa-life-ring me-1"></i> Get Help
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
