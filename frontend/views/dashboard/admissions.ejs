<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-5">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      Admissions Dashboard
    </h2>
    <p class="lead text-muted">
      Welcome, <%= user.firstName %> — You are logged in as
      <strong>Admissions Officer</strong>.
    </p>
  </div>

  <!-- Dashboard Cards -->
  <div class="row g-4 justify-content-center">
    <!-- View Applications -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-folder-open fa-3x mb-3 text-primary"></i>
          <h5 class="card-title fw-bold">View Applications</h5>
          <p class="card-text text-muted">
            Review all student applications and manage their status.
          </p>
          <a href="/admissions/applications" class="btn btn-primary w-100">
            <i class="fas fa-eye me-1"></i> Manage Applications
          </a>
        </div>
      </div>
    </div>

    <!-- Reports -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-chart-bar fa-3x mb-3 text-success"></i>
          <h5 class="card-title fw-bold">Reports & Analytics</h5>
          <p class="card-text text-muted">
            View insights into admission trends, applications per programme, and
            approvals.
          </p>
          <a href="/admissions/reports" class="btn btn-success w-100">
            <i class="fas fa-chart-line me-1"></i> View Reports
          </a>
        </div>
      </div>
    </div>

    <!-- Profile Settings -->
    <div class="col-lg-4 col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body text-center">
          <i class="fas fa-user-cog fa-3x mb-3 text-secondary"></i>
          <h5 class="card-title fw-bold">Profile Settings</h5>
          <p class="card-text text-muted">
            Update your account information and change your password.
          </p>
          <a href="/profile" class="btn btn-secondary w-100">
            <i class="fas fa-user-edit me-1"></i> Edit Profile
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
