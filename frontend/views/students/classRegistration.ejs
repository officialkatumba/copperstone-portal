<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      Register for Classes
    </h2>
    <p class="text-muted">
      Select the courses you wish to enroll in this semester.
    </p>
  </div>

  <form action="/student/register-classes" method="POST">
    <div class="card shadow-sm border-0 p-4">
      <div class="table-responsive">
        <table class="table table-bordered align-middle">
          <thead class="table-light">
            <tr>
              <th scope="col">Select</th>
              <th scope="col">Course Code</th>
              <th scope="col">Course Name</th>
              <th scope="col">Credits</th>
            </tr>
          </thead>
          <tbody>
            <% if (courses && courses.length > 0) { %> <% courses.forEach(course
            => { %>
            <tr>
              <td>
                <input
                  type="checkbox"
                  name="courses"
                  value="<%= course._id %>"
                />
              </td>
              <td><%= course.code %></td>
              <td><%= course.name %></td>
              <td><%= course.credits || "N/A" %></td>
            </tr>
            <% }) %> <% } else { %>
            <tr>
              <td colspan="4" class="text-center text-muted">
                No available courses to register for at this time.
              </td>
            </tr>
            <% } %>
          </tbody>
        </table>
      </div>

      <div class="text-center mt-4">
        <button type="submit" class="btn btn-primary px-4 py-2">
          <i class="fas fa-save me-1"></i> Submit Registration
        </button>
      </div>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
