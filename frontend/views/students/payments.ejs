<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-4">
            <!-- PAGE HEADING -->
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="color: var(--primary-purple)">My Payment Records</h2>
                <p class="text-muted">View all your payments, receipts, and outstanding balances</p>
            </div>

            <!-- STUDENT PAYMENT SUMMARY CARDS -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card shadow-sm text-center border-0 bg-primary bg-opacity-10">
                        <div class="card-body">
                            <small class="text-muted text-uppercase fw-bold">Total Paid</small>
                            <h4 class="fw-bold text-primary">ZMW <%= Number(summary.totalPaid ||
                                    0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                                    %>
                            </h4>
                            <small class="text-muted">Across <%= summary.paymentCount %> payment(s)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm text-center border-0 bg-warning bg-opacity-10">
                        <div class="card-body">
                            <small class="text-muted text-uppercase fw-bold">Total Due</small>
                            <h4 class="fw-bold text-warning">ZMW <%= Number(summary.totalDue ||
                                    0).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                                    %>
                            </h4>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div
                        class="card shadow-sm text-center border-0 <%= summary.totalBalance > 0 ? 'bg-danger bg-opacity-10' : 'bg-success bg-opacity-10' %>">
                        <div class="card-body">
                            <small class="text-muted text-uppercase fw-bold">Balance</small>
                            <h4 class="fw-bold <%= summary.totalBalance > 0 ? 'text-danger' : 'text-success' %>">
                                ZMW <%= Number(summary.totalBalance || 0).toLocaleString('en-US', {
                                    minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                            </h4>
                            <% if(summary.totalBalance> 0) { %>
                                <small class="text-danger">Outstanding</small>
                                <% } else { %>
                                    <small class="text-success">Fully Paid</small>
                                    <% } %>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm text-center border-0 bg-info bg-opacity-10">
                        <div class="card-body">
                            <small class="text-muted text-uppercase fw-bold">Completion</small>
                            <h4 class="fw-bold text-info">
                                <%= summary.completionPercentage %>%
                            </h4>
                            <div class="progress mt-2" style="height: 5px;">
                                <div class="progress-bar bg-info" role="progressbar"
                                    style="width: <%= summary.completionPercentage %>%"
                                    aria-valuenow="<%= summary.completionPercentage %>" aria-valuemin="0"
                                    aria-valuemax="100"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- STATUS SUMMARY (Quick Stats) -->
            <div class="row mb-4">
                <div class="col-md-12">
                    <div class="d-flex gap-2 justify-content-center flex-wrap">
                        <span class="badge bg-success p-2">
                            <i class="fas fa-check-circle me-1"></i>
                            Verified: <%= summary.verifiedCount || 0 %>
                        </span>
                        <span class="badge bg-warning text-dark p-2">
                            <i class="fas fa-clock me-1"></i>
                            Pending: <%= summary.pendingCount || 0 %>
                        </span>
                        <span class="badge bg-primary p-2">
                            <i class="fas fa-credit-card me-1"></i>
                            Total Payments: <%= summary.paymentCount || 0 %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- FILTERS -->
            <form method="GET" class="row g-2 mb-3">
                <div class="col-md-4">
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        <% categories.forEach(function(cat){ %>
                            <option value="<%= cat %>" <%=currentCategory===cat ? 'selected' : '' %>>
                                <%= cat %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="col-md-4">
                    <select name="status" class="form-select">
                        <option value="">All Statuses</option>
                        <% statuses.forEach(function(stat){ %>
                            <option value="<%= stat %>" <%=currentStatus===stat ? 'selected' : '' %>>
                                <%= stat %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <div class="col-md-2">
                    <select name="limit" class="form-select" onchange="this.form.submit()">
                        <option value="10" <%=pagination.limit===10 ? 'selected' : '' %>>10 per page</option>
                        <option value="20" <%=pagination.limit===20 ? 'selected' : '' %>>20 per page</option>
                        <option value="50" <%=pagination.limit===50 ? 'selected' : '' %>>50 per page</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">Filter</button>
                </div>
            </form>

            <!-- PAYMENTS TABLE -->
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Receipt #</th>
                                <th>Category</th>
                                <th>Description</th>
                                <th>Amount</th>
                                <th>Balance</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!payments || payments.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        <i class="fas fa-credit-card fa-3x mb-3 opacity-50"></i>
                                        <p class="mb-0">No payment records found</p>
                                        <small>Payments you make will appear here</small>
                                    </td>
                                </tr>
                                <% } %>

                                    <% payments.forEach(function(p, index){ %>
                                        <tr>
                                            <td>
                                                <%= ((pagination.currentPage - 1) * pagination.limit) + index + 1 %>
                                            </td>

                                            <td>
                                                <small>
                                                    <%= p.formattedDate || new
                                                        Date(p.createdAt).toLocaleDateString('en-GB') %>
                                                </small><br>
                                                <small class="text-muted">
                                                    <%= p.formattedTime || new Date(p.createdAt).toLocaleTimeString([],
                                                        { hour: '2-digit' , minute: '2-digit' }) %>
                                                </small>
                                            </td>

                                            <td>
                                                <span class="fw-bold">
                                                    <%= p.reference || 'N/A' %>
                                                </span>
                                            </td>

                                            <td>
                                                <span class="badge bg-secondary">
                                                    <%= p.category %>
                                                </span>
                                            </td>

                                            <td>
                                                <small>
                                                    <%= p.description || '—' %>
                                                </small>
                                                <% if(p.programme) { %>
                                                    <br><small class="text-muted">
                                                        <%= p.programme.name %>
                                                    </small>
                                                    <% } %>
                                            </td>

                                            <td class="fw-bold text-primary">
                                                ZMW <%= Number(p.amount || 0).toLocaleString('en-US', {
                                                    minimumFractionDigits: 2, maximumFractionDigits: 2 }) %>
                                            </td>

                                            <td>
                                                <% if((p.balanceAfterPayment || 0)> 0) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        ZMW <%= Number(p.balanceAfterPayment ||
                                                            0).toLocaleString('en-US', { minimumFractionDigits: 2,
                                                            maximumFractionDigits: 2 }) %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-success">Paid</span>
                                                        <% } %>
                                            </td>

                                            <td>
                                                <% if(p.status==='Verified' || p.status==='Fully Paid' ) { %>
                                                    <span class="badge bg-success">
                                                        <%= p.status %>
                                                    </span>
                                                    <% } else if(p.status==='Partially Paid' ) { %>
                                                        <span class="badge bg-warning text-dark">Partially Paid</span>
                                                        <% } else if(p.status==='Pending' ) { %>
                                                            <span class="badge bg-warning text-dark">Pending</span>
                                                            <% } else if(p.status==='Rejected' ) { %>
                                                                <span class="badge bg-danger">Rejected</span>
                                                                <% } else if(p.status==='Cancelled' ) { %>
                                                                    <span class="badge bg-secondary">Cancelled</span>
                                                                    <% } else { %>
                                                                        <span class="badge bg-secondary">
                                                                            <%= p.status %>
                                                                        </span>
                                                                        <% } %>
                                            </td>

                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= p._id %>">
                                                    <i class="fas fa-eye"></i> View
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- FOOTER COUNT -->
            <div class="text-muted mt-2">
                Showing <strong>
                    <%= payments.length %>
                </strong> of <strong>
                    <%= pagination.totalCount %>
                </strong> payments
            </div>

            <!-- PAGINATION -->
            <% if (pagination.totalPages> 1) { %>
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        <% const startPage=Math.max(1, pagination.currentPage - 2); %>
                            <% const endPage=Math.min(pagination.totalPages, pagination.currentPage + 2); %>

                                <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="?page=<%= pagination.currentPage-1 %>&limit=<%= pagination.limit %>&category=<%= currentCategory %>&status=<%= currentStatus %>">
                                        Previous
                                    </a>
                                </li>

                                <% if (startPage> 1) { %>
                                    <li class="page-item"><a class="page-link"
                                            href="?page=1&limit=<%= pagination.limit %>">1</a></li>
                                    <% if (startPage> 2) { %>
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                        <% } %>
                                            <% } %>

                                                <% for(let i=startPage; i <=endPage; i++){ %>
                                                    <li
                                                        class="page-item <%= i === pagination.currentPage ? 'active' : '' %>">
                                                        <a class="page-link"
                                                            href="?page=<%= i %>&limit=<%= pagination.limit %>&category=<%= currentCategory %>&status=<%= currentStatus %>">
                                                            <%= i %>
                                                        </a>
                                                    </li>
                                                    <% } %>

                                                        <% if (endPage < pagination.totalPages) { %>
                                                            <% if (endPage < pagination.totalPages - 1) { %>
                                                                <li class="page-item disabled"><span
                                                                        class="page-link">…</span></li>
                                                                <% } %>
                                                                    <li class="page-item"><a class="page-link"
                                                                            href="?page=<%= pagination.totalPages %>&limit=<%= pagination.limit %>">
                                                                            <%= pagination.totalPages %>
                                                                        </a></li>
                                                                    <% } %>

                                                                        <li
                                                                            class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
                                                                            <a class="page-link"
                                                                                href="?page=<%= pagination.currentPage+1 %>&limit=<%= pagination.limit %>&category=<%= currentCategory %>&status=<%= currentStatus %>">
                                                                                Next
                                                                            </a>
                                                                        </li>
                    </ul>
                </nav>
                <% } %>

        </div>

        <!-- Payment Modals for each payment -->
        <% payments.forEach(function(payment){ %>
            <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title fw-bold">
                                <i class="fas fa-receipt me-2 text-primary"></i>
                                Payment Details
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">

                            <!-- Payment Header -->
                            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                    style="width:50px;height:50px;">
                                    <i class="fas fa-credit-card text-primary"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">Receipt #: <strong>
                                            <%= payment.reference %>
                                        </strong></h6>
                                    <p class="text-muted mb-0">
                                        <i class="far fa-calendar-alt me-1"></i>
                                        <%= payment.formattedDate ? new
                                            Date(payment.createdAt).toLocaleDateString('en-GB', { weekday: 'long' ,
                                            year: 'numeric' , month: 'long' , day: 'numeric' }) : new
                                            Date(payment.createdAt).toLocaleDateString('en-GB', { weekday: 'long' ,
                                            year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                                    </p>
                                </div>
                            </div>

                            <!-- Payment Details Grid -->
                            <div class="row g-3">
                                <!-- Category -->
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block">Category</small>
                                        <span class="fw-bold">
                                            <%= payment.category %>
                                        </span>
                                    </div>
                                </div>

                                <!-- Method -->
                                <div class="col-6">
                                    <div class="p-3 bg-light rounded">
                                        <small class="text-muted d-block">Payment Method</small>
                                        <span class="fw-bold">
                                            <%= payment.method || 'N/A' %>
                                        </span>
                                    </div>
                                </div>

                                <!-- Description -->
                                <% if(payment.description) { %>
                                    <div class="col-12">
                                        <div class="p-3 bg-light rounded">
                                            <small class="text-muted d-block">Description</small>
                                            <span>
                                                <%= payment.description %>
                                            </span>
                                        </div>
                                    </div>
                                    <% } %>

                                        <!-- Programme Info -->
                                        <% if(payment.programme) { %>
                                            <div class="col-6">
                                                <div class="p-3 bg-light rounded">
                                                    <small class="text-muted d-block">Programme</small>
                                                    <span class="fw-bold">
                                                        <%= payment.programme.name %>
                                                    </span>
                                                    <br><small class="text-muted">
                                                        <%= payment.programme.code %>
                                                    </small>
                                                </div>
                                            </div>
                                            <% } %>

                                                <!-- Amount Paid -->
                                                <div class="col-6">
                                                    <div class="p-3 bg-success bg-opacity-10 rounded">
                                                        <small class="text-muted d-block">Amount Paid</small>
                                                        <span class="fw-bold text-success fs-5">
                                                            ZMW <%= Number(payment.amount || 0).toLocaleString('en-US',
                                                                { minimumFractionDigits: 2, maximumFractionDigits: 2 })
                                                                %>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Balance -->
                                                <div class="col-6">
                                                    <div
                                                        class="p-3 <%= (payment.balanceAfterPayment || 0) > 0 ? 'bg-danger bg-opacity-10' : 'bg-success bg-opacity-10' %> rounded">
                                                        <small class="text-muted d-block">Balance</small>
                                                        <span
                                                            class="fw-bold <%= (payment.balanceAfterPayment || 0) > 0 ? 'text-danger' : 'text-success' %> fs-5">
                                                            ZMW <%= Number(payment.balanceAfterPayment ||
                                                                0).toLocaleString('en-US', { minimumFractionDigits: 2,
                                                                maximumFractionDigits: 2 }) %>
                                                        </span>
                                                    </div>
                                                </div>

                                                <!-- Verification Info -->
                                                <% if(payment.verifiedAt) { %>
                                                    <div class="col-12">
                                                        <div class="p-3 bg-light rounded">
                                                            <small class="text-muted d-block">Verified On</small>
                                                            <span><i class="far fa-check-circle text-success me-1"></i>
                                                                <%= payment.formattedVerifiedDate || new
                                                                    Date(payment.verifiedAt).toLocaleDateString('en-GB',
                                                                    { weekday: 'long' , year: 'numeric' , month: 'long'
                                                                    , day: 'numeric' }) %>
                                                            </span>
                                                            <% if(payment.verifiedBy) { %>
                                                                <br><small class="text-muted">by <%=
                                                                        payment.verifiedBy.firstName %>
                                                                        <%= payment.verifiedBy.surname %></small>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <!-- Expected Payment Date (if balance exists) -->
                                                        <% if(payment.expectedPaymentDate &&
                                                            (payment.balanceAfterPayment || 0)> 0) { %>
                                                            <div class="col-12">
                                                                <div class="p-3 bg-warning bg-opacity-10 rounded">
                                                                    <small class="text-muted d-block">Expected Payment
                                                                        Date</small>
                                                                    <span class="fw-bold text-warning">
                                                                        <i class="far fa-calendar-alt me-1"></i>
                                                                        <%= new
                                                                            Date(payment.expectedPaymentDate).toLocaleDateString('en-GB',
                                                                            { weekday: 'long' , year: 'numeric' ,
                                                                            month: 'long' , day: 'numeric' }) %>
                                                                    </span>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <!-- Cancellation Info -->
                                                                <% if(payment.status==='Cancelled' &&
                                                                    payment.cancellationReason) { %>
                                                                    <div class="col-12">
                                                                        <div class="alert alert-danger mb-0">
                                                                            <i class="fas fa-ban me-2"></i>
                                                                            <strong>Cancelled:</strong>
                                                                            <%= payment.cancellationReason %>
                                                                                <% if(payment.cancelledAt) { %>
                                                                                    <br><small>
                                                                                        <%= new
                                                                                            Date(payment.cancelledAt).toLocaleDateString()
                                                                                            %>
                                                                                    </small>
                                                                                    <% } %>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>

                                                                        <!-- Payment Received Date -->
                                                                        <% if(payment.paymentReceivedOn) { %>
                                                                            <div class="col-12">
                                                                                <div class="p-3 bg-light rounded">
                                                                                    <small
                                                                                        class="text-muted d-block">Payment
                                                                                        Received On</small>
                                                                                    <span>
                                                                                        <i
                                                                                            class="far fa-calendar-check me-1"></i>
                                                                                        <%= payment.formattedReceivedDate
                                                                                            || new
                                                                                            Date(payment.paymentReceivedOn).toLocaleDateString('en-GB',
                                                                                            { weekday: 'long' ,
                                                                                            year: 'numeric' ,
                                                                                            month: 'long' ,
                                                                                            day: 'numeric' }) %>
                                                                                    </span>
                                                                                </div>
                                                                            </div>
                                                                            <% } %>
                            </div>

                            <!-- Documents Section -->
                            <div class="row mt-4 pt-3 border-top">
                                <!-- Receipt -->
                                <% if(payment.receipt && (payment.receipt.signedUrl || payment.receipt.gcsUrl)) { %>
                                    <div class="col-6">
                                        <a href="/applications/payments/<%= payment._id %>/receipt" target="_blank"
                                            class="btn btn-success w-100 d-flex align-items-center justify-content-center gap-2">
                                            <i class="fas fa-file-pdf"></i>
                                            <span>Download Receipt</span>
                                        </a>
                                    </div>
                                    <% } %>

                                        <!-- Proof of Payment -->
                                        <% if(payment.proofOfPayment && payment.proofOfPayment.signedUrl) { %>
                                            <div class="col-6">
                                                <a href="/applications/payments/<%= payment._id %>/proof"
                                                    target="_blank"
                                                    class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2">
                                                    <i class="fas fa-file-upload"></i>
                                                    <span>View Proof</span>
                                                </a>
                                            </div>
                                            <% } %>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                            <% if(payment.receipt && payment.receipt.signedUrl) { %>
                                <a href="/applications/payments/<%= payment._id %>/receipt" target="_blank"
                                    class="btn btn-primary">
                                    <i class="fas fa-print me-1"></i> Print Receipt
                                </a>
                                <% } %>
                        </div>
                    </div>
                </div>
            </div>
            <% }) %>

                <%- include('../partials/footer') %>