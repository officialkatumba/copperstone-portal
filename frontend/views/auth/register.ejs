<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div
  class="d-flex align-items-center justify-content-center"
  style="min-height: calc(100vh - 160px)"
>
  <div
    class="card shadow-lg border-0 p-4 my-5"
    style="max-width: 480px; width: 100%; border-radius: 12px"
  >
    <div class="text-center mb-4">
      <i
        class="fas fa-user-graduate fa-3x mb-2"
        style="color: var(--primary-purple)"
      ></i>
      <h3 class="fw-bold" style="color: var(--primary-purple)">
        Student Registration
      </h3>
      <p class="text-muted mb-0">
        Register now and have a Copperstone Portal account to apply for a
        program of your Choice
      </p>
    </div>

    <form action="/register" method="POST">
      <div class="mb-3">
        <label for="fullName" class="form-label fw-semibold">Full Name</label>
        <input
          type="text"
          name="fullName"
          id="fullName"
          class="form-control form-control-lg"
          placeholder="John Doe"
          required
        />
      </div>

      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control form-control-lg"
          placeholder="you@example.com"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control form-control-lg"
          placeholder="Enter password"
          required
        />
      </div>

      <div class="mb-3">
        <label for="confirmPassword" class="form-label fw-semibold"
          >Confirm Password</label
        >
        <input
          type="password"
          name="confirmPassword"
          id="confirmPassword"
          class="form-control form-control-lg"
          placeholder="Re-enter password"
          required
        />
      </div>

      <button
        type="submit"
        class="btn w-100 py-2 fw-semibold"
        style="
          background-color: var(--secondary-pink);
          color: white;
          border-radius: 30px;
        "
      >
        <i class="fas fa-user-plus me-1"></i> Register
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Already have an account?</p>
      <a href="/login" class="fw-semibold" style="color: var(--secondary-pink)">
        <i class="fas fa-sign-in-alt me-1"></i> Login Here
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
