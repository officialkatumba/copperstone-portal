<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div
  class="d-flex align-items-center justify-content-center"
  style="min-height: calc(100vh - 160px)"
>
  <div
    class="card shadow-lg border-0 p-4 my-5"
    style="max-width: 480px; width: 100%; border-radius: 12px"
  >
    <div class="text-center mb-4">
      <i
        class="fas fa-user-graduate fa-3x mb-2"
        style="color: var(--primary-purple)"
      ></i>
      <h3 class="fw-bold" style="color: var(--primary-purple)">
        Account Registration
      </h3>
      <p class="text-muted mb-0">Create An Account to Apply For A Programme</p>
    </div>

    <form action="/register" method="POST">
      <!-- First Name -->
      <div class="mb-3">
        <label for="firstName" class="form-label fw-semibold">First Name</label>
        <input
          type="text"
          name="firstName"
          id="firstName"
          class="form-control form-control-lg"
          placeholder="John"
          required
        />
      </div>

      <!-- Surname -->
      <div class="mb-3">
        <label for="surname" class="form-label fw-semibold">Surname</label>
        <input
          type="text"
          name="surname"
          id="surname"
          class="form-control form-control-lg"
          placeholder="Doe"
          required
        />
      </div>

      <!-- Other Names -->
      <div class="mb-3">
        <label for="otherNames" class="form-label fw-semibold"
          >Other Names (Optional)</label
        >
        <input
          type="text"
          name="otherNames"
          id="otherNames"
          class="form-control form-control-lg"
          placeholder="Mwape"
        />
      </div>

      <!-- Mobile -->
      <div class="mb-3">
        <label for="mobile" class="form-label fw-semibold">Mobile Number</label>
        <input
          type="text"
          name="mobile"
          id="mobile"
          class="form-control form-control-lg"
          placeholder="096xxxxxxx"
          required
        />
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control form-control-lg"
          placeholder="you@example.com"
          required
        />
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control form-control-lg"
          placeholder="Enter password"
          required
        />
      </div>

      <!-- Confirm Password -->
      <div class="mb-3">
        <label for="confirmPassword" class="form-label fw-semibold"
          >Confirm Password</label
        >
        <input
          type="password"
          name="confirmPassword"
          id="confirmPassword"
          class="form-control form-control-lg"
          placeholder="Re-enter password"
          required
        />
      </div>

      <button
        type="submit"
        class="btn w-100 py-2 fw-semibold"
        style="
          background-color: var(--secondary-pink);
          color: white;
          border-radius: 30px;
        "
      >
        <i class="fas fa-user-plus me-1"></i> Register
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Already have an account?</p>
      <a href="/login" class="fw-semibold" style="color: var(--secondary-pink)">
        <i class="fas fa-sign-in-alt me-1"></i> Login Here
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
