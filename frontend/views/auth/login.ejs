<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="d-flex align-items-center justify-content-center min-vh-100">
  <div
    class="card shadow-lg border-0 p-4"
    style="max-width: 420px; width: 100%; border-radius: 12px"
  >
    <div class="text-center mb-4">
      <i
        class="fas fa-user-circle fa-3x mb-2"
        style="color: var(--primary-purple)"
      ></i>
      <h3 class="fw-bold" style="color: var(--primary-purple)">Login</h3>
      <p class="text-muted mb-0">
        Access your Copperstone Portal apply for a program of your Choice And
        More!!!
      </p>
    </div>

    <form action="/login" method="POST">
      <div class="mb-3">
        <label for="email" class="form-label fw-semibold">Email</label>
        <input
          type="email"
          name="email"
          id="email"
          class="form-control form-control-lg"
          placeholder="you@example.com"
          required
        />
      </div>

      <div class="mb-3">
        <label for="password" class="form-label fw-semibold">Password</label>
        <input
          type="password"
          name="password"
          id="password"
          class="form-control form-control-lg"
          placeholder="Enter your password"
          required
        />
      </div>

      <!-- Forgot Password link -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <a
          href="/forgot-password"
          class="small fw-semibold"
          style="color: var(--primary-purple); text-decoration: none"
        >
          Forgot Password?
        </a>
      </div>

      <button
        type="submit"
        class="btn w-100 py-2 fw-semibold"
        style="
          background-color: var(--secondary-pink);
          color: white;
          border-radius: 30px;
        "
      >
        <i class="fas fa-sign-in-alt me-1"></i> Login
      </button>
    </form>

    <div class="text-center mt-4">
      <p class="mb-1 text-muted">Don’t have an account?</p>
      <a
        href="/register"
        class="fw-semibold"
        style="color: var(--secondary-pink)"
      >
        <i class="fas fa-user-plus me-1"></i> Register Here
      </a>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
