<%- include('../partials/header') %> <%- include('../partials/navbar') %>

    <div class="d-flex align-items-center justify-content-center min-vh-100">
      <div class="card shadow-lg border-0 p-4" style="max-width: 420px; width: 100%; border-radius: 12px">
        <div class="text-center mb-4">
          <i class="fas fa-lock fa-3x mb-2" style="color: var(--primary-purple)"></i>
          <h3 class="fw-bold" style="color: var(--primary-purple)">
            Reset Your Password
          </h3>
          <p class="text-muted mb-0">
            Please enter your new password below to securely reset it.
          </p>
        </div>

        <form action="/auth/reset-password/<%= token %>" method="POST">

          <!-- Hidden token field (sent in the reset email) -->
          <input type="hidden" name="token" value="<%= token %>" />

          <div class="mb-3">
            <label for="password" class="form-label fw-semibold">New Password</label>
            <input type="password" name="password" id="password" class="form-control form-control-lg"
              placeholder="Enter new password" required />
          </div>

          <div class="mb-3">
            <label for="confirmPassword" class="form-label fw-semibold">
              Confirm New Password
            </label>
            <input type="password" name="confirmPassword" id="confirmPassword" class="form-control form-control-lg"
              placeholder="Re-enter new password" required />
          </div>

          <button type="submit" class="btn w-100 py-2 fw-semibold" style="
          background-color: var(--secondary-pink);
          color: white;
          border-radius: 30px;
        ">
            <i class="fas fa-key me-1"></i> Reset Password
          </button>
        </form>

        <div class="text-center mt-4">
          <a href="/auth/login" class="fw-semibold" style="color: var(--secondary-pink); text-decoration: none">
            <i class="fas fa-arrow-left me-1"></i> Back to Login
          </a>
        </div>
      </div>
    </div>

    <%- include('../partials/footer') %>