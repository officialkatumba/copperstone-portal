<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="d-flex align-items-center justify-content-center min-vh-100 mt-4 mb-4">
            <div class="card shadow-lg border-0 p-4" style="max-width: 420px; width: 100%; border-radius: 12px">
                <div class="text-center mb-4">
                    <i class="fas fa-key fa-3x mb-2" style="color: var(--primary-purple)"></i>
                    <h3 class="fw-bold" style="color: var(--primary-purple)">
                        Change Password
                    </h3>
                    <p class="text-muted mb-0">
                        Update your password to keep your account secure.
                    </p>
                </div>

                <form id="changePasswordForm" action="/change-password" method="POST">
                    <div class="mb-3">
                        <label for="oldPassword" class="form-label fw-semibold">Current Password</label>
                        <input type="password" name="oldPassword" id="oldPassword" class="form-control form-control-lg"
                            placeholder="Enter current password" required />
                    </div>

                    <div class="mb-3">
                        <label for="newPassword" class="form-label fw-semibold">New Password</label>
                        <input type="password" name="newPassword" id="newPassword" class="form-control form-control-lg"
                            placeholder="Enter new password (min. 6 characters)" required minlength="6" />
                    </div>

                    <div class="mb-3">
                        <label for="confirmPassword" class="form-label fw-semibold">
                            Confirm New Password
                        </label>
                        <input type="password" name="confirmPassword" id="confirmPassword"
                            class="form-control form-control-lg" placeholder="Re-enter new password" required
                            minlength="6" />
                    </div>

                    <button type="submit" class="btn w-100 py-2 fw-semibold" style="
          background-color: var(--secondary-pink);
          color: white;
          border-radius: 30px;
        ">
                        <i class="fas fa-sync-alt me-1"></i> Update Password
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a href="/dashboard" class="fw-semibold"
                        style="color: var(--secondary-pink); text-decoration: none">
                        <i class="fas fa-arrow-left me-1"></i> Back to Dashboard
                    </a>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>