<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="color: var(--primary-purple)">All Payments</h2>
                <p class="text-muted">View and manage all student payment records.</p>
            </div>

            <!-- Summary Cards -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar-day fa-2x mb-3 text-primary"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalToday.toFixed(2) %>
                            </h5>
                            <small class="text-muted">Total Today (<%= today %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar-alt fa-2x mb-3 text-success"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalMonth.toFixed(2) %>
                            </h5>
                            <small class="text-muted">This Month (<%= monthRange %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar fa-2x mb-3 text-warning"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalYear.toFixed(2) %>
                            </h5>
                            <small class="text-muted">This Year (<%= yearRange %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-wallet fa-2x mb-3 text-secondary"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalAll.toFixed(2) %>
                            </h5>
                            <small class="text-muted">Total Payments</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Search and Pagination -->
            <form class="row mb-4 g-2" method="get" action="/vc/payments">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="search" placeholder="Search payments..."
                        value="<%= search %>">
                </div>
                <div class="col-md-2">
                    <select class="form-select" name="limit">
                        <% [5,10,20,50,100].forEach(n=> { %>
                            <option value="<%= n %>" <%=n===limit ? 'selected' : '' %>><%= n %> per page</option>
                            <% }) %>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
                <div class="col-md-2">
                    <a href="/vc/payments" class="btn btn-secondary w-100">Reset</a>
                </div>
            </form>

            <% if (payments.length===0) { %>
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No payments found.
                </div>
                <% } else { %>
                    <div class="table-responsive shadow-sm rounded-3">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Student</th>
                                    <th>Category</th>
                                    <th>Amount</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% payments.forEach((payment, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= (currentPage-1)*limit + index + 1 %>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= payment.student.firstName %>
                                                    <%= payment.student.surname %>
                                            </strong><br>
                                            <small class="text-muted">
                                                <%= payment.student.email %>
                                            </small>
                                        </td>
                                        <td>
                                            <%= payment.category %>
                                        </td>
                                        <td><strong style="color: var(--primary-purple)">ZMW <%=
                                                    payment.amount.toFixed(2) %></strong></td>
                                        <td>
                                            <%= payment.method %>
                                        </td>
                                        <td>
                                            <% if (payment.status==='Verified' ) { %>
                                                <span class="badge bg-success">Verified</span>
                                                <% } else if (payment.status==='Pending' ) { %>
                                                    <span class="badge bg-warning text-dark">Pending</span>
                                                    <% } else if (payment.status==='Cancelled' ) { %>
                                                        <span class="badge bg-danger">Cancelled</span>
                                                        <% } else { %>
                                                            <span class="badge bg-secondary">
                                                                <%= payment.status %>
                                                            </span>
                                                            <% } %>
                                        </td>
                                        <td>
                                            <small>
                                                <%= payment.createdAt.toLocaleDateString() %>
                                            </small><br>
                                            <small class="text-muted">
                                                <%= payment.createdAt.toLocaleTimeString([],
                                                    {hour:'2-digit',minute:'2-digit'}) %>
                                            </small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= payment._id %>">
                                                    <i class="fas fa-eye me-1"></i> View
                                                </button>
                                                <% if (payment.receipt?.gcsUrl) { %>
                                                    <a href="<%= payment.receipt.gcsUrl %>" target="_blank"
                                                        class="btn btn-outline-success">
                                                        <i class="fas fa-receipt"></i>
                                                    </a>
                                                    <% } %>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Modal -->
                                    <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title fw-bold">Payment Details</h5>
                                                    <button type="button" class="btn-close"
                                                        data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <p><strong>Student:</strong>
                                                        <%= payment.student.firstName %>
                                                            <%= payment.student.surname %>
                                                    </p>
                                                    <p><strong>Category:</strong>
                                                        <%= payment.category %>
                                                    </p>
                                                    <p><strong>Amount:</strong> ZMW <%= payment.amount.toFixed(2) %>
                                                    </p>
                                                    <p><strong>Method:</strong>
                                                        <%= payment.method %>
                                                    </p>
                                                    <p><strong>Status:</strong>
                                                        <%= payment.status %>
                                                    </p>
                                                    <p><strong>Description:</strong>
                                                        <%= payment.description %>
                                                    </p>
                                                    <% if(payment.receipt?.gcsUrl){ %>
                                                        <a href="<%= payment.receipt.gcsUrl %>" target="_blank"
                                                            class="btn btn-success">View Receipt</a>
                                                        <% } %>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary"
                                                        data-bs-dismiss="modal">Close</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <nav aria-label="Page navigation" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <% for(let i=1; i<=totalPages; i++){ %>
                                <li class="page-item <%= i===currentPage?'active':'' %>">
                                    <a class="page-link" href="?page=<%= i %>&limit=<%= limit %>&search=<%= search %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>
                        </ul>
                    </nav>
                    <% } %>
        </div>

        <%- include('../partials/footer') %>