<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <!-- PAGE HEADING -->
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: var(--primary-purple)">All Payments Overview By VC</h2>
                <p class="text-muted">Comprehensive view of all university payments and financial transactions</p>
            </div>
            <!-- ===================================== -->
            <!-- SUMMARY OVERVIEW - 2 ROWS OF 8 CARDS -->
            <!-- ===================================== -->
            <div class="row mb-5">
                <div class="col-12">
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4">
                            <h4 class="fw-bold mb-4" style="color: var(--primary-purple)">
                                <i class="fas fa-chart-line me-2"></i>Payment Summary Overview
                            </h4>

                            <!-- ROW 1: ALL TIME TOTALS -->
                            <!-- <h6 class="fw-bold mb-3 text-muted">All Time Totals (Since Inception)</h6> -->
                            <!-- ROW 1: ALL TIME TOTALS -->
                            <h6 class="fw-bold mb-3 text-muted d-flex align-items-center">
                                All Time Totals (Since Inception)
                                <span class="badge rounded-pill ms-2"
                                    style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; font-size: 0.9rem; padding: 0.4rem 0.8rem;">
                                    <i class="fas fa-wallet me-1"></i>
                                    ZMW <%= Number(totalAll || 0).toLocaleString('en-US', {minimumFractionDigits: 2,
                                        maximumFractionDigits: 2}) %>
                                </span>
                            </h6>
                            <div class="row g-3 mb-4">
                                <!-- Total Tuition Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e3f2fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #2196f3;">
                                            <i class="fas fa-university fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(tuitionTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Tuition Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Boarding Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #d1f7c4;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #4caf50;">
                                            <i class="fas fa-building fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(boardingTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Boarding Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Application Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fff3cd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #ff9800;">
                                            <i class="fas fa-file-signature fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(applicationTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Application Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Registration Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fce4ec;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #e91e63;">
                                            <i class="fas fa-user-plus fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(registrationTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Registration Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Exam Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e8f4fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #9c27b0;">
                                            <i class="fas fa-graduation-cap fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(examTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Exam Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Graduation Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #f3e5f5;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #673ab7;">
                                            <i class="fas fa-award fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(graduationTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Graduation Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Other Fees (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e8eaf6;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #3f51b5;">
                                            <i class="fas fa-file-invoice-dollar fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(otherTotal || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Other Fees</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Total Outstanding Balances (All Time) -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #ffebee;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #f44336;">
                                            <i class="fas fa-exclamation-triangle fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(totalBalanceOutstanding || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">All Balances</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ROW 2: TODAY'S TOTALS -->
                            <h6 class="fw-bold mb-3 text-muted">Today's Collection (<%= new Date().toLocaleDateString()
                                    %>)</h6>
                            <div class="row g-3">
                                <!-- Today's Tuition Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e3f2fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #2196f3;">
                                            <i class="fas fa-university fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayTuition || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Tuition Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Boarding Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #d1f7c4;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #4caf50;">
                                            <i class="fas fa-building fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayBoarding || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Boarding Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Application Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fff3cd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #ff9800;">
                                            <i class="fas fa-file-signature fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayApplication || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Applications Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Registration Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #fce4ec;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #e91e63;">
                                            <i class="fas fa-user-plus fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayRegistration || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Registrations Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Exam Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e8f4fd;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #9c27b0;">
                                            <i class="fas fa-graduation-cap fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayExam || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Exam Fees Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Graduation Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #f3e5f5;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #673ab7;">
                                            <i class="fas fa-award fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayGraduation || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Graduation Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Other Fees -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e8eaf6;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #3f51b5;">
                                            <i class="fas fa-file-invoice-dollar fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(todayOther || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Other Today</small>
                                        </div>
                                    </div>
                                </div>

                                <!-- Today's Total Collection -->
                                <div class="col-md-3 col-6">
                                    <div class="d-flex align-items-center p-3 rounded"
                                        style="background-color: #e0f7fa;">
                                        <div class="rounded-circle p-3 me-3" style="background-color: #00bcd4;">
                                            <i class="fas fa-wallet fa-2x text-white"></i>
                                        </div>
                                        <div>
                                            <h5 class="fw-bold mb-0">
                                                ZMW <%= Number(totalToday || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </h5>
                                            <small class="text-muted">Total Today</small>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- FILTERS AND SEARCH -->
            <!-- ===================================== -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <form method="GET" class="row g-3">
                        <div class="col-md-4">
                            <input type="text" name="search" class="form-control"
                                placeholder="Search student (name, email, or NURTE)" value="<%= search || '' %>">
                        </div>

                        <div class="col-md-3">
                            <select name="category" class="form-select">
                                <option value="">All Categories</option>
                                <option value="Tuition Fee (Per Semester)" <%=category==='Tuition Fee (Per Semester)'
                                    ? 'selected' : '' %>>Tuition Fee</option>
                                <option value="Boarding Fee" <%=category==='Boarding Fee' ? 'selected' : '' %>>Boarding
                                    Fee</option>
                                <option value="Application Fee" <%=category==='Application Fee' ? 'selected' : '' %>
                                    >Application Fee</option>
                                <option value="Registration Fee" <%=category==='Registration Fee' ? 'selected' : '' %>
                                    >Registration Fee</option>
                                <option value="Exam Fee" <%=category==='Exam Fee' ? 'selected' : '' %>>Exam Fee</option>
                                <option value="Graduation Fee" <%=category==='Graduation Fee' ? 'selected' : '' %>
                                    >Graduation Fee</option>
                                <option value="Other" <%=category==='Other' ? 'selected' : '' %>>Other</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <select name="limit" class="form-select" onchange="this.form.submit()">
                                <option value="20" <%=limit===20 ? 'selected' : '' %>>20 per page</option>
                                <option value="50" <%=limit===50 ? 'selected' : '' %>>50 per page</option>
                                <option value="100" <%=limit===100 ? 'selected' : '' %>>100 per page</option>
                            </select>
                        </div>

                        <div class="col-md-1">
                            <button class="btn btn-primary w-100">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>

                        <div class="col-md-2">
                            <a href="/vc/payments" class="btn btn-outline-secondary w-100">
                                <i class="fas fa-redo"></i> Reset
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- PAYMENTS TABLE -->
            <!-- ===================================== -->
            <div class="card shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0 fw-bold">
                        <i class="fas fa-list me-2"></i>Payment Records
                        <span class="badge bg-primary ms-2">
                            <%= totalCount %> payments
                        </span>
                    </h5>
                </div>

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Student Details</th>
                                <th>Category</th>
                                <th>Amount Paid</th>
                                <th>Balance</th>
                                <!-- <th>Method</th> -->
                                <th>Status</th>
                                <!-- <th>Date</th> -->
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!payments || payments.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-5">
                                        <i class="fas fa-search fa-2x mb-3"></i>
                                        <p>No payments found matching your criteria</p>
                                    </td>
                                </tr>
                                <% } else { %>
                                    <% payments.forEach(function(p, index) { %>
                                        <tr>
                                            <td class="fw-bold">
                                                <%= (currentPage - 1) * limit + index + 1 %>
                                            </td>

                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                                        style="width:40px; height:40px;">
                                                        <i class="fas fa-user-graduate text-primary"></i>
                                                    </div>
                                                    <div>
                                                        <strong>
                                                            <%= p.student ? p.student.firstName + ' ' +
                                                                p.student.surname : 'N/A' %>
                                                        </strong><br>
                                                        <small class="text-muted">
                                                            <%= p.student ? p.student.email : '' %>
                                                        </small><br>
                                                        <% if (p.student && p.student.studentProfile &&
                                                            p.student.studentProfile.nurteNumber) { %>
                                                            <small class="text-info">NURTE: <%=
                                                                    p.student.studentProfile.nurteNumber %></small>
                                                            <% } %>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <span class="badge bg-light text-dark border">
                                                    <%= p.category %>
                                                </span>
                                            </td>

                                            <td class="fw-bold" style="color: var(--primary-purple)">
                                                ZMW <%= Number(p.amount || 0).toLocaleString('en-US',
                                                    {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                            </td>

                                            <td>
                                                <% if ((p.balanceAfterPayment || 0)> 0) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-clock me-1"></i>ZMW <%=
                                                            Number(p.balanceAfterPayment || 0).toLocaleString('en-US',
                                                            {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-success">
                                                            <i class="fas fa-check me-1"></i>Paid
                                                        </span>
                                                        <% } %>
                                            </td>



                                            <td>
                                                <% const statusClass=p.status==='Verified' || p.status==='Fully Paid'
                                                    ? 'bg-success' : p.status==='Partially Paid'
                                                    ? 'bg-warning text-dark' : p.status==='Pending' ? 'bg-secondary' :
                                                    p.status==='Cancelled' || p.status==='Rejected' ? 'bg-danger'
                                                    : 'bg-light text-dark' ; %>
                                                    <span class="badge <%= statusClass %>">
                                                        <%= p.status %>
                                                    </span>
                                            </td>



                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= p._id %>">
                                                    <i class="fas fa-eye me-1"></i>View
                                                </button>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ===================================== -->
            <!-- PAGINATION AND FOOTER -->
            <!-- ===================================== -->
            <% if (payments && payments.length> 0) { %>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Showing <strong>
                            <%= (currentPage - 1) * limit + 1 %> to <%= Math.min(currentPage * limit, totalCount) %>
                        </strong>
                        of <strong>
                            <%= totalCount %>
                        </strong> payments
                    </div>

                    <% if (totalPages> 1) { %>
                        <nav>
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="?page=<%= currentPage-1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>

                                <% for(let i=Math.max(1, currentPage - 2); i <=Math.min(totalPages, currentPage + 2);
                                    i++) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                        <a class="page-link"
                                            href="?page=<%= i %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>

                                        <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                            <a class="page-link"
                                                href="?page=<%= currentPage+1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                                <i class="fas fa-chevron-right"></i>
                                            </a>
                                        </li>
                            </ul>
                        </nav>
                        <% } %>
                </div>
                <% } %>
        </div>
        <!-- ===================================== -->
        <!-- PAYMENT MODALS (VIEW ONLY - VC CAN'T VERIFY/CANCEL) -->
        <!-- ===================================== -->
        <% if (payments && payments.length> 0) { %>
            <% payments.forEach(function(payment) { %>
                <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
                        <div class="modal-content rounded-3">
                            <!-- Modal Header -->
                            <div class="modal-header" style="background-color: var(--primary-purple); color: white;">
                                <h5 class="modal-title fw-bold mb-0">
                                    <i class="fas fa-file-invoice-dollar me-2"></i>Payment Details
                                </h5>
                                <button type="button" class="btn-close btn-close-white"
                                    data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body p-4">
                                <!-- Reference & Status -->
                                <div class="mb-4">
                                    <div class="d-flex justify-content-between align-items-start mb-3">
                                        <div>
                                            <small class="text-muted d-block">Reference</small>
                                            <h6 class="mb-0 text-primary fw-bold">
                                                <%= payment.reference %>
                                            </h6>
                                        </div>
                                        <div class="text-end">
                                            <% let statusClass, statusIcon; if (payment.status==='Verified' ||
                                                payment.status==='Fully Paid' ) { statusClass='bg-success' ;
                                                statusIcon='fas fa-check-circle' ; } else if
                                                (payment.status==='Partially Paid' ) {
                                                statusClass='bg-warning text-dark' ; statusIcon='fas fa-clock' ; } else
                                                if (payment.status==='Pending' ) { statusClass='bg-secondary' ;
                                                statusIcon='fas fa-clock' ; } else if (payment.status==='Cancelled' ||
                                                payment.status==='Rejected' ) { statusClass='bg-danger' ;
                                                statusIcon='fas fa-times-circle' ; } else {
                                                statusClass='bg-light text-dark' ; statusIcon='fas fa-question-circle' ;
                                                } %>
                                                <small class="text-muted d-block">Status</small>
                                                <span class="badge <%= statusClass %>">
                                                    <i class="<%= statusIcon %> me-1"></i>
                                                    <%= payment.status %>
                                                </span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Amounts Section -->
                                <div class="mb-4">
                                    <div class="row g-2">
                                        <div class="col-4">
                                            <small class="text-muted d-block">Total Due</small>
                                            <h6 class="text-success fw-bold">
                                                ZMW <%= Number(payment.totalDue || 0).toFixed(2) %>
                                            </h6>
                                        </div>
                                        <div class="col-4">
                                            <small class="text-muted d-block">Amount Paid</small>
                                            <h6 class="text-primary fw-bold">
                                                ZMW <%= Number(payment.amount || 0).toFixed(2) %>
                                            </h6>
                                        </div>
                                        <div class="col-4">
                                            <small class="text-muted d-block">Balance</small>
                                            <h6
                                                class="<%= payment.balanceAfterPayment > 0 ? 'text-warning' : 'text-success' %> fw-bold">
                                                ZMW <%= Number(payment.balanceAfterPayment || 0).toFixed(2) %>
                                            </h6>
                                        </div>
                                    </div>
                                </div>

                                <!-- Expected Payment Date (if balance exists) -->
                                <% if (payment.expectedPaymentDate && payment.balanceAfterPayment> 0) { %>
                                    <div class="mb-4">
                                        <div class="alert alert-warning py-2">
                                            <div class="d-flex align-items-center">
                                                <i class="fas fa-calendar-alt me-2"></i>
                                                <div>
                                                    <small class="text-muted d-block mb-1">Expected Payment Date</small>
                                                    <strong>
                                                        <%= new Date(payment.expectedPaymentDate).toLocaleDateString()
                                                            %>
                                                    </strong>
                                                    <br>
                                                    <small class="text-muted">
                                                        Remaining balance: ZMW <%=
                                                            Number(payment.balanceAfterPayment).toFixed(2) %>
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>

                                        <!-- Student Information -->
                                        <div class="mb-4">
                                            <h6 class="fw-bold mb-3 border-bottom pb-2">
                                                <i class="fas fa-user-graduate me-2"></i> Student Details
                                            </h6>
                                            <div class="ps-3">
                                                <div class="mb-2">
                                                    <small class="text-muted d-block">Name</small>
                                                    <span class="fw-semibold">
                                                        <%= payment.student.firstName %>
                                                            <%= payment.student.surname %>
                                                    </span>
                                                </div>
                                                <div class="mb-2">
                                                    <small class="text-muted d-block">Email</small>
                                                    <span>
                                                        <%= payment.student.email %>
                                                    </span>
                                                </div>
                                                <% if (payment.student && typeof payment.student==='object' &&
                                                    payment.student.mobile) { %>
                                                    <div class="mb-2">
                                                        <small class="text-muted d-block">Mobile</small>
                                                        <span>
                                                            <%= payment.student.mobile %>
                                                        </span>
                                                    </div>
                                                    <% } else { %>
                                                        <div class="mb-2">
                                                            <small class="text-muted d-block">Mobile</small>
                                                            <span class="text-muted">Not available</span>
                                                        </div>
                                                        <% } %>

                                                            <% if (payment.student.studentId) { %>
                                                                <div>
                                                                    <small class="text-muted d-block">Student ID</small>
                                                                    <span class="badge bg-info">
                                                                        <%= payment.student.studentId %>
                                                                    </span>
                                                                </div>
                                                                <% } %>
                                            </div>
                                        </div>

                                        <!-- Payment Information -->
                                        <div class="mb-4">
                                            <h6 class="fw-bold mb-3 border-bottom pb-2">
                                                <i class="fas fa-credit-card me-2"></i> Payment Details
                                            </h6>
                                            <div class="ps-3">
                                                <div class="mb-2">
                                                    <small class="text-muted d-block">Category</small>
                                                    <span class="fw-semibold">
                                                        <%= payment.category %>
                                                    </span>
                                                </div>
                                                <% if (payment.description) { %>
                                                    <div class="mb-2">
                                                        <small class="text-muted d-block">Description</small>
                                                        <span>
                                                            <%= payment.description %>
                                                        </span>
                                                    </div>
                                                    <% } %>
                                                        <div class="mb-2">
                                                            <small class="text-muted d-block">Payment Method</small>
                                                            <span class="badge bg-primary">
                                                                <%= payment.method %>
                                                            </span>
                                                        </div>
                                            </div>
                                        </div>

                                        <!-- Academic Information -->
                                        <% if (payment.semester || payment.academicYear || payment.modeOfStudy) { %>
                                            <div class="mb-4">
                                                <h6 class="fw-bold mb-3 border-bottom pb-2">
                                                    <i class="fas fa-book me-2"></i> Academic Information
                                                </h6>
                                                <div class="ps-3">
                                                    <div class="row g-2">
                                                        <% if (payment.semester) { %>
                                                            <div class="col-6">
                                                                <small class="text-muted d-block">Semester</small>
                                                                <span>Semester <%= payment.semester %></span>
                                                            </div>
                                                            <% } %>
                                                                <% if (payment.academicYear) { %>
                                                                    <div class="col-6">
                                                                        <small class="text-muted d-block">Academic
                                                                            Year</small>
                                                                        <span>
                                                                            <%= payment.academicYear %>
                                                                        </span>
                                                                    </div>
                                                                    <% } %>
                                                                        <% if (payment.modeOfStudy) { %>
                                                                            <div class="col-12">
                                                                                <small class="text-muted d-block">Mode
                                                                                    of Study</small>
                                                                                <span>
                                                                                    <%= payment.modeOfStudy %>
                                                                                </span>
                                                                            </div>
                                                                            <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                            <% } %>

                                                <!-- Timeline -->
                                                <div class="mb-4">
                                                    <h6 class="fw-bold mb-3 border-bottom pb-2">
                                                        <i class="fas fa-history me-2"></i> Timeline
                                                    </h6>
                                                    <div class="ps-3">
                                                        <% const timeline=[ { label: 'Payment Created' , date:
                                                            payment.createdAt }, { label: 'Bank Deposit' , date:
                                                            payment.paymentReceivedOn }, { label: 'Payment Verified' ,
                                                            date: payment.verifiedAt } ].filter(item=> item.date); %>

                                                            <% timeline.forEach((item, index)=> { %>
                                                                <div class="mb-2">
                                                                    <small class="text-muted d-block">
                                                                        <%= item.label %>
                                                                    </small>
                                                                    <span>
                                                                        <%= new Date(item.date).toLocaleString() %>
                                                                    </span>
                                                                </div>
                                                                <% }); %>
                                                    </div>
                                                </div>

                                                <!-- Verified By -->
                                                <% if (payment.verifiedBy) { %>
                                                    <div class="mb-4">
                                                        <h6 class="fw-bold mb-3 border-bottom pb-2">
                                                            <i class="fas fa-user-check me-2"></i> Verified By
                                                        </h6>
                                                        <div class="ps-3">
                                                            <div class="d-flex align-items-center">
                                                                <div class="me-3">
                                                                    <i class="fas fa-user-tie fa-lg text-muted"></i>
                                                                </div>
                                                                <div>
                                                                    <small class="text-muted d-block">Finance
                                                                        Officer</small>
                                                                    <span class="fw-semibold">
                                                                        <%= payment.verifiedBy.firstName %>
                                                                            <%= payment.verifiedBy.surname %>
                                                                    </span>
                                                                    <br>
                                                                    <small class="text-muted">
                                                                        <%= new
                                                                            Date(payment.verifiedAt).toLocaleDateString()
                                                                            %>
                                                                    </small>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% } %>

                                                        <!-- Receipt -->
                                                        <% if (payment.receipt && payment.receipt.gcsUrl) { %>
                                                            <div class="mt-4 pt-3 border-top">
                                                                <div
                                                                    class="d-flex justify-content-between align-items-center">
                                                                    <div>
                                                                        <h6 class="fw-bold mb-1">
                                                                            <i class="fas fa-receipt me-2"></i> Receipt
                                                                        </h6>
                                                                        <small class="text-muted">
                                                                            Issued: <%= new
                                                                                Date(payment.receipt.issuedAt).toLocaleDateString()
                                                                                %>
                                                                        </small>
                                                                    </div>
                                                                    <div>
                                                                        <a href="<%= payment.receipt.gcsUrl %>"
                                                                            target="_blank"
                                                                            class="btn btn-sm btn-success">
                                                                            <i class="fas fa-eye me-1"></i> View
                                                                        </a>
                                                                        <a href="<%= payment.receipt.gcsUrl %>" download
                                                                            class="btn btn-sm btn-outline-success ms-1">
                                                                            <i class="fas fa-download me-1"></i>
                                                                            Download
                                                                        </a>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <% } %>
                            </div>

                            <!-- Modal Footer -->
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">
                                    <i class="fas fa-times me-1"></i> Close
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
                <% }); %>
                    <% } %>

                        <%- include('../partials/footer') %>