<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px">
                <h3 class="fw-bold text-center mb-4" style="color: var(--primary-purple)">
                    Skill Application
                </h3>

                <form action="/skills/apply" method="POST" enctype="multipart/form-data">

                    <!-- Select Skill -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Select Skill</label>
                        <select name="skill" class="form-select form-select-lg" required>
                            <option value="">-- Select a Skill --</option>
                            <% skills.forEach(s=> { %>
                                <option value="<%= s._id %>">
                                    <%= s.name %>
                                        <% if (s.duration) { %> ( <%= s.duration %> ) <% } %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <!-- Payment Method -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payment Method</label>
                        <select id="paymentMethod" name="paymentMethod" class="form-select" required>
                            <option value="">-- Select Payment Method --</option>
                            <option value="Manual">Manual Payment</option>
                            <option value="Electronic">Electronic Payment</option>
                            <option value="CDF Sponsored">CDF Sponsored</option>
                        </select>
                    </div>

                    <!-- Payment Amount -->
                    <div class="mb-3" id="amountGroup">
                        <label class="form-label fw-semibold">Amount Paid</label>
                        <input type="number" id="paymentAmount" name="paymentAmount" class="form-control" min="0"
                            step="0.01" placeholder="Enter amount paid" required />
                    </div>

                    <!-- Upload Documents -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Attach Certificates & Receipts(If Available)</label>
                        <input type="file" name="documents" class="form-control" multiple required />
                        <div class="form-text">Upload up to 5 files (PDF, JPG, PNG)</div>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn w-100 py-2 fw-semibold"
                        style="background-color: var(--secondary-pink); color: white; border-radius: 30px;">
                        <i class="fas fa-paper-plane me-1"></i> Submit Application
                    </button>

                </form>
            </div>
        </div>

        <!-- Auto-hide amount field when CDF is chosen -->
        <script>
            const paymentMethod = document.getElementById("paymentMethod");
            const amountGroup = document.getElementById("amountGroup");
            const paymentAmount = document.getElementById("paymentAmount");

            paymentMethod.addEventListener("change", function () {
                if (this.value === "CDF Sponsored") {
                    amountGroup.style.display = "none";
                    paymentAmount.required = false;
                    paymentAmount.value = 0;
                } else {
                    amountGroup.style.display = "block";
                    paymentAmount.required = true;
                    paymentAmount.value = "";
                }
            });
        </script>

        <%- include('../partials/footer') %>