<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">

            <div class="text-center mb-4">
                <h2 class="fw-bold mb-2" style="color: var(--primary-purple)">
                    <%= user.firstName %>
                        <%= user.surname %>
                            <%= user.otherNames || "" %>
                                Skill Applications
                </h2>
                <p class="text-muted">Track the status of your skill training applications</p>
            </div>

            <% if (applications.length===0) { %>
                <div class="alert alert-info text-center">
                    You have not submitted any skill applications yet.
                    <a href="/skills/apply" class="fw-bold" style="color: var(--secondary-pink)">Apply now</a>.
                </div>
                <% } else { %>

                    <div class="row justify-content-center g-4">

                        <% applications.forEach((app, index)=> { %>
                            <div class="col-12 col-md-6 col-lg-4">

                                <div class="card shadow-lg border-0 rounded-3 h-100 position-relative">

                                    <!-- 🎓 CDF SPONSORED RIBBON -->
                                    <% if (app.payment && app.payment.method==="CDF Sponsored" ) { %>
                                        <div class="position-absolute top-0 start-0 w-100 text-center fw-bold text-white py-1"
                                            style="background: linear-gradient(90deg, #ff6a00, #ff0084);
                     border-top-left-radius: 10px;
                     border-top-right-radius: 10px;
                     z-index: 10;">
                                            🎓 CDF SPONSORED APPLICATION
                                        </div>
                                        <% } %>

                                            <div class="card-body p-4 mt-4">

                                                <!-- Header -->
                                                <div class="text-center mb-4">
                                                    <div class="rounded-circle bg-primary bg-opacity-10 d-inline-flex align-items-center 
                  justify-content-center mb-3" style="width: 60px; height: 60px">
                                                        <i class="fas fa-tools fa-lg text-primary"></i>
                                                    </div>

                                                    <h5 class="fw-bold text-primary mb-2">
                                                        Skill Application #<%= index + 1 %>
                                                    </h5>

                                                    <span class="badge 
                <% if (app.status === 'Approved') { %> bg-success <% } %>
                <% if (app.status === 'Rejected') { %> bg-danger <% } %>
                <% if (app.status === 'Under Review') { %> bg-info text-dark <% } %>
                <% if (app.status === 'Pending') { %> bg-secondary <% } %>">
                                                        <%= app.status %>
                                                    </span>
                                                </div>

                                                <!-- Skill Details -->
                                                <div class="mb-4">
                                                    <h6 class="fw-bold text-success mb-3">
                                                        <i class="fas fa-book-open me-2"></i> Skill Applied For
                                                    </h6>
                                                    <div class="small text-muted">
                                                        <p class="mb-1">
                                                            <strong>Skill:</strong>
                                                            <%= app.skill?.name %>
                                                        </p>

                                                        <p class="mb-0">
                                                            <strong>Category:</strong>
                                                            <%= app.skill?.category %>
                                                        </p>
                                                    </div>
                                                </div>

                                                <!-- Application Info -->
                                                <div class="mb-4">
                                                    <h6 class="fw-bold text-info mb-3">
                                                        <i class="fas fa-calendar me-2"></i> Application Details
                                                    </h6>
                                                    <div class="small text-muted">
                                                        <p class="mb-1">
                                                            <strong>Submitted:</strong>
                                                            <%= app.createdAt.toDateString() %>
                                                        </p>
                                                        <p class="mb-0">
                                                            <strong>Payment:</strong>
                                                            <%= app.payment?.method %>
                                                        </p>
                                                    </div>
                                                </div>

                                                <!-- Documents -->
                                                <div class="mb-4">
                                                    <h6 class="fw-bold text-secondary mb-3">
                                                        <i class="fas fa-paperclip me-2"></i> Supporting Documents
                                                    </h6>
                                                    <ul class="list-group small">
                                                        <% app.documents.forEach(doc=> { %>
                                                            <li
                                                                class="list-group-item d-flex justify-content-between align-items-center">
                                                                <span>
                                                                    <%= doc.name %>
                                                                </span>
                                                                <a href="<%= doc.signedUrl %>" target="_blank"
                                                                    class="btn btn-sm btn-outline-primary">View</a>
                                                            </li>
                                                            <% }) %>
                                                    </ul>
                                                </div>

                                                <!-- Acceptance Letter -->
                                                <div class="mb-4">
                                                    <h5 class="fw-bold text-warning mb-3">
                                                        <i class="fas fa-award me-2"></i> Acceptance Letter
                                                    </h5>

                                                    <% if (app.acceptanceLetter && app.acceptanceLetter.gcsPath) { %>
                                                        <div class="alert alert-success">
                                                            <div
                                                                class="d-flex justify-content-between align-items-center">
                                                                <div>
                                                                    <i class="fas fa-check-circle me-2"></i>
                                                                    <strong>
                                                                        <%= app.acceptanceLetter.name %>
                                                                    </strong>
                                                                    <br />
                                                                    <small class="text-muted">
                                                                        Uploaded: <%=
                                                                            app.acceptanceLetter.uploadedAt.toDateString()
                                                                            %>
                                                                    </small>
                                                                </div>
                                                                <a href="/skills/<%= app._id %>/letter" target="_blank"
                                                                    class="btn btn-success btn-sm">
                                                                    <i class="fas fa-download me-1"></i> View Letter
                                                                </a>
                                                            </div>
                                                        </div>
                                                        <% } else { %>
                                                            <div class="alert alert-secondary">
                                                                <i class="fas fa-clock me-2"></i> Not available yet
                                                            </div>
                                                            <% } %>
                                                </div>

                                                <!-- Status -->
                                                <div class="mt-4 pt-3 border-top text-center">
                                                    <% if (app.status==='Approved' ) { %>
                                                        <div class="alert alert-success py-2 mb-0">
                                                            <i class="fas fa-check-circle me-2"></i> Approved
                                                        </div>
                                                        <% } else if (app.status==='Rejected' ) { %>
                                                            <div class="alert alert-danger py-2 mb-0">
                                                                <i class="fas fa-times-circle me-2"></i> Rejected
                                                            </div>
                                                            <% } else if (app.status==='Under Review' ) { %>
                                                                <div class="alert alert-info py-2 mb-0">
                                                                    <i class="fas fa-sync-alt me-2"></i> Under Review
                                                                </div>
                                                                <% } else { %>
                                                                    <div class="alert alert-secondary py-2 mb-0">
                                                                        <i class="fas fa-clock me-2"></i> Pending
                                                                    </div>
                                                                    <% } %>
                                                </div>

                                            </div>
                                </div>
                            </div>
                            <% }) %>

                    </div>

                    <% } %>
        </div>

        <%- include('../partials/footer') %>