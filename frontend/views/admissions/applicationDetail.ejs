<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="container my-4">
  <h2 class="fw-bold mb-4 text-center" style="color: var(--primary-purple)">
    Application Detail By admission
  </h2>

  <div class="row justify-content-center">
    <!-- 1/2 width on large screens -->
    <div class="col-12 col-md-8 col-lg-6">
      <!-- Main Card -->
      <div class="card shadow-lg border-0 rounded-3 p-3 p-md-4">

        <!-- Applicant Info -->
        <div class="mb-4">
          <h5 class="fw-bold text-primary mb-3">
            <i class="fas fa-user-graduate me-2"></i> Applicant Information
          </h5>
          <div class="small text-muted">
            <p class="mb-1"><strong>Name:</strong> <%= application.applicant.firstName %> <%= application.applicant.surname %></p>
            <p class="mb-1"><strong>Email:</strong> <%= application.applicant.email %></p>
            <p class="mb-0"><strong>Mobile:</strong> <%= application.applicant.mobile %></p>
          </div>
        </div>

        <!-- Programme Choices -->
        <div class="mb-4">
          <h5 class="fw-bold text-success mb-3">
            <i class="fas fa-book-open me-2"></i> Programme Choices
          </h5>
          <div class="small text-muted">
            <p class="mb-1"><strong>First Choice:</strong> <%= application.firstChoice.name %> (<%= application.firstChoice.code %>)</p>
            <p class="mb-0"><strong>Second Choice:</strong> 
              <%= application.secondChoice ? application.secondChoice.name : "None" %>
            </p>
          </div>
        </div>

        <!-- Documents -->
        <!-- <div class="mb-4">
          <h5 class="fw-bold text-info mb-3">
            <i class="fas fa-file-alt me-2"></i> Documents
          </h5>
          <ul class="list-group small">
            <% application.documents.forEach(doc => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span><i class="fas fa-paperclip me-2 text-secondary"></i><%= doc.name %></span>
                <a href="<%= doc.gcsUrl %>" target="_blank" class="btn btn-sm btn-outline-primary">
                  View
                </a>
              </li>
            <% }) %>
          </ul>
        </div> -->

        <!-- Documents -->
    <div class="mb-4">
      <h5 class="fw-bold text-info mb-3">
        <i class="fas fa-file-alt me-2"></i> Documents
      </h5>
      <ul class="list-group small">
        <% application.documents.forEach(doc => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><i class="fas fa-paperclip me-2 text-secondary"></i><%= doc.name %></span>
            <a href="<%= doc.signedUrl %>" target="_blank" class="btn btn-sm btn-outline-primary">
              View
            </a>
          </li>
        <% }) %>
      </ul>
    </div>


        <!-- Status & Actions -->
        <div>
          <h5 class="fw-bold text-warning mb-3">
            <i class="fas fa-tasks me-2"></i> Application Status
          </h5>
          <form action="/admissions/applications/<%= application._id %>/status" method="POST">
            <div class="mb-3">
              <select name="status" class="form-select" required>
                <option value="Pending" <%= application.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                <option value="Under Review" <%= application.status === 'Under Review' ? 'selected' : '' %>>Under Review</option>
                <option value="Approved" <%= application.status === 'Approved' ? 'selected' : '' %>>Approved</option>
                <option value="Rejected" <%= application.status === 'Rejected' ? 'selected' : '' %>>Rejected</option>
              </select>
            </div>

            <div class="mb-3">
              <textarea name="remarks" class="form-control" rows="3" placeholder="Add remarks (optional)"><%= application.remarks || "" %></textarea>
            </div>

            <div class="d-grid gap-2">
              <button type="submit" class="btn btn-success">
                <i class="fas fa-save me-1"></i> Update Status
              </button>
              <a href="/admissions/applications" class="btn btn-outline-secondary">
                <i class="fas fa-arrow-left me-1"></i> Back to Applications
              </a>
            </div>
          </form>
        </div>

      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
