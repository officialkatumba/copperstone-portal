<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      Applications & Payments
    </h2>
    <p class="text-muted">
      Review all student applications and their payment status.
    </p>
  </div>

  <% if (applications.length === 0) { %>
  <div class="alert alert-info text-center">No applications found.</div>
  <% } else { %>
  <div class="table-responsive shadow-sm rounded-3">
    <table class="table table-striped align-middle">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <th>Applicant</th>
          <th>Programme (1st Choice)</th>
          <th>Application Status</th>
          <th>Payment Method & Amount</th>
          <th>Payment Status</th>
          <th>Submitted On</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% applications.forEach((app, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <strong
              ><%= app.applicant.firstName %> <%= app.applicant.surname
              %></strong
            ><br />
            <small><%= app.applicant.email %></small>
          </td>
          <td><%= app.firstChoice?.name %> (<%= app.firstChoice?.code %>)</td>

          <!-- ✅ Application Status -->
          <td>
            <% if (app.status === 'Approved') { %>
            <span class="badge bg-success">Approved</span>
            <% } else if (app.status === 'Rejected') { %>
            <span class="badge bg-danger">Rejected</span>
            <% } else if (app.status === 'Under Review') { %>
            <span class="badge bg-info text-dark">Under Review</span>
            <% } else { %>
            <span class="badge bg-warning text-dark">Pending</span>
            <% } %>
          </td>

          <!-- ✅ Payment Method & Amount combined -->
          <td>
            <% if (app.payment?.method) { %> <%= app.payment.method %> <% if
            (app.payment.amount) { %> —
            <strong>ZMW <%= app.payment.amount.toLocaleString() %></strong> <% }
            %> <% } else { %>
            <span class="text-muted">N/A</span>
            <% } %>
          </td>

          <!-- ✅ Payment Status -->
          <td>
            <% if (app.payment?.status === 'Verified') { %>
            <span class="badge bg-success">Verified</span>
            <% } else if (app.payment?.status === 'Rejected') { %>
            <span class="badge bg-danger">Rejected</span>
            <% } else { %>
            <span class="badge bg-warning text-dark">Pending</span>
            <% } %>
          </td>

          <td><%= new Date(app.createdAt).toLocaleDateString() %></td>

          <td>
            <a
              href="/admissions/applications/<%= app._id %>"
              class="btn btn-sm btn-primary"
            >
              <i class="fas fa-eye"></i> View
            </a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
