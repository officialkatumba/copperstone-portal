<%- include('../../partials/header') %>
    <%- include('../../partials/navbar') %>

        <div class="container my-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="color: var(--primary-purple)">
                    Skill Applications - Admissions
                </h2>
                <p class="text-muted">Review and approve/reject skill applications.</p>
            </div>

            <% if (!applications || applications.length===0) { %>
                <div class="alert alert-info text-center">No skill applications found.</div>
                <% } else { %>
                    <div class="table-responsive shadow-sm rounded-3">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Applicant</th>
                                    <th>Skill</th>
                                    <th>Method</th>
                                    <th>Payment Status</th>
                                    <th>Application Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% applications.forEach((app, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= index + 1 %>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= app.applicant.firstName %>
                                                    <%= app.applicant.surname %>
                                            </strong><br>
                                            <small class="text-muted">
                                                <%= app.applicant.email %>
                                            </small>
                                        </td>
                                        <td>
                                            <%= app.skill?.name %>
                                                <div class="small text-muted">
                                                    <%= app.skill?.code %> • <%= app.skill?.duration %>
                                                </div>
                                        </td>
                                        <td>
                                            <%= app.payment?.method || "—" %>
                                        </td>
                                        <td>
                                            <% if (app.payment?.status==="Verified" ) { %>
                                                <span class="badge bg-success">Verified</span>
                                                <% } else if (app.payment?.status==="Rejected" ) { %>
                                                    <span class="badge bg-danger">Rejected</span>
                                                    <% } else { %>
                                                        <span class="badge bg-warning text-dark">Pending</span>
                                                        <% } %>
                                        </td>
                                        <td>
                                            <% if (app.status==='Approved' ) { %>
                                                <span class="badge bg-success">Approved</span>
                                                <% } else if (app.status==='Rejected' ) { %>
                                                    <span class="badge bg-danger">Rejected</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">Pending</span>
                                                        <% } %>
                                        </td>
                                        <td>
                                            <a href="/admissions/skills/applications/<%= app._id %>"
                                                class="btn btn-sm btn-primary">
                                                <i class="fas fa-eye me-1"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>

        <%- include('../../partials/footer') %>