<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold" style="color: var(--primary-purple)">
                        <i class="fas fa-users me-2"></i>Manage Academic Groups
                    </h2>
                    <p class="text-muted">View and manage all academic groups/classes</p>
                </div>
                <a href="/registrar/groups/create" class="btn btn-primary">
                    <i class="fas fa-plus-circle me-1"></i> Create New Group
                </a>
            </div>

            <!-- Filter Card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <form method="GET" action="/registrar/groups" class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Academic Year</label>
                            <select class="form-select" name="academicYear">
                                <option value="">All Years</option>
                                <% academicYears.forEach(year=> { %>
                                    <option value="<%= year %>" <%=query.academicYear===year ? 'selected' : '' %>>
                                        <%= year %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Semester</label>
                            <select class="form-select" name="semester">
                                <option value="">All Semesters</option>
                                <% semesters.forEach(sem=> { %>
                                    <option value="<%= sem %>" <%=query.semester===sem ? 'selected' : '' %>>
                                        <%= sem %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Programme</label>
                            <select class="form-select" name="programme">
                                <option value="">All Programmes</option>
                                <% programmes.forEach(prog=> { %>
                                    <option value="<%= prog._id %>" <%=query.programme===prog._id.toString()
                                        ? 'selected' : '' %>>
                                        <%= prog.code %>
                                    </option>
                                    <% }); %>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" name="status">
                                <option value="">All Status</option>
                                <option value="Draft" <%=query.status==='Draft' ? 'selected' : '' %>>Draft</option>
                                <option value="Active" <%=query.status==='Active' ? 'selected' : '' %>>Active</option>
                                <option value="Inactive" <%=query.status==='Inactive' ? 'selected' : '' %>>Inactive
                                </option>
                                <option value="Completed" <%=query.status==='Completed' ? 'selected' : '' %>>Completed
                                </option>
                                <option value="Archived" <%=query.status==='Archived' ? 'selected' : '' %>>Archived
                                </option>
                            </select>
                        </div>
                        <div class="col-12">
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-filter me-1"></i> Filter
                                </button>
                                <a href="/registrar/groups" class="btn btn-outline-secondary">
                                    <i class="fas fa-times me-1"></i> Clear
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Groups Table -->
            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Group Name</th>
                                    <th>Programme</th>
                                    <th>Academic Year</th>
                                    <th>Semester</th>
                                    <th>Year</th>
                                    <th>Students</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (groups.length===0) { %>
                                    <tr>
                                        <td colspan="9" class="text-center py-4">
                                            <i class="fas fa-users fa-2x text-muted mb-3"></i>
                                            <p class="text-muted">No groups found</p>
                                            <a href="/registrar/groups/create" class="btn btn-primary btn-sm">
                                                <i class="fas fa-plus me-1"></i> Create First Group
                                            </a>
                                        </td>
                                    </tr>
                                    <% } %>

                                        <% groups.forEach(group=> { %>
                                            <tr>
                                                <td>
                                                    <strong>
                                                        <%= group.name %>
                                                    </strong><br>
                                                    <small class="text-muted">
                                                        <%= group.groupType %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <% if (group.programme) { %>
                                                        <%= group.programme.code %><br>
                                                            <small class="text-muted">
                                                                <%= group.programme.name %>
                                                            </small>
                                                            <% } else { %>
                                                                <span class="text-muted">N/A</span>
                                                                <% } %>
                                                </td>
                                                <td>
                                                    <%= group.academicYear %>
                                                </td>
                                                <td>
                                                    <%= group.semester %>
                                                </td>
                                                <td>Year <%= group.yearOfStudy %>
                                                </td>
                                                <td>
                                                    <span
                                                        class="badge bg-<%= group.currentEnrollment >= group.capacity ? 'danger' : 'success' %>">
                                                        <%= group.currentEnrollment %> / <%= group.capacity %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <span class="badge bg-<%= 
                                        group.status === 'Active' ? 'success' : 
                                        group.status === 'Draft' ? 'warning' : 
                                        group.status === 'Archived' ? 'secondary' : 
                                        'info' 
                                    %>">
                                                        <%= group.status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <small>
                                                        <%= group.createdAt.toLocaleDateString() %>
                                                    </small>
                                                </td>
                                                <td>
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="/registrar/groups/<%= group._id %>"
                                                            class="btn btn-outline-primary" title="View">
                                                            <i class="fas fa-eye"></i>
                                                        </a>
                                                        <a href="/registrar/groups/<%= group._id %>"
                                                            class="btn btn-outline-info" title="Edit">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                        <button type="button" class="btn btn-outline-danger"
                                                            title="Archive" data-bs-toggle="modal"
                                                            data-bs-target="#deleteModal<%= group._id %>">
                                                            <i class="fas fa-archive"></i>
                                                        </button>
                                                    </div>

                                                    <!-- Delete Modal -->
                                                    <div class="modal fade" id="deleteModal<%= group._id %>"
                                                        tabindex="-1">
                                                        <div class="modal-dialog">
                                                            <div class="modal-content">
                                                                <div class="modal-header">
                                                                    <h5 class="modal-title">Archive Group</h5>
                                                                    <button type="button" class="btn-close"
                                                                        data-bs-dismiss="modal"></button>
                                                                </div>
                                                                <div class="modal-body">
                                                                    Are you sure you want to archive "<%= group.name %>
                                                                        "?
                                                                        <% if (group.currentEnrollment> 0) { %>
                                                                            <div class="alert alert-warning mt-2">
                                                                                <i
                                                                                    class="fas fa-exclamation-triangle me-1"></i>
                                                                                This group has <%=
                                                                                    group.currentEnrollment %> enrolled
                                                                                    students.
                                                                            </div>
                                                                            <% } %>
                                                                </div>
                                                                <div class="modal-footer">
                                                                    <button type="button" class="btn btn-secondary"
                                                                        data-bs-dismiss="modal">Cancel</button>
                                                                    <form method="POST"
                                                                        action="/registrar/groups/<%= group._id %>/delete">
                                                                        <button type="submit"
                                                                            class="btn btn-danger">Archive
                                                                            Group</button>
                                                                    </form>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </td>
                                            </tr>
                                            <% }); %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <% if (totalPages> 1) { %>
                        <nav class="mt-4">
                            <ul class="pagination justify-content-center">
                                <% for(let i=1; i <=totalPages; i++) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                        <a class="page-link"
                                            href="/registrar/groups?page=<%= i %><%= query.academicYear ? '&academicYear=' + query.academicYear : '' %><%= query.semester ? '&semester=' + query.semester : '' %><%= query.programme ? '&programme=' + query.programme : '' %><%= query.status ? '&status=' + query.status : '' %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                    <% } %>
                            </ul>
                        </nav>
                        <% } %>

                            <!-- Summary -->
                            <div class="mt-3 text-end">
                                <small class="text-muted">
                                    Showing <%= groups.length %> of <%= totalGroups %> groups
                                </small>
                            </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>