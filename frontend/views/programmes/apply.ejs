<%- include('../partials/header') %>
  <%- include('../partials/navbar') %>

    <div class="container my-5">
      <div class="card shadow-lg p-4 mx-auto" style="max-width: 500px">
        <h3 class="fw-bold text-center mb-4" style="color: var(--primary-purple)">
          Programme Application
        </h3>

        <form action="/applications/apply" method="POST" enctype="multipart/form-data">
          <!-- ADD THESE HIDDEN FIELDS -->
          <input type="hidden" name="source" value="student">
          <input type="hidden" name="category" value="Application Fee">
          <input type="hidden" name="totalDue" id="totalDueField" value="0">
          <input type="hidden" name="balanceAfterPayment" value="0">

          <div class="mb-3">
            <label class="form-label fw-semibold">First Choice Programme</label>
            <select name="firstChoice" class="form-select form-select-lg" required>
              <option value="">-- Select First Choice --</option>
              <% programmes.forEach(p=> { %>
                <option value="<%= p._id %>">
                  <%= p.name %>
                </option>
                <% }) %>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Second Choice Programme</label>
            <select name="secondChoice" class="form-select form-select-lg">
              <option value="">-- Optional --</option>
              <% programmes.forEach(p=> { %>
                <option value="<%= p._id %>">
                  <%= p.name %>
                </option>
                <% }) %>
            </select>
          </div>

          <!-- Payment Information -->
          <div class="mb-3">
            <label class="form-label fw-semibold">Payment Method</label>
            <select id="paymentMethod" name="paymentMethod" class="form-select" required>
              <option value="">-- Select Payment Method --</option>
              <option value="Cash">Cash</option>
              <option value="Manual">Bank</option>
              <option value="Electronic">Online</option>
            </select>
          </div>

          <input type="hidden" name="paymentDescription" value="Application Fee">

          <!-- <div class="mb-3" id="amountGroup">
            <label class="form-label fw-semibold">Amount Paid</label>
            <input type="number" id="paymentAmount" name="paymentAmount" class="form-control" min="0" step="0.01"
              placeholder="Enter amount paid" required oninput="updateTotalDue()" />
          </div> -->

          <div class="mb-3" id="amountGroup">
            <label class="form-label fw-semibold">Amount Paid (Application Fee Only)</label>
            <select id="paymentAmount" name="paymentAmount" class="form-control" required oninput="updateTotalDue()">
              <option value="" disabled selected>Select amount paid</option>
              <option value="150">150</option>
              <option value="200">200</option>
              <option value="300">300</option>
            </select>
          </div>

          <div class="mb-3">
            <label class="form-label fw-semibold">Attach Certificates & Receipts</label>
            <input type="file" name="documents" class="form-control" multiple required />
            <div class="form-text">Upload up to 5 files (PDF, JPG, PNG)</div>
          </div>

          <button type="submit" class="btn w-100 py-2 fw-semibold"
            style="background-color: var(--secondary-pink); color: white; border-radius: 30px;">
            <i class="fas fa-paper-plane me-1"></i> Submit Application
          </button>

        </form>
      </div>
    </div>

    <script>
      const paymentMethod = document.getElementById("paymentMethod");
      const amountGroup = document.getElementById("amountGroup");
      const paymentAmount = document.getElementById("paymentAmount");
      const totalDueField = document.getElementById("totalDueField");

      // Function to update totalDue hidden field
      function updateTotalDue() {
        const amount = parseFloat(paymentAmount.value) || 0;
        totalDueField.value = amount; // For application fee, total due = amount paid
      }

      paymentMethod.addEventListener("change", function () {
        if (this.value === "CDF Sponsored") {
          amountGroup.style.display = "none";
          paymentAmount.required = false;
          paymentAmount.value = 0;
          updateTotalDue();
        } else {
          amountGroup.style.display = "block";
          paymentAmount.required = true;
          paymentAmount.value = "";
        }
      });

      // Initialize on page load
      updateTotalDue();
    </script>

    <%- include('../partials/footer') %>