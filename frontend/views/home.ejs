    <!-- Hero Section -->
    <section class="hero">
      <div class="container">
        <h1>Welcome to Copperstone University</h1>
        <p>
          Excellence in education since 2000. Join our community of learners and
          innovators shaping the future.
        </p>
        <div class="hero-buttons">
          <a href="#" class="btn hero-btn">Explore Programs</a>
          <a href="#" class="btn hero-btn outline">Request Information</a>
        </div>
      </div>
    </section>

    <!-- Features Section -->
    <section class="features">
      <div class="container">
        <div class="row text-center mb-5">
          <div class="col-12">
            <h2>Why Choose Copperstone?</h2>
            <p class="lead">Discover what makes us different</p>
          </div>
        </div>
        <div class="row">
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon">
                <i class="fas fa-graduation-cap"></i>
              </div>
              <h3>Accredited Programs</h3>
              <p>
                Our programs are fully accredited and recognized globally for
                their academic excellence.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon">
                <i class="fas fa-users"></i>
              </div>
              <h3>Expert Faculty</h3>
              <p>
                Learn from industry professionals and renowned academics
                dedicated to your success.
              </p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="feature-box">
              <div class="feature-icon">
                <i class="fas fa-hand-holding-usd"></i>
              </div>
              <h3>Affordable Tuition</h3>
              <p>
                Quality education shouldn't break the bank. We offer competitive
                tuition and financial aid.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Courses Section -->
    <section class="courses">
      <div class="container">
        <div class="row text-center mb-5">
          <div class="col-12">
            <h2>Popular Programs</h2>
            <p class="lead">Explore our most sought-after degrees</p>
          </div>
        </div>
        <div class="row g-4">
          <div class="col-md-4">
            <div class="card">
              <img
                src="https://media.istockphoto.com/id/1396801868/photo/a-young-african-american-doctor-works-on-hud-or-graphic-display-in-front-of-her.jpg?s=1024x1024&w=is&k=20&c=2lHP_sEKCF-oGDLXmMtkDZaY0smbQCEHGdi7KBS_9Jg="
                class="card-img-top"
                alt="Computer Science"
              />
              <div class="card-body">
                <h5 class="card-title">Computer Science</h5>
                <p class="card-text">
                  Master programming, AI, and data science through hands-on
                  projects with industry experts and cutting-edge technology.
                </p>
                <a href="#" class="btn card-btn">Learn More</a>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card">
              <img
                src="https://media.istockphoto.com/id/635977924/photo/workplace-safety-manual-with-work-equipment.jpg?s=1024x1024&w=is&k=20&c=wT005jqKxBGRBHcGEXdpa4muJQigLaIFcvTSDTY-kMU="
                class="card-img-top"
                alt="Health and Safety Management"
              />
              <div class="card-body">
                <h5 class="card-title">Health & Safety Management</h5>
                <p class="card-text">
                  Learn risk assessment, safety protocols, and regulatory
                  compliance for workplace environments across various
                  industries.
                </p>
                <a href="#" class="btn card-btn">Learn More</a>
              </div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="card">
              <img
                src="https://media.istockphoto.com/id/2161387257/photo/young-businesswoman-using-laptop-at-table-looking-to-side.jpg?s=1024x1024&w=is&k=20&c=KktrDV-Cf2cjUZiZgNmA6BKKddE5qoZhfGmS93CHmqQ="
                class="card-img-top"
                alt="Business Administration"
              />
              <div class="card-body">
                <h5 class="card-title">Business Administration</h5>
                <p class="card-text">
                  Develop leadership, finance, and entrepreneurial skills for
                  today's dynamic global business environment and challenges.
                </p>
                <a href="#" class="btn card-btn">Learn More</a>
              </div>
            </div>
          </div>
        </div>
        <div class="row mt-5 text-center">
          <div class="col-12">
            <a href="#" class="btn btn-outline-primary btn-lg"
              >View All Programs</a
            >
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
