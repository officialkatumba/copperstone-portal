<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      <%= user.firstName %> <%= user.surname %> <%= user.otherNames || "" %>
      Applications
    </h2>
    <p class="text-muted">Track the status of your submitted applications</p>
  </div>

  <% if (applications.length === 0) { %>
  <div class="alert alert-info text-center">
    You have not submitted any applications yet.
    <a
      href="/programs/apply"
      class="fw-bold"
      style="color: var(--secondary-pink)"
      >Apply now</a
    >.
  </div>
  <% } else { %>
  <div class="row g-4">
    <% applications.forEach(app => { %>
    <div class="col-md-6">
      <div class="card shadow-sm border-0 h-100">
        <div class="card-body">
          <h5 class="fw-bold">
            <i class="fas fa-file-alt me-2"></i>Application
          </h5>
          <p>
            <strong>First Choice:</strong> <%= app.firstChoice?.name %> (<%=
            app.firstChoice?.level %>)
          </p>
          <% if (app.secondChoice) { %>
          <p>
            <strong>Second Choice:</strong> <%= app.secondChoice?.name %> (<%=
            app.secondChoice?.level %>)
          </p>
          <% } %>
          <p>
            <strong>Status:</strong>
            <% if (app.status === "Pending") { %>
            <span class="badge bg-secondary">Pending</span>
            <% } else if (app.status === "Under Review") { %>
            <span class="badge bg-info text-dark">Under Review</span>
            <% } else if (app.status === "Approved") { %>
            <span class="badge bg-success">Approved</span>
            <% } else { %>
            <span class="badge bg-danger">Rejected</span>
            <% } %>
          </p>
          <p>
            <strong>Submitted On:</strong> <%= app.createdAt.toDateString() %>
          </p>

          <hr />

          <!-- Application Documents -->
          <h6><i class="fas fa-file-pdf me-2"></i>Application Documents</h6>
          <ul>
            <% app.documents.forEach(doc => { %>
            <li>
              <a href="<%= doc.signedUrl %>" target="_blank"><%= doc.name %></a>
            </li>
            <% }) %>
          </ul>

          <!-- Acceptance Letter -->
          <h6><i class="fas fa-award me-2"></i>Acceptance Letter</h6>
          <% if (app.acceptanceLetter && app.acceptanceLetter.gcsName) { %>
          <div class="d-flex justify-content-between align-items-center">
            <span>Official Acceptance Letter</span>
            <a
              href="/applications/<%= app._id %>/letter"
              target="_blank"
              class="btn btn-sm btn-success"
            >
              <i class="fas fa-download me-1"></i> View Letter
            </a>
          </div>
          <% } else { %>
          <div class="text-muted">
            <i class="fas fa-clock me-1"></i> Not available yet
          </div>
          <% } %>
        </div>
      </div>
    </div>
    <% }) %>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
