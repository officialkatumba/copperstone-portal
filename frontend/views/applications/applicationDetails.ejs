<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-4">
            <h2 class="fw-bold mb-4 text-center" style="color: var(--primary-purple)">
                Application Details
            </h2>

            <div class="row justify-content-center">
                <div class="col-12 col-md-8 col-lg-6">

                    <!-- Main Card -->
                    <div class="card shadow-lg border-0 rounded-3 p-3 p-md-4">

                        <!-- Application Status -->
                        <div class="mb-4 mt-3 text-center">
                            <span class="badge 
                        <%= application.status === 'Approved' ? 'bg-success' :
                            application.status === 'Rejected' ? 'bg-danger' :
                            application.status === 'Under Review' ? 'bg-info text-dark' :
                            'bg-secondary' %>">
                                <%= application.status %>
                            </span>
                        </div>

                        <!-- Programme Choices -->
                        <div class="mb-4">
                            <h5 class="fw-bold text-success mb-3">
                                <i class="fas fa-book-open me-2"></i> Programme Choices
                            </h5>
                            <div class="small text-muted">
                                <p class="mb-1">
                                    <strong>First Choice:</strong>
                                    <%= application.firstChoice?.name %>
                                        (<%= application.firstChoice?.code %>)
                                </p>
                                <p class="mb-0">
                                    <strong>Second Choice:</strong>
                                    <%= application.secondChoice ? application.secondChoice.name : "None" %>
                                </p>
                            </div>
                        </div>

                        <!-- Application Info -->
                        <div class="mb-4">
                            <h5 class="fw-bold text-info mb-3">
                                <i class="fas fa-info-circle me-2"></i> Application Info
                            </h5>
                            <div class="small text-muted">
                                <p class="mb-1">
                                    <strong>Submitted On:</strong>
                                    <%= new Date(application.createdAt).toDateString() %>
                                </p>
                                <p class="mb-1">
                                    <strong>Mode of Study:</strong>
                                    <span class="badge bg-primary">
                                        <%= application.modeOfStudy || "Full Time" %>
                                    </span>
                                </p>
                                <p class="mb-0">
                                    <strong>Level:</strong>
                                    <%= application.firstChoice?.level || "N/A" %>
                                </p>
                            </div>
                        </div>

                        <!-- Documents -->
                        <div class="mb-4">
                            <h5 class="fw-bold text-secondary mb-3">
                                <i class="fas fa-file-alt me-2"></i> Documents
                            </h5>
                            <ul class="list-group small">
                                <% application.documents.forEach(doc=> { %>
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>
                                            <i class="fas fa-paperclip me-2 text-muted"></i>
                                            <%= doc.name %>
                                        </span>
                                        <a href="<%= doc.signedUrl %>" target="_blank"
                                            class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    </li>
                                    <% }) %>
                            </ul>
                        </div>

                        <!-- Receipt -->
                        <!-- Receipt Section - Updated for payment.receipt -->
                        <div class="mb-4">
                            <h5 class="fw-bold text-success mb-3">
                                <i class="fas fa-receipt me-2"></i> Payment Receipt
                            </h5>

                            <% if (application.payment && application.payment.receipt?.gcsPath) { %>
                                <div class="alert alert-success d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fas fa-check-circle me-2"></i>
                                        Receipt Available
                                        <br />
                                        <small class="text-muted">
                                            Payment Status: <%= application.payment.status %>
                                                <br />
                                                Issued on:
                                                <%= application.payment.receipt.issuedAt ? new
                                                    Date(application.payment.receipt.issuedAt).toLocaleDateString()
                                                    : 'N/A' %>
                                        </small>
                                    </div>

                                    <a href="/applications/<%= application._id %>/receipt" target="_blank"
                                        class="btn btn-success btn-sm">
                                        <i class="fas fa-download me-1"></i> View Receipt
                                    </a>
                                </div>
                                <% } else if (application.payment) { %>
                                    <div class="alert alert-warning">
                                        <i class="fas fa-clock me-2"></i>
                                        Payment Status: <strong>
                                            <%= application.payment.status %>
                                        </strong>
                                        <% if (application.payment.status==='Pending' ) { %>
                                            <br /><small>Waiting for finance verification</small>
                                            <% } %>
                                    </div>
                                    <% } else { %>
                                        <div class="alert alert-secondary">
                                            <i class="fas fa-clock me-2"></i>
                                            No payment record found
                                        </div>
                                        <% } %>
                        </div>

                        <!-- Acceptance Letter -->
                        <div class="mb-4">
                            <h5 class="fw-bold text-warning mb-3">
                                <i class="fas fa-award me-2"></i> Acceptance Letter
                            </h5>

                            <% if (application.acceptanceLetter?.gcsPath) { %>
                                <div class="alert alert-success d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="fas fa-check-circle me-2"></i>
                                        <strong>
                                            <%= application.acceptanceLetter.name %>
                                        </strong>
                                        <br />
                                        <small class="text-muted">
                                            Uploaded on:
                                            <%= application.acceptanceLetter.uploadedAt.toDateString() %>
                                        </small>
                                    </div>

                                    <a href="/applications/<%= application._id %>/letter" target="_blank"
                                        class="btn btn-success btn-sm">
                                        <i class="fas fa-download me-1"></i> View Letter
                                    </a>
                                </div>
                                <% } else { %>
                                    <div class="alert alert-secondary">
                                        <i class="fas fa-clock me-2"></i>
                                        Not available yet
                                    </div>
                                    <% } %>
                        </div>

                        <!-- Back -->
                        <div class="d-grid gap-2">
                            <a href="/applications/my" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-1"></i> Back to My Applications
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <%- include('../partials/footer') %>