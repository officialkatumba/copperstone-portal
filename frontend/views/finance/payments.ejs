<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-4">

            <!-- PAGE HEADING -->
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="color: var(--primary-purple)">All Payments</h2>
                <p class="text-muted">View, verify and reprint student payments</p>
            </div>

            <!-- SUMMARY CARDS -->
            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <small class="text-muted">Today</small>
                            <h5 class="fw-bold">ZMW <%= Number(totalToday || 0).toLocaleString() %>
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <small class="text-muted">This Month</small>
                            <h5 class="fw-bold">ZMW <%= Number(totalMonth || 0).toLocaleString() %>
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <small class="text-muted">This Year</small>
                            <h5 class="fw-bold">ZMW <%= Number(totalYear || 0).toLocaleString() %>
                            </h5>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm text-center">
                        <div class="card-body">
                            <small class="text-muted">All Time</small>
                            <h5 class="fw-bold">ZMW <%= Number(totalAll || 0).toLocaleString() %>
                            </h5>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FILTERS -->
            <form method="GET" class="row g-2 mb-3">
                <div class="col-md-3">
                    <input type="text" name="search" class="form-control"
                        placeholder="Search by firstname,sirname or email" value="<%= search || '' %>">
                </div>

                <div class="col-md-2">
                    <select name="category" class="form-select">
                        <option value="">All Categories</option>
                        <% [ "Application Fee" , "Registration Fee" , "Tuition Fee (Per Semester)" , "Exam Fee"
                            , "Graduation Fee" , "Other" ].forEach(function(c){ %>
                            <option value="<%= c %>" <%=category===c ? 'selected' : '' %>>
                                <%= c %>
                            </option>
                            <% }) %>
                    </select>
                </div>

                <!-- Items per page filter -->
                <div class="col-md-2">
                    <select name="limit" class="form-select" onchange="this.form.submit()">
                        <option value="20" <%=limit===20 ? 'selected' : '' %>>20 per page</option>
                        <option value="50" <%=limit===50 ? 'selected' : '' %>>50 per page</option>
                        <option value="100" <%=limit===100 ? 'selected' : '' %>>100 per page</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <button class="btn btn-primary w-100">Filter</button>
                </div>

                <div class="col-md-2">
                    <a href="/finance/payments" class="btn btn-outline-secondary w-100">Reset</a>
                </div>
            </form>

            <!-- PAYMENTS TABLE -->
            <div class="card shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Student</th>
                                <th>Category</th>
                                <th>Paid</th>
                                <th>Balance</th>
                                <th>Method</th>
                                <th>Status</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>

                            <% if (!payments || payments.length===0) { %>
                                <tr>
                                    <td colspan="9" class="text-center text-muted py-4">
                                        No payments found
                                    </td>
                                </tr>
                                <% } %>

                                    <% payments.forEach(function(p, index){ %>
                                        <tr>
                                            <td>
                                                <%= (currentPage - 1) * limit + index + 1 %>
                                            </td>

                                            <td>
                                                <strong>
                                                    <%= p.student ? p.student.firstName + ' ' + p.student.surname
                                                        : 'N/A' %>
                                                </strong><br>
                                                <small class="text-muted">
                                                    <%= p.student ? p.student.email : '' %>
                                                </small>
                                            </td>

                                            <td>
                                                <%= p.category %>
                                            </td>

                                            <td class="fw-bold text-primary">
                                                ZMW <%= Number(p.amount || 0).toFixed(2) %>
                                            </td>

                                            <td>
                                                <% if ((p.balanceAfterPayment || 0)> 0) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        ZMW <%= Number(p.balanceAfterPayment).toFixed(2) %>
                                                    </span>
                                                    <% } else { %>
                                                        <span class="badge bg-success">Paid</span>
                                                        <% } %>
                                            </td>

                                            <td>
                                                <%= p.method %>
                                            </td>

                                            <td>
                                                <span class="badge 
        <%= p.status === 'Pending' ? 'bg-warning text-dark' : 
            p.status === 'Cancelled' ? 'bg-danger text-white' : 
            p.status === 'Rejected' ? 'bg-danger text-white' : 
            p.status === 'Partially Paid' ? 'bg-warning text-dark' : 
            'bg-success' %>">
                                                    <%= p.status %>
                                                </span>
                                            </td>

                                            <td>
                                                <small>
                                                    <%= new Date(p.createdAt).toLocaleDateString() %>
                                                </small><br>
                                                <small class="text-muted">
                                                    <%= new Date(p.createdAt).toLocaleTimeString([], { hour: '2-digit' ,
                                                        minute: '2-digit' }) %>
                                                </small>
                                            </td>

                                            <td>
                                                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= p._id %>">
                                                    View
                                                </button>
                                            </td>
                                        </tr>
                                        <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- FOOTER COUNT -->
            <div class="text-muted mt-2">
                Showing <strong>
                    <%= payments.length %>
                </strong> of
                <strong>
                    <%= totalCount %>
                </strong> payments
            </div>

            <!-- PAGINATION -->
            <% if (totalPages> 1) { %>
                <nav class="mt-3">
                    <ul class="pagination justify-content-center">
                        <% const startPage=Math.max(1, currentPage - 2); const endPage=Math.min(totalPages, currentPage
                            + 2); %>

                            <ul class="pagination justify-content-center">
                                <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link"
                                        href="?page=<%= currentPage-1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                        Previous
                                    </a>
                                </li>

                                <% if (startPage> 1) { %>
                                    <li class="page-item">
                                        <a class="page-link" href="?page=1&limit=<%= limit %>">1</a>
                                    </li>
                                    <% if (startPage> 2) { %>
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                        <% } %>
                                            <% } %>

                                                <% for(let i=startPage;i<=endPage;i++){ %>
                                                    <li class="page-item <%= i===currentPage?'active':'' %>">
                                                        <a class="page-link"
                                                            href="?page=<%= i %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                                            <%= i %>
                                                        </a>
                                                    </li>
                                                    <% } %>

                                                        <% if (endPage < totalPages) { %>
                                                            <% if (endPage < totalPages - 1) { %>
                                                                <li class="page-item disabled"><span
                                                                        class="page-link">…</span>
                                                                </li>
                                                                <% } %>
                                                                    <li class="page-item">
                                                                        <a class="page-link"
                                                                            href="?page=<%= totalPages %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                                                            <%= totalPages %>
                                                                        </a>
                                                                    </li>
                                                                    <% } %>

                                                                        <li
                                                                            class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                                                            <a class="page-link"
                                                                                href="?page=<%= currentPage+1 %>&limit=<%= limit %>&search=<%= search %>&category=<%= category %>">
                                                                                Next
                                                                            </a>
                                                                        </li>
                            </ul>

                    </ul>
                </nav>
                <% } %>

        </div>

        <!-- Payment Modals for each payment -->
        <% payments.forEach(function(payment){ %>
            <!-- Payment Modal - Keep original design, add new fields -->
            <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title fw-bold">Payment Details</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <!-- Student Info -->
                            <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                                <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                    style="width:50px;height:50px;">
                                    <i class="fas fa-user-graduate text-primary"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0">
                                        <%= payment.student.firstName %>
                                            <%= payment.student.surname %>
                                    </h6>
                                    <p class="text-muted mb-0">
                                        <%= payment.student.email %>
                                    </p>
                                </div>
                            </div>

                            <!-- Payment Details - Add new fields here -->
                            <div class="row mb-3">
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Payment ID</small>
                                    <small class="text-muted">
                                        <%= payment._id %>
                                    </small>
                                </div>
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Category</small>
                                    <span class="fw-bold">
                                        <%= payment.category %>
                                    </span>
                                </div>
                                <div class="col-12 mb-2">
                                    <small class="text-muted d-block">Description</small>
                                    <span>
                                        <%= payment.description %>
                                    </span>
                                </div>

                                <!-- ADDED: Total Due -->
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Total Due</small>
                                    <span class="fw-bold text-success">ZMW <%= payment.totalDue ?
                                            payment.totalDue.toFixed(2) : '0.00' %></span>
                                </div>

                                <!-- KEEP: Amount -->
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Amount Paid</small>
                                    <span class="fw-bold text-primary">ZMW <%= payment.amount.toFixed(2) %></span>
                                </div>

                                <!-- ADDED: Balance Remaining -->
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Balance Remaining</small>
                                    <span class="fw-bold text-warning">ZMW <%= payment.balanceAfterPayment ?
                                            payment.balanceAfterPayment.toFixed(2) : '0.00' %>
                                    </span>
                                </div>

                                <!-- KEEP: Method -->
                                <div class="col-6 mb-2">
                                    <small class="text-muted d-block">Method</small>
                                    <span>
                                        <%= payment.method %>
                                    </span>
                                </div>

                                <% if(payment.semester){ %>
                                    <div class="col-6 mb-2">
                                        <small class="text-muted d-block">Semester</small>
                                        <span>Semester <%= payment.semester %></span>
                                    </div>
                                    <% } %>
                                        <% if(payment.academicYear){ %>
                                            <div class="col-6 mb-2">
                                                <small class="text-muted d-block">Academic
                                                    Year</small>
                                                <span>
                                                    <%= payment.academicYear %>
                                                </span>
                                            </div>
                                            <% } %>
                                                <div class="col-6 mb-2">
                                                    <small class="text-muted d-block">Status</small>
                                                    <% if(payment.status==='Verified' || payment.status==='Fully Paid'
                                                        ){ %>
                                                        <span class="badge bg-success">
                                                            <%= payment.status %>
                                                        </span>
                                                        <% } else if(payment.status==='Partially Paid' ){ %>
                                                            <span class="badge bg-warning text-dark">
                                                                <%= payment.status %>
                                                            </span>
                                                            <% } else if(payment.status==='Pending' ){ %>
                                                                <span class="badge bg-warning text-dark">Pending</span>
                                                                <% } else if(payment.status==='Cancelled' ){ %>
                                                                    <span class="badge bg-secondary">Cancelled</span>
                                                                    <% } else if(payment.status==='Rejected' ){ %>
                                                                        <span class="badge bg-danger">Rejected</span>
                                                                        <% } else { %>
                                                                            <span class="badge bg-secondary">
                                                                                <%= payment.status %>
                                                                            </span>
                                                                            <% } %>
                                                </div>
                            </div>

                            <!-- Receipt and Proof of Payment Section -->
                            <div class="border-top pt-3 mb-3">
                                <!-- Receipt - Only show for verified/paid payments -->
                                <% if((payment.status==='Verified' || payment.status==='Fully Paid' ||
                                    payment.status==='Partially Paid' ) && (payment.receipt &&
                                    payment.receipt.gcsPath)){ %>
                                    <div class="mb-2">
                                        <small class="text-muted d-block mb-1">Payment
                                            Receipt</small>
                                        <a href="/finance/payments/<%= payment._id %>/receipt" target="_blank"
                                            class="btn btn-sm btn-success d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm"
                                            style="border-radius:20px;">
                                            <i class="fas fa-file-pdf"></i>
                                            <span class="fw-semibold">View Receipt</span>
                                        </a>
                                        <!-- Cancel Receipt Button - Only show if receipt exists and payment is verified -->
                                        <% if(payment.receipt && payment.receipt.gcsPath && (payment.status==='Verified'
                                            || payment.status==='Fully Paid' || payment.status==='Partially Paid' )){ %>
                                            <button type="button"
                                                class="btn btn-sm btn-danger d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm"
                                                style="border-radius:20px;" data-bs-toggle="modal"
                                                data-bs-target="#cancelReceiptModal<%= payment._id %>">
                                                <i class="fas fa-ban"></i>
                                                <span class="fw-semibold">Cancel Receipt</span>
                                            </button>
                                            <% } %>
                                    </div>
                                    <% } %>

                                        <!-- Proof of Payment Upload -->
                                        <% if(payment.proofOfPayment && (payment.proofOfPayment.gcsPath ||
                                            payment.proofOfPayment.gcsUrl)){ %>
                                            <div class="mb-2">
                                                <small class="text-muted d-block mb-1">Proof of
                                                    Payment</small>
                                                <a href="/finance/payments/<%= payment._id %>/proof" target="_blank"
                                                    class="btn btn-sm btn-primary d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm"
                                                    style="border-radius:20px;">
                                                    <i class="fas fa-file-upload"></i>
                                                    <span class="fw-semibold">View Uploaded
                                                        Proof</span>
                                                </a>
                                                <% if(payment.proofOfPayment.name){ %>
                                                    <small class="text-muted d-block mt-1">
                                                        <i class="fas fa-file me-1"></i>
                                                        <%= payment.proofOfPayment.name %>
                                                    </small>
                                                    <% } %>
                                            </div>
                                            <% } %>
                            </div>

                            <!-- Dates -->
                            <div class="small text-muted pt-3 border-top">
                                <div class="d-flex justify-content-between">
                                    <span>Created: <%= payment.createdAt.toLocaleString() %>
                                    </span>
                                    <% if(payment.verifiedAt){ %>
                                        <span>Verified: <%= payment.verifiedAt.toLocaleDateString() %>
                                        </span>
                                        <% } %>
                                </div>
                            </div>
                        </div>

                        <!-- Verify Payment Section - Only show for Pending payments -->
                        <% if(payment.status==='Pending' ) { %>
                            <div class="border-top pt-3 px-3">
                                <h6 class="fw-bold mb-3" style="color: var(--primary-purple)">
                                    Verify Payment</h6>

                                <form action="/finance/payments/<%= payment._id %>/verify" method="POST"
                                    class="needs-validation" novalidate>
                                    <div class="row g-3">
                                        <!-- Select Action -->
                                        <div class="col-12">
                                            <label for="verifyAction<%= payment._id %>"
                                                class="form-label small fw-semibold">Select
                                                Action</label>
                                            <select class="form-select form-select-sm"
                                                id="verifyAction<%= payment._id %>" name="action" required>
                                                <option value="" disabled selected>Choose
                                                    action...</option>
                                                <option value="Verified">Verify Payment</option>
                                                <option value="Rejected">Reject Payment</option>
                                                <% if(payment.balanceAfterPayment && payment.balanceAfterPayment> 0){ %>
                                                    <option value="partial">Mark as Partially
                                                        Paid</option>
                                                    <% } %>
                                            </select>
                                            <div class="invalid-feedback">
                                                Please select an action.
                                            </div>
                                        </div>

                                        <!-- Remarks Input -->
                                        <div class="col-12">
                                            <label for="verifyRemarks<%= payment._id %>"
                                                class="form-label small fw-semibold">Add remarks
                                                (optional)</label>
                                            <textarea class="form-control form-control-sm"
                                                id="verifyRemarks<%= payment._id %>" name="remarks" rows="3"
                                                placeholder="Add any notes or remarks regarding this verification..."></textarea>
                                            <div class="form-text">Remarks will be recorded in
                                                payment history.</div>
                                        </div>

                                        <!-- Submit Button -->
                                        <div class="col-12 mt-2">
                                            <button type="submit" class="btn btn-sm w-100"
                                                style="background-color: var(--primary-purple); color: white;">
                                                <i class="fas fa-check-circle me-1"></i> Submit
                                                Verification
                                            </button>
                                        </div>
                                    </div>
                                </form>
                            </div>
                            <% } %>

                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary"
                                        data-bs-dismiss="modal">Close</button>
                                    <!-- Print button - only show for verified payments with receipt -->
                                    <% if((payment.status==='Verified' || payment.status==='Fully Paid' ||
                                        payment.status==='Partially Paid' ) && payment.receipt &&
                                        payment.receipt.gcsUrl){ %>
                                        <a href="<%= payment.receipt.gcsUrl %>" target="_blank" class="btn btn-primary">
                                            <i class="fas fa-print me-1"></i> Print
                                        </a>
                                        <% } %>
                                </div>
                    </div>
                </div>
            </div>

            <!-- Cancel Receipt Modal -->
            <div class="modal fade" id="cancelReceiptModal<%= payment._id %>" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title fw-bold text-danger">Cancel Receipt</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <form action="/finance/payments/<%= payment._id %>/cancel-receipt" method="POST">
                            <div class="modal-body">
                                <div class="alert alert-warning">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <strong>Warning:</strong> This action cannot be undone.
                                </div>

                                <p>Are you sure you want to cancel this receipt? This will:</p>
                                <ul class="mb-3">
                                    <li>Remove the receipt from this payment</li>
                                    <li>Change payment status to "Cancelled"</li>
                                    <li>Require the student to make a new payment</li>
                                </ul>

                                <div class="mb-3">
                                    <label for="cancelReason<%= payment._id %>" class="form-label small fw-semibold">
                                        Reason for cancellation (required)
                                    </label>
                                    <textarea class="form-control" id="cancelReason<%= payment._id %>"
                                        name="cancelReason" rows="3" required
                                        placeholder="Enter reason for cancelling this receipt..."></textarea>
                                    <div class="form-text">This reason will be recorded in the payment history.</div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-ban me-1"></i> Cancel Receipt
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <% }) %>

                <%- include('../partials/footer') %>