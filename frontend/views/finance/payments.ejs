<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="color: var(--primary-purple)">All Payments</h2>
                <p class="text-muted">View and manage all student payment records.</p>
            </div>

            <!-- Summary Cards (keep as is) -->
            <div class="row mb-4">
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar-day fa-2x mb-3 text-primary"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalToday.toFixed(2) %>
                            </h5>
                            <small class="text-muted">Total Today (<%= today %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar-alt fa-2x mb-3 text-success"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalMonth.toFixed(2) %>
                            </h5>
                            <small class="text-muted">This Month (<%= monthRange %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-calendar fa-2x mb-3 text-warning"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalYear.toFixed(2) %>
                            </h5>
                            <small class="text-muted">This Year (<%= yearRange %>)</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-3 mb-3">
                    <div class="card border-0 shadow-sm h-100">
                        <div class="card-body text-center">
                            <i class="fas fa-wallet fa-2x mb-3 text-secondary"></i>
                            <h5 class="fw-bold mb-0">ZMW <%= totalAll.toFixed(2) %>
                            </h5>
                            <small class="text-muted">Total Payments</small>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Search and Limit -->
            <form class="row mb-4 g-2" method="get" action="/finance/payments">
                <div class="col-md-4">
                    <input type="text" class="form-control" name="search" placeholder="Search payments..."
                        value="<%= search %>">
                </div>
                <div class="col-md-2">
                    <select class="form-select" name="limit">
                        <% [5,10,20,50,100].forEach(n=> { %>
                            <option value="<%= n %>" <%=n===limit ? 'selected' : '' %>><%= n %> per page</option>
                            <% }) %>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Search</button>
                </div>
                <div class="col-md-2">
                    <a href="/finance/payments" class="btn btn-secondary w-100">Reset</a>
                </div>
            </form>

            <% if (payments.length===0) { %>
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle me-2"></i>No payments found yet.
                </div>
                <% } else { %>
                    <div class="table-responsive shadow-sm rounded-3">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Student</th>
                                    <th>Category</th>
                                    <th>Amount</th>
                                    <th>Balance</th>
                                    <th>Method</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% payments.forEach((payment, index)=> { %>
                                    <tr>
                                        <td>
                                            <%= (currentPage - 1) * limit + index + 1 %>
                                        </td>
                                        <td>
                                            <strong>
                                                <%= payment.student.firstName %>
                                                    <%= payment.student.surname %>
                                            </strong><br>
                                            <small class="text-muted">
                                                <%= payment.student.email %>
                                            </small>
                                        </td>
                                        <td>
                                            <%= payment.category %>
                                        </td>
                                        <td><strong style="color: var(--primary-purple)">ZMW <%=
                                                    payment.amount.toFixed(2) %></strong></td>
                                        <td>
                                            <% if (payment.balanceAfterPayment && payment.balanceAfterPayment> 0) { %>
                                                <span class="badge bg-warning text-dark">ZMW <%=
                                                        payment.balanceAfterPayment.toFixed(2) %></span>
                                                <% } else if (payment.balanceAfterPayment===0) { %>
                                                    <span class="badge bg-success">Paid in Full</span>
                                                    <% } else { %>
                                                        <span class="badge bg-secondary">N/A</span>
                                                        <% } %>
                                        </td>
                                        <td>
                                            <%= payment.method %>
                                        </td>
                                        <td>
                                            <% if(payment.status==='Verified' || payment.status==='Fully Paid' ){ %>
                                                <span class="badge bg-success">
                                                    <%= payment.status %>
                                                </span>
                                                <% } else if(payment.status==='Partially Paid' ){ %>
                                                    <span class="badge bg-warning text-dark">
                                                        <%= payment.status %>
                                                    </span>
                                                    <% } else if(payment.status==='Pending' ){ %>
                                                        <span class="badge bg-warning text-dark">Pending</span>
                                                        <% } else if(payment.status==='Cancelled' ){ %>
                                                            <span class="badge bg-danger">Cancelled</span>
                                                            <% } else { %>
                                                                <span class="badge bg-secondary">
                                                                    <%= payment.status %>
                                                                </span>
                                                                <% } %>
                                        </td>
                                        <td>
                                            <small>
                                                <%= payment.createdAt.toLocaleDateString() %>
                                            </small><br>
                                            <small class="text-muted">
                                                <%= payment.createdAt.toLocaleTimeString([],
                                                    {hour:'2-digit',minute:'2-digit'}) %>
                                            </small>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" data-bs-toggle="modal"
                                                    data-bs-target="#paymentModal<%= payment._id %>">
                                                    <i class="fas fa-eye me-1"></i> View
                                                </button>
                                                <% if(payment.receipt?.gcsUrl){ %>
                                                    <a href="<%= payment.receipt.gcsUrl %>" target="_blank"
                                                        class="btn btn-outline-success">
                                                        <i class="fas fa-receipt"></i>
                                                    </a>
                                                    <% } %>
                                            </div>
                                        </td>
                                    </tr>

                                    <!-- Payment Modal - Keep original design, add new fields -->
                                    <div class="modal fade" id="paymentModal<%= payment._id %>" tabindex="-1">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content">
                                                <div class="modal-header">
                                                    <h5 class="modal-title fw-bold">Payment Details</h5>
                                                    <button type="button" class="btn-close"
                                                        data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body">
                                                    <!-- Student Info -->
                                                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                                                        <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center me-3"
                                                            style="width:50px;height:50px;">
                                                            <i class="fas fa-user-graduate text-primary"></i>
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0">
                                                                <%= payment.student.firstName %>
                                                                    <%= payment.student.surname %>
                                                            </h6>
                                                            <p class="text-muted mb-0">
                                                                <%= payment.student.email %>
                                                            </p>
                                                        </div>
                                                    </div>

                                                    <!-- Payment Details - Add new fields here -->
                                                    <div class="row mb-3">
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Payment ID</small>
                                                            <small class="text-muted">
                                                                <%= payment._id %>
                                                            </small>
                                                        </div>
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Category</small>
                                                            <span class="fw-bold">
                                                                <%= payment.category %>
                                                            </span>
                                                        </div>
                                                        <div class="col-12 mb-2">
                                                            <small class="text-muted d-block">Description</small>
                                                            <span>
                                                                <%= payment.description %>
                                                            </span>
                                                        </div>

                                                        <!-- ADDED: Total Due -->
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Total Due</small>
                                                            <span class="fw-bold text-success">ZMW <%= payment.totalDue
                                                                    ? payment.totalDue.toFixed(2) : '0.00' %></span>
                                                        </div>

                                                        <!-- KEEP: Amount -->
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Amount Paid</small>
                                                            <span class="fw-bold text-primary">ZMW <%=
                                                                    payment.amount.toFixed(2) %></span>
                                                        </div>

                                                        <!-- ADDED: Balance Remaining -->
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Balance Remaining</small>
                                                            <span class="fw-bold text-warning">ZMW <%=
                                                                    payment.balanceAfterPayment ?
                                                                    payment.balanceAfterPayment.toFixed(2) : '0.00' %>
                                                            </span>
                                                        </div>

                                                        <!-- KEEP: Method -->
                                                        <div class="col-6 mb-2">
                                                            <small class="text-muted d-block">Method</small>
                                                            <span>
                                                                <%= payment.method %>
                                                            </span>
                                                        </div>

                                                        <% if(payment.semester){ %>
                                                            <div class="col-6 mb-2">
                                                                <small class="text-muted d-block">Semester</small>
                                                                <span>Semester <%= payment.semester %></span>
                                                            </div>
                                                            <% } %>
                                                                <% if(payment.academicYear){ %>
                                                                    <div class="col-6 mb-2">
                                                                        <small class="text-muted d-block">Academic
                                                                            Year</small>
                                                                        <span>
                                                                            <%= payment.academicYear %>
                                                                        </span>
                                                                    </div>
                                                                    <% } %>
                                                                        <div class="col-6 mb-2">
                                                                            <small
                                                                                class="text-muted d-block">Status</small>
                                                                            <% if(payment.status==='Verified' ||
                                                                                payment.status==='Fully Paid' ){ %>
                                                                                <span class="badge bg-success">
                                                                                    <%= payment.status %>
                                                                                </span>
                                                                                <% } else
                                                                                    if(payment.status==='Partially Paid'
                                                                                    ){ %>
                                                                                    <span
                                                                                        class="badge bg-warning text-dark">
                                                                                        <%= payment.status %>
                                                                                    </span>
                                                                                    <% } else
                                                                                        if(payment.status==='Pending' ){
                                                                                        %>
                                                                                        <span
                                                                                            class="badge bg-warning text-dark">Pending</span>
                                                                                        <% } else { %>
                                                                                            <span
                                                                                                class="badge bg-secondary">
                                                                                                <%= payment.status %>
                                                                                            </span>
                                                                                            <% } %>
                                                                        </div>
                                                    </div>

                                                    <!-- Receipt and Proof of Payment Section -->
                                                    <div class="border-top pt-3 mb-3">
                                                        <!-- Receipt - Only show for verified/paid payments -->
                                                        <% if((payment.status==='Verified' ||
                                                            payment.status==='Fully Paid' ||
                                                            payment.status==='Partially Paid' ) && (payment.receipt &&
                                                            payment.receipt.gcsPath)){ %>
                                                            <div class="mb-2">
                                                                <small class="text-muted d-block mb-1">Payment
                                                                    Receipt</small>
                                                                <a href="/finance/payments/<%= payment._id %>/receipt"
                                                                    target="_blank"
                                                                    class="btn btn-sm btn-success d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm"
                                                                    style="border-radius:20px;">
                                                                    <i class="fas fa-file-pdf"></i>
                                                                    <span class="fw-semibold">View Receipt</span>
                                                                </a>
                                                            </div>
                                                            <% } %>

                                                                <!-- Proof of Payment Upload -->
                                                                <% if(payment.proofOfPayment &&
                                                                    (payment.proofOfPayment.gcsPath ||
                                                                    payment.proofOfPayment.gcsUrl)){ %>
                                                                    <div class="mb-2">
                                                                        <small class="text-muted d-block mb-1">Proof of
                                                                            Payment</small>
                                                                        <a href="/finance/payments/<%= payment._id %>/proof"
                                                                            target="_blank"
                                                                            class="btn btn-sm btn-primary d-inline-flex align-items-center gap-2 px-3 py-2 shadow-sm"
                                                                            style="border-radius:20px;">
                                                                            <i class="fas fa-file-upload"></i>
                                                                            <span class="fw-semibold">View Uploaded
                                                                                Proof</span>
                                                                        </a>
                                                                        <% if(payment.proofOfPayment.name){ %>
                                                                            <small class="text-muted d-block mt-1">
                                                                                <i class="fas fa-file me-1"></i>
                                                                                <%= payment.proofOfPayment.name %>
                                                                            </small>
                                                                            <% } %>
                                                                    </div>
                                                                    <% } %>
                                                    </div>

                                                    <!-- Dates -->
                                                    <div class="small text-muted pt-3 border-top">
                                                        <div class="d-flex justify-content-between">
                                                            <span>Created: <%= payment.createdAt.toLocaleString() %>
                                                            </span>
                                                            <% if(payment.verifiedAt){ %>
                                                                <span>Verified: <%=
                                                                        payment.verifiedAt.toLocaleDateString() %>
                                                                </span>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- Verify Payment Section - Only show for Pending payments -->
                                                <% if(payment.status==='Pending' ) { %>
                                                    <div class="border-top pt-3 px-3">
                                                        <h6 class="fw-bold mb-3" style="color: var(--primary-purple)">
                                                            Verify Payment</h6>

                                                        <form action="/finance/payments/<%= payment._id %>/verify"
                                                            method="POST" class="needs-validation" novalidate>
                                                            <div class="row g-3">
                                                                <!-- Select Action -->
                                                                <div class="col-12">
                                                                    <label for="verifyAction<%= payment._id %>"
                                                                        class="form-label small fw-semibold">Select
                                                                        Action</label>
                                                                    <select class="form-select form-select-sm"
                                                                        id="verifyAction<%= payment._id %>"
                                                                        name="action" required>
                                                                        <option value="" disabled selected>Choose
                                                                            action...</option>
                                                                        <option value="Verified">Verify Payment</option>
                                                                        <option value="Rejected">Reject Payment</option>
                                                                        <% if(payment.balanceAfterPayment &&
                                                                            payment.balanceAfterPayment> 0){ %>
                                                                            <option value="partial">Mark as Partially
                                                                                Paid</option>
                                                                            <% } %>
                                                                    </select>
                                                                    <div class="invalid-feedback">
                                                                        Please select an action.
                                                                    </div>
                                                                </div>

                                                                <!-- Remarks Input -->
                                                                <div class="col-12">
                                                                    <label for="verifyRemarks<%= payment._id %>"
                                                                        class="form-label small fw-semibold">Add remarks
                                                                        (optional)</label>
                                                                    <textarea class="form-control form-control-sm"
                                                                        id="verifyRemarks<%= payment._id %>"
                                                                        name="remarks" rows="3"
                                                                        placeholder="Add any notes or remarks regarding this verification..."></textarea>
                                                                    <div class="form-text">Remarks will be recorded in
                                                                        payment history.</div>
                                                                </div>

                                                                <!-- Submit Button -->
                                                                <div class="col-12 mt-2">
                                                                    <button type="submit" class="btn btn-sm w-100"
                                                                        style="background-color: var(--primary-purple); color: white;">
                                                                        <i class="fas fa-check-circle me-1"></i> Submit
                                                                        Verification
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </form>
                                                    </div>
                                                    <% } %>

                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary"
                                                                data-bs-dismiss="modal">Close</button>
                                                            <!-- Print button - only show for verified payments with receipt -->
                                                            <% if((payment.status==='Verified' ||
                                                                payment.status==='Fully Paid' ||
                                                                payment.status==='Partially Paid' ) && payment.receipt
                                                                && payment.receipt.gcsUrl){ %>
                                                                <a href="<%= payment.receipt.gcsUrl %>" target="_blank"
                                                                    class="btn btn-primary">
                                                                    <i class="fas fa-print me-1"></i> Print
                                                                </a>
                                                                <% } %>
                                                        </div>
                                            </div>
                                        </div>
                                    </div>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <nav aria-label="Page navigation" class="mt-3">
                        <ul class="pagination justify-content-center">
                            <% for(let i=1;i<=totalPages;i++){ %>
                                <li class="page-item <%= i===currentPage?'active':'' %>">
                                    <a class="page-link" href="?page=<%= i %>&limit=<%= limit %>&search=<%= search %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>
                        </ul>
                    </nav>
                    <% } %>
        </div>

        <%- include('../partials/footer') %>