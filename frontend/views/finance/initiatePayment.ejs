<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-4">
            <div class="card shadow-lg p-4 mx-auto" style="max-width: 600px">
                <div class="text-center mb-4">
                    <div class="mb-3">
                        <i class="fas fa-credit-card fa-3x text-primary"></i>
                    </div>
                    <h4 class="fw-bold">Initiate Payment</h4>
                    <p class="text-muted">
                        <i class="fas fa-info-circle me-1"></i>
                        Create a new payment record for a student
                    </p>
                </div>

                <form action="/finance/payments" method="POST" id="paymentForm" enctype="multipart/form-data">

                    <input type="hidden" name="source" value="finance">
                    <!-- Searchable Student Dropdown -->
                    <div class="mb-3">
                        <label class="fw-semibold">Student</label>
                        <div class="position-relative">
                            <input type="text" id="studentSearch" class="form-control"
                                placeholder="Start typing student name or email..." autocomplete="off">
                            <input type="hidden" name="student" id="selectedStudentId" required>
                            <div id="studentDropdown" class="dropdown-menu w-100"
                                style="display: none; max-height: 250px; overflow-y: auto;">
                                <!-- Search results will appear here -->
                            </div>
                        </div>
                        <div id="selectedStudentInfo" class="mt-2 p-2 border rounded bg-light" style="display: none;">
                            <small class="text-muted">Selected:</small>
                            <span id="selectedStudentText" class="fw-semibold ms-2"></span>
                            <button type="button" id="clearSelection"
                                class="btn btn-sm btn-outline-danger float-end">×</button>
                        </div>
                        <div class="form-text">
                            Search by name (e.g., "samuel") or email
                        </div>
                    </div>

                    <!-- Category with Fee Suggestions -->
                    <div class="mb-3">
                        <label class="fw-semibold">Category</label>
                        <select name="category" id="category" class="form-select" required
                            onchange="updateFeeSuggestion()">
                            <option value="">Select Category</option>
                            <% [ {name: "Application Fee" , typicalAmount: 50}, {name: "Registration Fee" ,
                                typicalAmount: 100}, {name: "Semester Registration Fee" , typicalAmount: 500},
                                {name: "Tuition Fee (Semester)" , typicalAmount: 5000}, {name: "Tuition Fee (Full Year)"
                                , typicalAmount: 10000}, {name: "Exam Fee" , typicalAmount: 200},
                                {name: "Student Management Fee" , typicalAmount: 300}, {name: "Medical Fee" ,
                                typicalAmount: 150}, {name: "Library Fee" , typicalAmount: 100}, {name: "Internet Fee" ,
                                typicalAmount: 200}, {name: "Maintenance Fee" , typicalAmount: 250},
                                {name: "Distance Learning Logistics Fee" , typicalAmount: 500}, {name: "Research Fee" ,
                                typicalAmount: 1000}, {name: "Graduation Fee" , typicalAmount: 800}, {name: "Boarding" ,
                                typicalAmount: 1200}, {name: "Penalty" , typicalAmount: 100}, {name: "Other" ,
                                typicalAmount: 0} ].forEach(c=> { %>
                                <option value="<%= c.name %>" data-typical="<%= c.typicalAmount %>">
                                    <%= c.name %>
                                        <% if (c.typicalAmount> 0) { %>(Typically: ZMW <%= c.typicalAmount %>)<% } %>
                                </option>
                                <% }) %>
                        </select>
                        <div id="feeSuggestion" class="form-text" style="display: none;"></div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-semibold">Description</label>
                        <input type="text" name="description" class="form-control" required />
                    </div>

                    <!-- Total Amount Due (Manual Input) -->
                    <div class="mb-3">
                        <label class="fw-semibold">Total Amount Due (ZMW)</label>
                        <div class="input-group">
                            <span class="input-group-text">ZMW</span>
                            <input type="number" name="totalDue" id="totalDue" step="0.01" min="0" class="form-control"
                                required oninput="calculateBalance()" />
                            <button type="button" class="btn btn-outline-secondary" onclick="useTypicalFee()">
                                Use Typical
                            </button>
                        </div>
                        <div class="form-text">
                            Enter the total amount required for this fee category
                        </div>
                    </div>

                    <!-- Payment Amount Being Made Now -->
                    <div class="mb-3">
                        <label class="fw-semibold">Payment Amount (ZMW)</label>
                        <div class="input-group">
                            <span class="input-group-text">ZMW</span>
                            <input type="number" name="amount" id="paymentAmount" step="0.01" min="0"
                                class="form-control" required oninput="calculateBalance()" />
                            <button type="button" class="btn btn-outline-secondary" onclick="payFullAmount()">
                                Pay Full Amount
                            </button>
                        </div>
                        <div class="form-text">
                            Enter the payment amount being made now
                        </div>
                    </div>

                    <!-- Balance After Payment (Calculated automatically) -->
                    <div class="mb-3">
                        <label class="fw-semibold">Balance After This Payment</label>
                        <div class="input-group">
                            <span class="input-group-text">ZMW</span>
                            <input type="number" name="balanceAfterPayment" id="balanceAfterPayment" step="0.01"
                                class="form-control" readonly style="background-color: #e9ecef; font-weight: bold;" />
                        </div>
                        <div id="balanceMessage" class="form-text">
                            This is calculated automatically: (Total Due - Payment Amount)
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-semibold">Payment Method</label>
                        <select name="method" class="form-select" required id="paymentMethod"
                            onchange="toggleUploadField()">
                            <option value="">Select Method</option>
                            <option value="Cash">Cash</option>
                            <option value="Manual">Manual</option>
                            <option value="Online">Online</option>
                        </select>
                    </div>

                    <!-- Upload Proof Field (Hidden by default, shown only for Manual) -->
                    <div class="mb-3" id="uploadField" style="display: none;">
                        <label class="fw-semibold">Upload Payment Proof</label>
                        <input type="file" name="paymentProof" class="form-control"
                            accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" />
                        <div class="form-text">
                            Supported formats: PDF, JPG, JPEG, PNG, DOC, DOCX (Max: 5MB)
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="fw-semibold">Semester (optional)</label>
                        <select name="semester" class="form-select">
                            <option value="">Select Semester</option>
                            <% [ "Semester 1" , "Semester 2" , "Semester 3" , "Semester 4" , "Semester 5" , "Semester 6"
                                , "Semester 7" , "Semester 8" ].forEach(s=> { %>
                                <option value="<%= s %>">
                                    <%= s %>
                                </option>
                                <% }) %>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="fw-semibold">Academic Year (optional)</label>
                        <input type="text" name="academicYear" placeholder="2025/2026" class="form-control" />
                    </div>

                    <!-- Hidden field for typical fee -->
                    <input type="hidden" id="typicalFee" value="0">

                    <button type="submit" class="btn btn-success w-100">
                        <i class="fas fa-check-circle me-1"></i> Create Payment
                    </button>
                </form>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const studentSearch = document.getElementById('studentSearch');
                const studentDropdown = document.getElementById('studentDropdown');
                const selectedStudentId = document.getElementById('selectedStudentId');
                const selectedStudentInfo = document.getElementById('selectedStudentInfo');
                const selectedStudentText = document.getElementById('selectedStudentText');
                const clearSelectionBtn = document.getElementById('clearSelection');
                const uploadField = document.getElementById('uploadField');
                const paymentMethodSelect = document.getElementById('paymentMethod');
                let searchTimeout;

                // Function to toggle upload field based on payment method
                window.toggleUploadField = function () {
                    const selectedMethod = paymentMethodSelect.value;
                    if (selectedMethod === 'Manual') {
                        uploadField.style.display = 'block';
                    } else {
                        uploadField.style.display = 'none';
                        // Clear the file input when hidden
                        const fileInput = uploadField.querySelector('input[type="file"]');
                        if (fileInput) {
                            fileInput.value = '';
                        }
                    }
                };

                // Global calculation function
                window.calculateBalance = function () {
                    const totalDue = parseFloat(document.getElementById('totalDue').value) || 0;
                    const paymentAmount = parseFloat(document.getElementById('paymentAmount').value) || 0;
                    const balanceAfter = totalDue - paymentAmount;

                    const balanceField = document.getElementById('balanceAfterPayment');
                    const balanceMessage = document.getElementById('balanceMessage');

                    balanceField.value = balanceAfter.toFixed(2);

                    // Update message color based on balance
                    if (balanceAfter < 0) {
                        balanceMessage.innerHTML = '<span class="text-danger">⚠️ Payment exceeds total due! Please check amounts.</span>';
                        balanceField.style.backgroundColor = '#f8d7da';
                        balanceField.style.color = '#721c24';
                    } else if (balanceAfter > 0) {
                        balanceMessage.innerHTML = '<span class="text-warning">Balance remaining after this payment</span>';
                        balanceField.style.backgroundColor = '#fff3cd';
                        balanceField.style.color = '#856404';
                    } else {
                        balanceMessage.innerHTML = '<span class="text-success">✓ Full payment - No balance remaining</span>';
                        balanceField.style.backgroundColor = '#d1e7dd';
                        balanceField.style.color = '#0f5132';
                    }
                };

                // Function to use typical fee for selected category
                window.useTypicalFee = function () {
                    const typicalFee = parseFloat(document.getElementById('typicalFee').value) || 0;
                    if (typicalFee > 0) {
                        document.getElementById('totalDue').value = typicalFee;
                        calculateBalance();
                    }
                };

                // Function to pay the full amount
                window.payFullAmount = function () {
                    const totalDue = parseFloat(document.getElementById('totalDue').value) || 0;
                    if (totalDue > 0) {
                        document.getElementById('paymentAmount').value = totalDue;
                        calculateBalance();
                    }
                };

                // Function to update fee suggestion based on category
                window.updateFeeSuggestion = function () {
                    const categorySelect = document.getElementById('category');
                    const selectedOption = categorySelect.options[categorySelect.selectedIndex];
                    const typicalAmount = parseFloat(selectedOption.getAttribute('data-typical')) || 0;

                    const feeSuggestion = document.getElementById('feeSuggestion');
                    document.getElementById('typicalFee').value = typicalAmount;

                    if (typicalAmount > 0) {
                        feeSuggestion.innerHTML = `Typical amount for this category: <strong>ZMW ${typicalAmount.toFixed(2)}</strong> <button type="button" class="btn btn-sm btn-link p-0" onclick="useTypicalFee()">Use this amount</button>`;
                        feeSuggestion.style.display = 'block';
                    } else {
                        feeSuggestion.style.display = 'none';
                    }
                };

                // Debounced search function
                studentSearch.addEventListener('input', function () {
                    clearTimeout(searchTimeout);
                    const searchTerm = this.value.trim();

                    if (searchTerm.length < 2) {
                        studentDropdown.style.display = 'none';
                        return;
                    }

                    searchTimeout = setTimeout(() => {
                        searchStudents(searchTerm);
                    }, 300);
                });

                // Handle click outside to close dropdown
                document.addEventListener('click', function (e) {
                    if (!studentSearch.contains(e.target) && !studentDropdown.contains(e.target)) {
                        studentDropdown.style.display = 'none';
                    }
                });

                // Search students function
                async function searchStudents(searchTerm) {
                    try {
                        const response = await fetch(`/finance/search-students?search=${encodeURIComponent(searchTerm)}`);
                        const students = await response.json();

                        if (students.length === 0) {
                            studentDropdown.innerHTML = '<div class="dropdown-item text-muted">No students found</div>';
                            studentDropdown.style.display = 'block';
                            return;
                        }

                        studentDropdown.innerHTML = students.map(student => `
                <button type="button" class="dropdown-item" data-id="${student._id}" data-text="${student.firstName} ${student.surname} - ${student.email}">
                    <strong>${student.firstName} ${student.surname}</strong><br>
                    <small class="text-muted">${student.email}</small>
                    ${student.studentId ? `<br><small class="text-muted">ID: ${student.studentId}</small>` : ''}
                </button>
            `).join('');

                        studentDropdown.style.display = 'block';

                        // Add click listeners to dropdown items
                        document.querySelectorAll('#studentDropdown .dropdown-item').forEach(item => {
                            item.addEventListener('click', function () {
                                const studentId = this.getAttribute('data-id');
                                const studentText = this.getAttribute('data-text');

                                selectedStudentId.value = studentId;
                                selectedStudentText.textContent = studentText;
                                selectedStudentInfo.style.display = 'block';
                                studentSearch.value = '';
                                studentDropdown.style.display = 'none';

                                // Validate form
                                document.getElementById('paymentForm').reportValidity();
                            });
                        });

                    } catch (error) {
                        console.error('Error searching students:', error);
                        studentDropdown.innerHTML = '<div class="dropdown-item text-danger">Error loading students</div>';
                        studentDropdown.style.display = 'block';
                    }
                }

                // Clear selection
                clearSelectionBtn.addEventListener('click', function () {
                    selectedStudentId.value = '';
                    selectedStudentText.textContent = '';
                    selectedStudentInfo.style.display = 'none';
                    studentSearch.value = '';

                    // Reset calculation fields
                    document.getElementById('totalDue').value = '';
                    document.getElementById('paymentAmount').value = '';
                    document.getElementById('balanceAfterPayment').value = '';
                    document.getElementById('balanceMessage').innerHTML = 'This is calculated automatically: (Total Due - Payment Amount)';
                    document.getElementById('balanceAfterPayment').style.backgroundColor = '#e9ecef';
                    document.getElementById('balanceAfterPayment').style.color = '';

                    studentSearch.focus();
                });

                // Keyboard navigation
                studentSearch.addEventListener('keydown', function (e) {
                    const items = studentDropdown.querySelectorAll('.dropdown-item');

                    if (items.length === 0) return;

                    let currentIndex = -1;
                    items.forEach((item, index) => {
                        if (item.classList.contains('active')) {
                            currentIndex = index;
                        }
                    });

                    switch (e.key) {
                        case 'ArrowDown':
                            e.preventDefault();
                            if (currentIndex < items.length - 1) {
                                items[currentIndex + 1].classList.add('active');
                                if (currentIndex >= 0) items[currentIndex].classList.remove('active');
                            }
                            break;
                        case 'ArrowUp':
                            e.preventDefault();
                            if (currentIndex > 0) {
                                items[currentIndex - 1].classList.add('active');
                                items[currentIndex].classList.remove('active');
                            }
                            break;
                        case 'Enter':
                            e.preventDefault();
                            if (currentIndex >= 0) {
                                items[currentIndex].click();
                            }
                            break;
                        case 'Escape':
                            studentDropdown.style.display = 'none';
                            break;
                    }
                });

                // Initialize calculation and toggle function
                calculateBalance();
                toggleUploadField(); // Initial call to set correct state
            });
        </script>

        <style>
            .dropdown-item:hover,
            .dropdown-item.active {
                background-color: #f8f9fa;
                cursor: pointer;
            }

            .dropdown-item {
                white-space: normal;
                padding: 0.5rem 1rem;
            }

            .form-text button.btn-link {
                text-decoration: none;
                vertical-align: baseline;
                padding: 0 0.25rem;
            }

            #balanceAfterPayment:read-only {
                cursor: not-allowed;
            }
        </style>

        <%- include('../partials/footer') %>