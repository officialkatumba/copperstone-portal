<%- include('../partials/header') %> <%- include('../partials/navbar') %>

<div class="container my-5">
  <div class="text-center mb-4">
    <h2 class="fw-bold" style="color: var(--primary-purple)">
      Applications & Payments
    </h2>
    <p class="text-muted">
      Review all student application payments for verification.
    </p>
  </div>

  <% if (applications.length === 0) { %>
  <div class="alert alert-info text-center">No applications found yet.</div>
  <% } else { %>
  <div class="table-responsive shadow-sm rounded-3">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>#</th>
          <th>Applicant</th>
          <th>Programme</th>
          <th>Amount</th>
          <th>Method</th>
          <th>Payment Status</th>
          <th>Application Status</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% applications.forEach((app, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td>
            <strong
              ><%= app.applicant.firstName %> <%= app.applicant.surname
              %></strong
            ><br />
            <small class="text-muted"><%= app.applicant.email %></small>
          </td>
          <td>
            <%= app.firstChoice ? app.firstChoice.name : "N/A" %>
            <small class="text-muted d-block"
              ><%= app.firstChoice?.code %></small
            >
          </td>
          <td>
            <%= app.payment?.amount ? "ZMW " + app.payment.amount.toFixed(2) :
            "—" %>
          </td>
          <td><%= app.payment?.method || "—" %></td>
          <td>
            <% if (app.payment?.status === "Verified") { %>
            <span class="badge bg-success">Verified</span>
            <% } else if (app.payment?.status === "Rejected") { %>
            <span class="badge bg-danger">Rejected</span>
            <% } else { %>
            <span class="badge bg-warning text-dark">Pending</span>
            <% } %>
          </td>
          <td>
            <% if (app.status === "Approved") { %>
            <span class="badge bg-success">Approved</span>
            <% } else if (app.status === "Rejected") { %>
            <span class="badge bg-danger">Rejected</span>
            <% } else if (app.status === "Under Review") { %>
            <span class="badge bg-info text-dark">Under Review</span>
            <% } else { %>
            <span class="badge bg-secondary">Pending</span>
            <% } %>
          </td>
          <td>
            <a
              href="/finance/applications/<%= app._id %>"
              class="btn btn-sm btn-primary"
            >
              <i class="fas fa-eye me-1"></i> View
            </a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
