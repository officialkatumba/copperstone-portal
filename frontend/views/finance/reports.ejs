<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="card shadow border-0">
                <div class="card-header bg-gradient-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-chart-pie me-2"></i> Finance Reports</h4>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Report Form -->
                        <div class="col-md-6">
                            <div class="card border-primary">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0"><i class="fas fa-cogs me-2"></i> Generate Payment Report</h5>
                                </div>
                                <div class="card-body">
                                    <form id="reportForm" method="GET" action="/finance/reports/generate">
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label for="startDate" class="form-label">Start Date</label>
                                                <input type="date" class="form-control" id="startDate" name="startDate"
                                                    max="<%= today %>">
                                            </div>
                                            <div class="col-md-6">
                                                <label for="endDate" class="form-label">End Date</label>
                                                <input type="date" class="form-control" id="endDate" name="endDate"
                                                    max="<%= today %>" value="<%= today %>">
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Output Format</label>
                                            <div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="outputFormat"
                                                        id="formatHtml" value="html" checked>
                                                    <label class="form-check-label" for="formatHtml">
                                                        <i class="fas fa-eye me-1"></i> HTML View
                                                    </label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="outputFormat"
                                                        id="formatPdf" value="pdf">
                                                    <label class="form-check-label" for="formatPdf">
                                                        <i class="fas fa-file-pdf me-1"></i> PDF Download
                                                    </label>
                                                </div>
                                                <!-- Add this inside the form, after the PDF radio button -->
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="outputFormat"
                                                        id="formatExcel" value="excel">
                                                    <label class="form-check-label" for="formatExcel">
                                                        <i class="fas fa-file-excel me-1"></i> Excel Export
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <button type="submit" class="btn btn-primary btn-gradient">
                                                <i class="fas fa-chart-bar me-1"></i> Generate Full Report
                                            </button>
                                            <button type="button" id="quickStatsBtn" class="btn btn-info btn-gradient">
                                                <i class="fas fa-bolt me-1"></i> Quick Balance Stats
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <!-- Quick Stats Display -->
                            <div class="card border-info mt-4 d-none" id="quickStatsCard">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0"><i class="fas fa-tachometer-alt me-2"></i> Balance Statistics</h5>
                                </div>
                                <div class="card-body">
                                    <div id="quickStatsContent">
                                        <!-- Stats will be loaded here -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Report Information -->
                        <div class="col-md-6">
                            <div class="card border-success">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i> Report Information</h5>
                                </div>
                                <div class="card-body">
                                    <h6 class="text-primary">What's included:</h6>
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Payment Summary:</strong> Total payments & amounts
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Balance Tracking:</strong> Due vs Paid vs Outstanding
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Category Analysis:</strong> Breakdown with percentages
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Status Overview:</strong> Payment status distribution
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Detailed Listing:</strong> Complete payment records
                                        </li>
                                    </ul>

                                    <div class="alert alert-info mt-4 border-info">
                                        <h6 class="text-info"><i class="fas fa-lightbulb me-2"></i>Quick Tips:</h6>
                                        <ul class="mb-0 small">
                                            <li>Use <strong>Quick Balance Stats</strong> for instant financial overview
                                            </li>
                                            <li>PDF reports include all balance calculations</li>
                                            <li>Empty dates = Current month report</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Report Results -->
                    <div id="reportResults" class="mt-4"></div>
                </div>
            </div>
        </div>

        <style>
            /* Inline styles for minimalistic beauty */
            .btn-gradient {
                background: linear-gradient(45deg, #4e73df, #224abe);
                border: none;
                color: white;
                transition: all 0.3s;
            }

            .btn-gradient:hover {
                background: linear-gradient(45deg, #224abe, #4e73df);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            }

            .bg-gradient-primary {
                background: linear-gradient(45deg, #4e73df, #1cc88a);
            }

            .stat-card {
                border-radius: 15px;
                transition: transform 0.3s, box-shadow 0.3s;
                border: none;
                box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
            }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }

            .balance-positive {
                color: #1cc88a;
                font-weight: bold;
            }

            .balance-negative {
                color: #e74a3b;
                font-weight: bold;
            }

            .balance-neutral {
                color: #6c757d;
                font-weight: bold;
            }

            .progress-bar-balance {
                height: 10px;
                border-radius: 5px;
                background: linear-gradient(90deg, #e74a3b, #f6c23e, #1cc88a);
            }

            .category-badge {
                font-size: 0.75em;
                padding: 4px 10px;
                border-radius: 20px;
                background: linear-gradient(45deg, #6c757d, #858796);
                color: white;
            }

            .table-hover tbody tr:hover {
                background: linear-gradient(90deg, rgba(78, 115, 223, 0.05), rgba(28, 200, 138, 0.05));
            }

            /* Quick Stats specific styles */
            .quick-stat-value {
                font-size: 1.75rem;
                font-weight: 700;
            }

            .quick-stat-label {
                font-size: 0.8rem;
                color: #6c757d;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }
        </style>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                const reportForm = document.getElementById('reportForm');
                const quickStatsBtn = document.getElementById('quickStatsBtn');
                const quickStatsCard = document.getElementById('quickStatsCard');
                const quickStatsContent = document.getElementById('quickStatsContent');
                const startDateInput = document.getElementById('startDate');
                const endDateInput = document.getElementById('endDate');

                // ============ THOUSAND SEPARATOR FORMATTER ============
                function formatNumber(num) {
                    if (num === undefined || num === null) return "0.00";
                    return num.toLocaleString('en-US', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }

                function formatInteger(num) {
                    if (num === undefined || num === null) return "0";
                    return num.toLocaleString('en-US');
                }

                // Set default dates (last 30 days)
                if (!startDateInput.value) {
                    const thirtyDaysAgo = new Date();
                    thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
                    startDateInput.value = thirtyDaysAgo.toISOString().split('T')[0];
                }

                // Quick Stats button
                quickStatsBtn.addEventListener('click', function () {
                    const startDate = startDateInput.value;
                    const endDate = endDateInput.value;

                    // Show loading
                    quickStatsContent.innerHTML = `
                <div class="text-center py-4">
                    <div class="spinner-border text-info" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2 text-muted">Calculating balance statistics...</p>
                </div>
            `;

                    quickStatsCard.classList.remove('d-none');
                    quickStatsCard.scrollIntoView({ behavior: 'smooth' });

                    // Fetch quick stats
                    fetch(`/finance/reports/quick-stats?startDate=${startDate}&endDate=${endDate}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                displayQuickStats(data.report);
                            } else {
                                quickStatsContent.innerHTML = `
                            <div class="alert alert-danger border-danger">
                                <i class="fas fa-exclamation-triangle me-2"></i>
                                Failed to load statistics: ${data.error}
                            </div>
                        `;
                            }
                        })
                        .catch(error => {
                            quickStatsContent.innerHTML = `
                        <div class="alert alert-danger border-danger">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            Error loading statistics. Please try again.
                        </div>
                    `;
                            console.error('Error:', error);
                        });
                });

                // PDF report handling
                // reportForm.addEventListener('submit', function (e) {
                //     const outputFormat = document.querySelector('input[name="outputFormat"]:checked').value;

                //     if (outputFormat === 'pdf') {
                //         e.preventDefault();
                //         const reportResults = document.getElementById('reportResults');

                //         reportResults.innerHTML = `
                //     <div class="text-center py-5">
                //         <div class="spinner-border text-primary" role="status">
                //             <span class="visually-hidden">Loading...</span>
                //         </div>
                //         <p class="mt-3 text-primary">
                //             <i class="fas fa-file-pdf me-2"></i>Generating PDF report with balance details...
                //         </p>
                //     </div>
                // `;

                //         const formData = new FormData(this);
                //         const params = new URLSearchParams(formData).toString();

                //         fetch(`/finance/reports/generate?${params}`)
                //             .then(response => response.json())
                //             .then(data => {
                //                 if (data.success) {
                //                     window.open(data.downloadUrl, '_blank');
                //                     reportResults.innerHTML = `
                //                 <div class="alert alert-success border-success">
                //                     <h5 class="text-success">
                //                         <i class="fas fa-check-circle me-2"></i>PDF Report Generated!
                //                     </h5>
                //                     <div class="row mt-3">
                //                         <div class="col-md-4">
                //                             <div class="card stat-card">
                //                                 <div class="card-body text-center">
                //                                     <h3 class="mb-2">${formatInteger(data.reportData.totalPayments)}</h3>
                //                                     <p class="mb-0 small text-muted">Total Payments</p>
                //                                 </div>
                //                             </div>
                //                         </div>
                //                         <div class="col-md-4">
                //                             <div class="card stat-card">
                //                                 <div class="card-body text-center">
                //                                     <h3 class="mb-2 balance-positive">ZMW ${data.reportData.totalAmount}</h3>
                //                                     <p class="mb-0 small text-muted">Total Collected</p>
                //                                 </div>
                //                             </div>
                //                         </div>
                //                         <div class="col-md-4">
                //                             <div class="card stat-card">
                //                                 <div class="card-body text-center">
                //                                     <h3 class="mb-2 balance-negative">ZMW ${data.reportData.totalBalance}</h3>
                //                                     <p class="mb-0 small text-muted">Outstanding Balance</p>
                //                                 </div>
                //                             </div>
                //                         </div>
                //                     </div>
                //                     <div class="mt-4 text-center">
                //                         <a href="${data.downloadUrl}" class="btn btn-success btn-gradient" target="_blank">
                //                             <i class="fas fa-download me-1"></i> Download PDF
                //                         </a>
                //                         <a href="/finance/reports" class="btn btn-outline-primary ms-2">
                //                             <i class="fas fa-redo me-1"></i> Generate Another
                //                         </a>
                //                     </div>
                //                 </div>
                //             `;
                //                 } else {
                //                     reportResults.innerHTML = `
                //                 <div class="alert alert-danger border-danger">
                //                     <i class="fas fa-exclamation-triangle me-2"></i>
                //                     Failed to generate PDF: ${data.error}
                //                 </div>
                //             `;
                //                 }
                //             })
                //             .catch(error => {
                //                 reportResults.innerHTML = `
                //             <div class="alert alert-danger border-danger">
                //                 <i class="fas fa-exclamation-triangle me-2"></i>
                //                 Error generating PDF report
                //             </div>
                //         `;
                //                 console.error('Error:', error);
                //             });
                //     }
                // });

                // PDF and Excel report handling
                reportForm.addEventListener('submit', function (e) {
                    const outputFormat = document.querySelector('input[name="outputFormat"]:checked').value;

                    if (outputFormat === 'pdf') {
                        e.preventDefault();
                        handlePDFReport(this);
                    } else if (outputFormat === 'excel') {
                        e.preventDefault();
                        handleExcelReport(this);
                    }
                    // HTML format will submit normally
                });

                function handlePDFReport(form) {
                    const reportResults = document.getElementById('reportResults');

                    reportResults.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-primary">
                <i class="fas fa-file-pdf me-2"></i>Generating PDF report with balance details...
            </p>
        </div>
    `;

                    const formData = new FormData(form);
                    const params = new URLSearchParams(formData).toString();

                    fetch(`/finance/reports/generate?${params}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                window.open(data.downloadUrl, '_blank');
                                reportResults.innerHTML = `
                    <div class="alert alert-success border-success">
                        <h5 class="text-success">
                            <i class="fas fa-check-circle me-2"></i>PDF Report Generated!
                        </h5>
                        <div class="row mt-3">
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2">${formatInteger(data.reportData.totalPayments)}</h3>
                                        <p class="mb-0 small text-muted">Total Payments</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2 balance-positive">ZMW ${data.reportData.totalAmount}</h3>
                                        <p class="mb-0 small text-muted">Total Collected</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2 balance-negative">ZMW ${data.reportData.totalBalance}</h3>
                                        <p class="mb-0 small text-muted">Outstanding Balance</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="${data.downloadUrl}" class="btn btn-success btn-gradient" target="_blank">
                                <i class="fas fa-download me-1"></i> Download PDF
                            </a>
                            <a href="/finance/reports" class="btn btn-outline-primary ms-2">
                                <i class="fas fa-redo me-1"></i> Generate Another
                            </a>
                        </div>
                    </div>
                `;
                            } else {
                                reportResults.innerHTML = `
                    <div class="alert alert-danger border-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Failed to generate PDF: ${data.error}
                    </div>
                `;
                            }
                        })
                        .catch(error => {
                            reportResults.innerHTML = `
                <div class="alert alert-danger border-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Error generating PDF report
                </div>
            `;
                            console.error('Error:', error);
                        });
                }

                function handleExcelReport(form) {
                    const reportResults = document.getElementById('reportResults');

                    reportResults.innerHTML = `
        <div class="text-center py-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-3 text-success">
                <i class="fas fa-file-excel me-2"></i>Generating Excel report...
            </p>
        </div>
    `;

                    const formData = new FormData(form);
                    const params = new URLSearchParams(formData).toString();

                    fetch(`/finance/reports/export-excel?${params}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                window.open(data.downloadUrl, '_blank');
                                reportResults.innerHTML = `
                    <div class="alert alert-success border-success">
                        <h5 class="text-success">
                            <i class="fas fa-check-circle me-2"></i>Excel Report Generated!
                        </h5>
                        <div class="row mt-3">
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2">${formatInteger(data.reportData.totalPayments)}</h3>
                                        <p class="mb-0 small text-muted">Total Payments</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2 balance-positive">ZMW ${data.reportData.totalAmount}</h3>
                                        <p class="mb-0 small text-muted">Total Collected</p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="card stat-card">
                                    <div class="card-body text-center">
                                        <h3 class="mb-2 balance-negative">ZMW ${data.reportData.totalBalance}</h3>
                                        <p class="mb-0 small text-muted">Outstanding Balance</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4 text-center">
                            <a href="${data.downloadUrl}" class="btn btn-success btn-gradient" target="_blank">
                                <i class="fas fa-download me-1"></i> Download Excel
                            </a>
                            <a href="/finance/reports" class="btn btn-outline-primary ms-2">
                                <i class="fas fa-redo me-1"></i> Generate Another
                            </a>
                        </div>
                    </div>
                `;
                            } else {
                                reportResults.innerHTML = `
                    <div class="alert alert-danger border-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Failed to generate Excel: ${data.error}
                    </div>
                `;
                            }
                        })
                        .catch(error => {
                            reportResults.innerHTML = `
                <div class="alert alert-danger border-danger">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    Error generating Excel report
                </div>
            `;
                            console.error('Error:', error);
                        });
                }

                // ============ FUNCTION TO DISPLAY QUICK STATS WITH THOUSAND SEPARATORS ============
                function displayQuickStats(stats) {
                    const completionColor = stats.summary.completionPercentage >= 75 ? 'balance-positive' :
                        stats.summary.completionPercentage >= 50 ? 'balance-neutral' : 'balance-negative';

                    let html = `
                <h6 class="text-primary mb-3">
                    <i class="fas fa-calendar-alt me-2"></i>
                    ${stats.dateRange.formattedStart} to ${stats.dateRange.formattedEnd}
                </h6>
                
                <!-- Balance Summary Cards with Thousand Separators -->
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <div class="card stat-card border-primary">
                            <div class="card-body text-center py-3">
                                <h3 class="mb-2 text-primary quick-stat-value">${formatInteger(stats.summary.totalPayments)}</h3>
                                <p class="mb-0 quick-stat-label">Total Payments</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card stat-card border-success">
                            <div class="card-body text-center py-3">
                                <h3 class="mb-2 balance-positive quick-stat-value">ZMW ${formatNumber(stats.summary.totalAmount)}</h3>
                                <p class="mb-0 quick-stat-label">Total Collected</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card stat-card border-warning">
                            <div class="card-body text-center py-3">
                                <h3 class="mb-2 quick-stat-value">ZMW ${formatNumber(stats.summary.totalDue)}</h3>
                                <p class="mb-0 quick-stat-label">Total Due</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card stat-card border-danger">
                            <div class="card-body text-center py-3">
                                <h3 class="mb-2 balance-negative quick-stat-value">ZMW ${formatNumber(stats.summary.totalBalance)}</h3>
                                <p class="mb-0 quick-stat-label">Outstanding Balance</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Completion Progress -->
                <div class="mb-4">
                    <h6 class="text-primary">Payment Completion</h6>
                    <div class="progress progress-bar-balance mb-2" style="height: 10px;">
                        <div class="progress-bar bg-success" 
                             style="width: ${stats.summary.completionPercentage}%"
                             role="progressbar">
                        </div>
                    </div>
                    <div class="d-flex justify-content-between small">
                        <span class="text-muted">Completion Rate:</span>
                        <span class="${completionColor} fw-bold">${stats.summary.completionPercentage}%</span>
                    </div>
                </div>
                
                <!-- Category Breakdown with Thousand Separators -->
                <h6 class="text-primary">Category Summary</h6>
                <div class="table-responsive">
                    <table class="table table-sm table-hover">
                        <thead class="bg-light">
                            <tr>
                                <th>Category</th>
                                <th class="text-end">Count</th>
                                <th class="text-end">Collected (ZMW)</th>
                                <th class="text-end">Balance (ZMW)</th>
                            </tr>
                        </thead>
                        <tbody>
            `;

                    stats.categoryStats.forEach(cat => {
                        const balanceClass = cat.totalBalance > 0 ? 'balance-negative' : 'balance-positive';
                        html += `
                    <tr>
                        <td><span class="badge category-badge">${cat._id || 'Uncategorized'}</span></td>
                        <td class="text-end fw-bold">${formatInteger(cat.count)}</td>
                        <td class="text-end balance-positive">ZMW ${formatNumber(cat.total)}</td>
                        <td class="text-end ${balanceClass}">ZMW ${formatNumber(cat.totalBalance || 0)}</td>
                    </tr>
                `;
                    });

                    // Add status summary
                    html += `
                        </tbody>
                    </table>
                </div>
                
                <div class="mt-4 text-center">
                    <button class="btn btn-outline-primary btn-sm" onclick="document.getElementById('reportForm').submit()">
                        <i class="fas fa-chart-bar me-1"></i> View Full Report
                    </button>
                    <small class="d-block text-muted mt-2">
                        <i class="fas fa-clock me-1"></i> Generated: ${stats.generatedAt}
                    </small>
                    <small class="d-block text-muted mt-1">
                        <i class="fas fa-building me-1"></i> Finance Department - Copperstone University
                    </small>
                </div>
            `;

                    quickStatsContent.innerHTML = html;
                }
            });
        </script>

        <%- include('../partials/footer') %>