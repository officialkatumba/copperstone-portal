<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-5">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-chart-pie me-2"></i> Finance Reports</h4>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Report Form -->
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Generate Payment Report</h5>
                                </div>
                                <div class="card-body">
                                    <form id="reportForm" method="GET" action="/finance/reports/generate">
                                        <div class="row mb-3">
                                            <div class="col-md-6">
                                                <label for="startDate" class="form-label">Start Date</label>
                                                <input type="date" class="form-control" id="startDate" name="startDate"
                                                    max="<%= today %>">
                                            </div>
                                            <div class="col-md-6">
                                                <label for="endDate" class="form-label">End Date</label>
                                                <input type="date" class="form-control" id="endDate" name="endDate"
                                                    max="<%= today %>" value="<%= today %>">
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Output Format</label>
                                            <div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="outputFormat"
                                                        id="formatHtml" value="html" checked>
                                                    <label class="form-check-label" for="formatHtml">
                                                        HTML (View in Browser)
                                                    </label>
                                                </div>
                                                <div class="form-check form-check-inline">
                                                    <input class="form-check-input" type="radio" name="outputFormat"
                                                        id="formatPdf" value="pdf">
                                                    <label class="form-check-label" for="formatPdf">
                                                        PDF (Download)
                                                    </label>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="d-grid gap-2">
                                            <button type="submit" class="btn btn-primary">
                                                <i class="fas fa-chart-bar me-1"></i> Generate Report
                                            </button>
                                            <button type="button" id="quickStatsBtn" class="btn btn-outline-info">
                                                <i class="fas fa-bolt me-1"></i> Quick Stats
                                            </button>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <!-- Quick Stats Display -->
                            <div class="card mt-4 d-none" id="quickStatsCard">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0">Quick Statistics</h5>
                                </div>
                                <div class="card-body">
                                    <div id="quickStatsContent">
                                        <!-- Stats will be loaded here -->
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Report Information -->
                        <div class="col-md-6">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Report Information</h5>
                                </div>
                                <div class="card-body">
                                    <h6>What's included in the report:</h6>
                                    <ul class="list-group list-group-flush">
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Total payments and amount
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Category breakdown with percentages
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Payment status summary
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Detailed payment list with student info
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Date range selection
                                        </li>
                                        <li class="list-group-item">
                                            <i class="fas fa-check text-success me-2"></i>
                                            Export to PDF option
                                        </li>
                                    </ul>

                                    <div class="alert alert-info mt-4">
                                        <h6><i class="fas fa-info-circle me-2"></i>Tips:</h6>
                                        <ul class="mb-0">
                                            <li>Leave dates empty for current month report</li>
                                            <li>PDF reports include all details and are formatted for printing</li>
                                            <li>Use Quick Stats for instant summary without page reload</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Report Results (will be loaded dynamically) -->
                    <div id="reportResults" class="mt-4"></div>
                </div>
            </div>
        </div>

        <style>
            .stat-card {
                border-radius: 10px;
                transition: transform 0.2s;
            }

            .stat-card:hover {
                transform: translateY(-2px);
            }

            .category-badge {
                font-size: 0.8em;
                padding: 3px 8px;
                border-radius: 12px;
            }
        </style>

        <script>
            document.addEventListener('DOMContentLoaded', function () {
                // Form submission handling
                const reportForm = document.getElementById('reportForm');
                const quickStatsBtn = document.getElementById('quickStatsBtn');
                const quickStatsCard = document.getElementById('quickStatsCard');
                const quickStatsContent = document.getElementById('quickStatsContent');

                // Quick Stats button
                quickStatsBtn.addEventListener('click', function () {
                    const startDate = document.getElementById('startDate').value;
                    const endDate = document.getElementById('endDate').value;

                    // Show loading
                    quickStatsContent.innerHTML = `
        <div class="text-center">
          <div class="spinner-border text-info" role="status">
            <span class="visually-hidden">Loading...</span>
          </div>
          <p class="mt-2">Loading statistics...</p>
        </div>
      `;
                    quickStatsCard.classList.remove('d-none');

                    // Fetch quick stats
                    fetch(`/finance/reports/quick-stats?startDate=${startDate}&endDate=${endDate}`)
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                displayQuickStats(data.report);
                            } else {
                                quickStatsContent.innerHTML = `
              <div class="alert alert-danger">
                Failed to load statistics: ${data.error}
              </div>
            `;
                            }
                        })
                        .catch(error => {
                            quickStatsContent.innerHTML = `
            <div class="alert alert-danger">
              Error loading statistics
            </div>
          `;
                            console.error('Error:', error);
                        });
                });

                // PDF report handling
                reportForm.addEventListener('submit', function (e) {
                    const outputFormat = document.querySelector('input[name="outputFormat"]:checked').value;

                    if (outputFormat === 'pdf') {
                        e.preventDefault();

                        // Show loading
                        const reportResults = document.getElementById('reportResults');
                        reportResults.innerHTML = `
          <div class="text-center">
            <div class="spinner-border text-primary" role="status">
              <span class="visually-hidden">Loading...</span>
            </div>
            <p class="mt-2">Generating PDF report...</p>
          </div>
        `;

                        // Get form data
                        const formData = new FormData(this);
                        const params = new URLSearchParams(formData).toString();

                        // Generate PDF via AJAX
                        fetch(`/finance/reports/generate?${params}`)
                            .then(response => response.json())
                            .then(data => {
                                if (data.success) {
                                    // Open PDF in new tab
                                    window.open(data.downloadUrl, '_blank');
                                    reportResults.innerHTML = `
                <div class="alert alert-success">
                  <h5><i class="fas fa-check-circle me-2"></i>PDF Report Generated!</h5>
                  <p>Your report has been generated successfully.</p>
                  <p><strong>Date Range:</strong> ${data.reportData.dateRange}</p>
                  <p><strong>Total Payments:</strong> ${data.reportData.totalPayments}</p>
                  <p><strong>Total Amount:</strong> ZMW ${data.reportData.totalAmount}</p>
                  <p class="mt-3">
                    <a href="${data.downloadUrl}" class="btn btn-success" target="_blank">
                      <i class="fas fa-download me-1"></i> Download PDF
                    </a>
                    <a href="/finance/reports" class="btn btn-outline-secondary">
                      Generate Another Report
                    </a>
                  </p>
                </div>
              `;
                                } else {
                                    reportResults.innerHTML = `
                <div class="alert alert-danger">
                  Failed to generate PDF: ${data.error}
                </div>
              `;
                                }
                            })
                            .catch(error => {
                                reportResults.innerHTML = `
              <div class="alert alert-danger">
                Error generating PDF report
              </div>
            `;
                                console.error('Error:', error);
                            });
                    }
                    // For HTML format, let form submit normally
                });

                // Function to display quick stats
                function displayQuickStats(stats) {
                    let html = `
        <h6>Date Range: ${stats.dateRange.formattedStart} to ${stats.dateRange.formattedEnd}</h6>
        <hr>
        
        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
          <div class="col-md-3">
            <div class="card stat-card bg-primary text-white">
              <div class="card-body text-center">
                <h3 class="mb-1">${stats.summary.totalPayments}</h3>
                <p class="mb-0 small">Total Payments</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card stat-card bg-success text-white">
              <div class="card-body text-center">
                <h3 class="mb-1">ZMW ${stats.summary.totalAmount.toFixed(2)}</h3>
                <p class="mb-0 small">Total Amount</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card stat-card bg-info text-white">
              <div class="card-body text-center">
                <h3 class="mb-1">ZMW ${stats.summary.averageAmount.toFixed(2)}</h3>
                <p class="mb-0 small">Average Payment</p>
              </div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card stat-card bg-warning text-dark">
              <div class="card-body text-center">
                <h3 class="mb-1">ZMW ${stats.summary.maxAmount.toFixed(2)}</h3>
                <p class="mb-0 small">Largest Payment</p>
              </div>
            </div>
          </div>
        </div>
      `;

                    // Category Breakdown
                    if (stats.categoryStats.length > 0) {
                        html += `
          <h6>Category Breakdown</h6>
          <div class="table-responsive">
            <table class="table table-sm table-hover">
              <thead>
                <tr>
                  <th>Category</th>
                  <th class="text-end">Count</th>
                  <th class="text-end">Total</th>
                  <th class="text-end">Average</th>
                </tr>
              </thead>
              <tbody>
        `;

                        stats.categoryStats.forEach(cat => {
                            html += `
            <tr>
              <td><span class="badge bg-secondary category-badge">${cat._id}</span></td>
              <td class="text-end">${cat.count}</td>
              <td class="text-end">ZMW ${cat.total.toFixed(2)}</td>
              <td class="text-end">ZMW ${cat.average.toFixed(2)}</td>
            </tr>
          `;
                        });

                        html += `</tbody></table></div>`;
                    }

                    // Recent Payments
                    if (stats.recentPayments.length > 0) {
                        html += `
          <hr>
          <h6>Recent Payments</h6>
          <div class="table-responsive">
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Student</th>
                  <th>Amount</th>
                  <th>Status</th>
                </tr>
              </thead>
              <tbody>
        `;

                        stats.recentPayments.forEach(payment => {
                            html += `
            <tr>
              <td>${new Date(payment.createdAt).toLocaleDateString()}</td>
              <td>${payment.student ? payment.student.firstName + ' ' + payment.student.surname : 'N/A'}</td>
              <td>ZMW ${payment.amount.toFixed(2)}</td>
              <td><span class="badge bg-${payment.status === 'Verified' ? 'success' : payment.status === 'Pending' ? 'warning' : 'secondary'}">${payment.status}</span></td>
            </tr>
          `;
                        });

                        html += `</tbody></table></div>`;
                    }

                    html += `
        <div class="mt-3 text-end">
          <small class="text-muted">Generated: ${stats.generatedAt}</small>
        </div>
      `;

                    quickStatsContent.innerHTML = html;
                }

                // Set default dates (last 30 days)
                const endDateInput = document.getElementById('endDate');
                const startDateInput = document.getElementById('startDate');

                if (!startDateInput.value) {
                    const thirtyDaysAgo = new Date();
                    thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
                    startDateInput.value = thirtyDaysAgo.toISOString().split('T')[0];
                }
            });
        </script>

        <%- include('../partials/footer') %>