<%- include('../partials/header') %>
    <%- include('../partials/navbar') %>

        <div class="container my-4">
            <div class="card shadow border-0">
                <div
                    class="card-header bg-gradient-primary text-white d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><i class="fas fa-file-alt me-2"></i> Payment Report</h4>
                    <div>
                        <a href="/finance/reports/generate?startDate=<%= reportData.dateRange.start %>&endDate=<%= reportData.dateRange.end %>&outputFormat=pdf"
                            class="btn btn-light btn-sm" target="_blank">
                            <i class="fas fa-download me-1"></i> PDF
                        </a>
                        <a href="/finance/reports" class="btn btn-outline-light btn-sm ms-2">
                            <i class="fas fa-arrow-left me-1"></i> Back
                        </a>
                    </div>
                </div>

                <div class="card-body">
                    <!-- Report Header -->
                    <div class="row mb-4">
                        <div class="col-md-8">
                            <h5 class="text-primary">
                                <i class="fas fa-calendar-alt me-2"></i>
                                <%= reportData.dateRange.formattedStart %> to <%= reportData.dateRange.formattedEnd %>
                            </h5>
                            <p class="text-muted mb-0">
                                <i class="fas fa-clock me-1"></i>Generated: <%= reportData.generatedAt %>
                            </p>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-success">
                                <div class="card-body text-center py-3">
                                    <h3 class="mb-1 balance-positive">ZMW <%= reportData.summary.totalAmount.toFixed(2)
                                            %>
                                    </h3>
                                    <p class="mb-0 small text-muted">
                                        Total Collected (<%= reportData.summary.totalPayments %> payments)
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Balance Summary -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="card stat-card border-primary">
                                <div class="card-body text-center py-3">
                                    <h2 class="mb-2 text-primary">
                                        <%= reportData.summary.totalPayments %>
                                    </h2>
                                    <p class="mb-0 small text-muted">Total Payments</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card border-success">
                                <div class="card-body text-center py-3">
                                    <h2 class="mb-2 balance-positive">
                                        ZMW <%= reportData.summary.totalPaid.toFixed(2) %>
                                    </h2>
                                    <p class="mb-0 small text-muted">Total Paid</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card border-warning">
                                <div class="card-body text-center py-3">
                                    <h2 class="mb-2">
                                        ZMW <%= reportData.summary.totalDue.toFixed(2) %>
                                    </h2>
                                    <p class="mb-0 small text-muted">Total Due</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="card stat-card border-danger">
                                <div class="card-body text-center py-3">
                                    <h2 class="mb-2 balance-negative">
                                        ZMW <%= reportData.summary.totalBalance.toFixed(2) %>
                                    </h2>
                                    <p class="mb-0 small text-muted">Outstanding Balance</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Completion Progress -->
                    <div class="card mb-4 border-info">
                        <div class="card-header bg-light">
                            <h5 class="mb-0 text-primary">
                                <i class="fas fa-chart-line me-2"></i> Payment Completion
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="progress progress-bar-balance mb-2" style="height: 20px;">
                                <div class="progress-bar bg-success"
                                    style="width: <%= reportData.summary.completionPercentage %>%" role="progressbar">
                                    <span class="fw-bold">
                                        <%= reportData.summary.completionPercentage %>%
                                    </span>
                                </div>
                            </div>
                            <div class="row text-center small">
                                <div class="col">
                                    <span class="balance-positive">ZMW <%= reportData.summary.totalPaid.toFixed(2) %>
                                            </span>
                                    <p class="mb-0 text-muted">Paid</p>
                                </div>
                                <div class="col">
                                    <span class="balance-negative">ZMW <%= reportData.summary.totalBalance.toFixed(2) %>
                                            </span>
                                    <p class="mb-0 text-muted">Outstanding</p>
                                </div>
                                <div class="col">
                                    <span>ZMW <%= reportData.summary.totalDue.toFixed(2) %></span>
                                    <p class="mb-0 text-muted">Total Due</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Category Breakdown WITH BALANCE -->
                    <div class="card mb-4 border-success">
                        <div class="card-header bg-light">
                            <h5 class="mb-0 text-primary">
                                <i class="fas fa-chart-pie me-2"></i> Category Breakdown
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Category</th>
                                            <th class="text-end">Count</th>
                                            <th class="text-end">Collected</th>
                                            <th class="text-end">Due</th>
                                            <th class="text-end">Balance</th>
                                            <th class="text-end">%</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% const categories=Object.entries(reportData.summary.categories).sort((a, b)=>
                                            b[1].totalAmount - a[1].totalAmount);
                                            for (const [category, data] of categories) {
                                            %>
                                            <tr>
                                                <td>
                                                    <span class="badge category-badge">
                                                        <%= category %>
                                                    </span>
                                                </td>
                                                <td class="text-end">
                                                    <%= data.count %>
                                                </td>
                                                <td class="text-end balance-positive">
                                                    ZMW <%= data.totalAmount.toFixed(2) %>
                                                </td>
                                                <td class="text-end">
                                                    ZMW <%= data.totalDue.toFixed(2) %>
                                                </td>
                                                <td
                                                    class="text-end <%= data.totalBalance > 0 ? 'balance-negative' : 'balance-positive' %>">
                                                    ZMW <%= data.totalBalance.toFixed(2) %>
                                                </td>
                                                <td class="text-end">
                                                    <%= data.percentage %>%
                                                </td>
                                            </tr>
                                            <% } %>
                                    </tbody>
                                    <tfoot class="table-light fw-bold">
                                        <tr>
                                            <td>TOTAL</td>
                                            <td class="text-end">
                                                <%= reportData.summary.totalPayments %>
                                            </td>
                                            <td class="text-end balance-positive">
                                                ZMW <%= reportData.summary.totalAmount.toFixed(2) %>
                                            </td>
                                            <td class="text-end">
                                                ZMW <%= reportData.summary.totalDue.toFixed(2) %>
                                            </td>
                                            <td class="text-end balance-negative">
                                                ZMW <%= reportData.summary.totalBalance.toFixed(2) %>
                                            </td>
                                            <td class="text-end">100%</td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Status Breakdown -->
                    <div class="card mb-4 border-warning">
                        <div class="card-header bg-light">
                            <h5 class="mb-0 text-primary">
                                <i class="fas fa-chart-bar me-2"></i> Status Breakdown
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <% for (const [status, count] of Object.entries(reportData.summary.statusCount)) { const
                                    percentage=Math.round((count / reportData.summary.totalPayments) * 100); let
                                    bgClass='bg-secondary' ; if (status==='Verified' || status==='Fully Paid' )
                                    bgClass='bg-success' ; else if (status==='Pending' ) bgClass='bg-warning' ; else if
                                    (status==='Rejected' ) bgClass='bg-danger' ; else if (status==='Partially Paid' )
                                    bgClass='bg-info' ; %>
                                    <div class="col-md-3 mb-3">
                                        <div class="card <%= bgClass %> text-white stat-card">
                                            <div class="card-body text-center py-3">
                                                <h3 class="mb-1">
                                                    <%= count %>
                                                </h3>
                                                <p class="mb-1">
                                                    <%= status %>
                                                </p>
                                                <p class="mb-0 small">
                                                    <%= percentage %>% of total
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <% } %>
                            </div>
                        </div>
                    </div>

                    <!-- Detailed Payments WITH BALANCE -->
                    <div class="card border-primary">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-primary">
                                <i class="fas fa-list me-2"></i> Detailed Payments (<%= reportData.payments.length %>)
                            </h5>
                            <button class="btn btn-sm btn-outline-primary" onclick="togglePaymentDetails()">
                                <i class="fas fa-eye me-1"></i> Toggle Details
                            </button>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive" id="paymentDetails">
                                <table class="table table-sm table-hover">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Date</th>
                                            <th>Receipt #</th>
                                            <th>Student</th>
                                            <th>Category</th>
                                            <th class="text-end">Amount</th>
                                            <th class="text-end">Due</th>
                                            <th class="text-end">Balance</th>
                                            <th>Method</th>
                                            <th>Status</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% reportData.payments.forEach(payment=> {
                                            const date = new Date(payment.createdAt);
                                            let statusClass = 'secondary';
                                            if (payment.status === 'Verified' || payment.status === 'Fully Paid')
                                            statusClass = 'success';
                                            else if (payment.status === 'Pending') statusClass = 'warning';
                                            else if (payment.status === 'Rejected') statusClass = 'danger';
                                            else if (payment.status === 'Partially Paid') statusClass = 'info';
                                            %>
                                            <tr>
                                                <td>
                                                    <%= date.toLocaleDateString() %>
                                                </td>
                                                <td><code><%= payment.reference %></code></td>
                                                <td>
                                                    <%= payment.student.firstName %>
                                                        <%= payment.student.surname %>
                                                            <br>
                                                            <small class="text-muted">
                                                                <%= payment.student.studentId || 'N/A' %>
                                                            </small>
                                                </td>
                                                <td>
                                                    <span class="badge category-badge">
                                                        <%= payment.category %>
                                                    </span>
                                                </td>
                                                <td class="text-end fw-bold balance-positive">
                                                    ZMW <%= payment.amount.toFixed(2) %>
                                                </td>
                                                <td class="text-end">
                                                    ZMW <%= (payment.totalDue || 0).toFixed(2) %>
                                                </td>
                                                <td
                                                    class="text-end fw-bold <%= (payment.balanceAfterPayment || 0) > 0 ? 'balance-negative' : 'balance-positive' %>">
                                                    ZMW <%= (payment.balanceAfterPayment || 0).toFixed(2) %>
                                                </td>
                                                <td>
                                                    <%= payment.method %>
                                                </td>
                                                <td>
                                                    <span class="badge bg-<%= statusClass %>">
                                                        <%= payment.status %>
                                                    </span>
                                                </td>
                                                <td>
                                                    <a href="/finance/payments/<%= payment._id %>/receipt"
                                                        class="btn btn-sm btn-outline-primary" title="View Receipt">
                                                        <i class="fas fa-receipt"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                    <tfoot class="table-light fw-bold">
                                        <tr>
                                            <td colspan="4" class="text-end">TOTAL:</td>
                                            <td class="text-end balance-positive">
                                                ZMW <%= reportData.summary.totalAmount.toFixed(2) %>
                                            </td>
                                            <td class="text-end">
                                                ZMW <%= reportData.summary.totalDue.toFixed(2) %>
                                            </td>
                                            <td class="text-end balance-negative">
                                                ZMW <%= reportData.summary.totalBalance.toFixed(2) %>
                                            </td>
                                            <td colspan="3"></td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- Report Footer -->
                    <div class="mt-4 text-center">
                        <div class="alert alert-light border">
                            <p class="mb-1"><strong>Report Summary:</strong></p>
                            <p class="mb-0 small">
                                <i class="fas fa-clock me-1"></i>Generated: <%= reportData.generatedAt %> |
                                    <i class="fas fa-receipt me-1"></i>
                                    <%= reportData.payments.length %> payments |
                                        <i class="fas fa-money-bill-wave me-1"></i>Collected: ZMW <%=
                                            reportData.summary.totalAmount.toFixed(2) %> |
                                            <i class="fas fa-scale-balanced me-1"></i>Balance: ZMW <%=
                                                reportData.summary.totalBalance.toFixed(2) %>
                            </p>
                        </div>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="/finance/reports" class="btn btn-outline-primary">
                                <i class="fas fa-redo me-1"></i> New Report
                            </a>
                            <a href="/finance/reports/generate?startDate=<%= reportData.dateRange.start %>&endDate=<%= reportData.dateRange.end %>&outputFormat=pdf"
                                class="btn btn-primary btn-gradient" target="_blank">
                                <i class="fas fa-file-pdf me-1"></i> Download PDF
                            </a>
                            <button class="btn btn-success btn-gradient" onclick="window.print()">
                                <i class="fas fa-print me-1"></i> Print
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            /* Inline styles matching the reports page */
            .btn-gradient {
                background: linear-gradient(45deg, #4e73df, #224abe);
                border: none;
                color: white;
                transition: all 0.3s;
            }

            .btn-gradient:hover {
                background: linear-gradient(45deg, #224abe, #4e73df);
                transform: translateY(-2px);
                box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            }

            .bg-gradient-primary {
                background: linear-gradient(45deg, #4e73df, #1cc88a);
            }

            .stat-card {
                border-radius: 15px;
                transition: transform 0.3s, box-shadow 0.3s;
                border: none;
                box-shadow: 0 3px 10px rgba(0, 0, 0, 0.08);
            }

            .stat-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            }

            .balance-positive {
                color: #1cc88a;
                font-weight: bold;
            }

            .balance-negative {
                color: #e74a3b;
                font-weight: bold;
            }

            .balance-neutral {
                color: #6c757d;
                font-weight: bold;
            }

            .progress-bar-balance {
                height: 10px;
                border-radius: 5px;
                background: linear-gradient(90deg, #e74a3b, #f6c23e, #1cc88a);
            }

            .category-badge {
                font-size: 0.75em;
                padding: 4px 10px;
                border-radius: 20px;
                background: linear-gradient(45deg, #6c757d, #858796);
                color: white;
            }

            .table-hover tbody tr:hover {
                background: linear-gradient(90deg, rgba(78, 115, 223, 0.05), rgba(28, 200, 138, 0.05));
            }

            @media print {

                .btn,
                .card-header .d-flex,
                .alert,
                .text-end .alert {
                    display: none !important;
                }

                .card {
                    border: 1px solid #ddd !important;
                    box-shadow: none !important;
                }

                .card-body {
                    padding: 0 !important;
                }

                table {
                    font-size: 10px !important;
                }

                h4,
                h5,
                h6 {
                    margin-top: 5px !important;
                    margin-bottom: 5px !important;
                }

                .balance-positive,
                .balance-negative {
                    color: #000 !important;
                }
            }
        </style>

        <script>
            function togglePaymentDetails() {
                const details = document.getElementById('paymentDetails');
                if (details.classList.contains('d-none')) {
                    details.classList.remove('d-none');
                } else {
                    details.classList.add('d-none');
                }
            }

            // Add print styles
            const style = document.createElement('style');
            style.textContent = `
        @media print {
            .btn, .card-header .d-flex, .alert, .text-end .alert {
                display: none !important;
            }
            .card {
                border: 1px solid #ddd !important;
                box-shadow: none !important;
            }
            .card-body {
                padding: 0 !important;
            }
            table {
                font-size: 11px !important;
            }
            h4, h5, h6 {
                margin-top: 5px !important;
                margin-bottom: 5px !important;
            }
            .balance-positive, .balance-negative {
                color: #000 !important;
            }
        }
    `;
            document.head.appendChild(style);
        </script>

        <%- include('../partials/footer') %>