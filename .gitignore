cat > .gitignore << 'EOF'
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# Env files
.env
backend/.env

# OS, editors
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
logs/
*.log

# Build / dist
dist/
build/

# Misc
*.sqlite
EOF


# Backend seed files to ignore
backend/seedAllTraining.js
backend/seedTraining.js
backend/seedAdmissionOfficer.js
backend/seedFinaceOfficer.js